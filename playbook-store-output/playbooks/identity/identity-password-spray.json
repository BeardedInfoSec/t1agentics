{
  "name": "Password Spray Detection & Response",
  "slug": "identity-password-spray",
  "description": "Detects and responds to password spray attacks targeting multiple accounts with common passwords. Uses AI to analyze authentication patterns, evaluates the scope of affected accounts, locks targeted accounts exceeding failure thresholds, blocks the source IP on the perimeter firewall, and notifies the SOC team with full attack details.",
  "category": "identity",
  "subcategory": "password_spray",
  "author": "T1 Agentics",
  "version": "1.0.0",
  "difficulty": "intermediate",
  "estimated_time": "8 minutes",
  "tags": ["password_spray", "credential_attack", "authentication", "lockout", "automated"],
  "alert_types": ["password_spray", "brute_force", "authentication"],
  "severity_filter": ["medium", "high", "critical"],
  "trigger_conditions": {
    "alert_types": ["password_spray", "brute_force"],
    "min_severity": "medium"
  },
  "required_integrations": [
    {
      "connector_id": "microsoft_graph",
      "name": "Microsoft Graph",
      "category": "identity",
      "reason": "Lock targeted user accounts and retrieve sign-in activity logs"
    },
    {
      "connector_id": "palo_alto_ngfw",
      "name": "Palo Alto NGFW",
      "category": "network",
      "reason": "Block attacker source IP on perimeter firewall"
    }
  ],
  "canvas_data": {
    "nodes": [
      {
        "id": "ps-1",
        "type": "signal",
        "position": { "x": 520, "y": 60 },
        "data": {
          "kind": "trigger",
          "title": "Password Spray Alert",
          "summary": "Fires on password spray or distributed brute force alert",
          "config": {
            "trigger_type": "alert",
            "alert_filter": "password_spray OR brute_force"
          }
        }
      },
      {
        "id": "ps-2",
        "type": "signal",
        "position": { "x": 520, "y": 220 },
        "data": {
          "kind": "analyze",
          "title": "AI Password Spray Analysis",
          "summary": "Analyze authentication logs for password spray patterns across multiple accounts",
          "config": {
            "mode": "ai_analysis",
            "template_id": "brute_force",
            "custom_instructions": "",
            "alert_path": "$.trigger.alert",
            "include_context": true
          }
        }
      },
      {
        "id": "ps-3",
        "type": "signal",
        "position": { "x": 520, "y": 380 },
        "data": {
          "kind": "decision",
          "title": "> 5 Accounts Targeted?",
          "summary": "Branch if multiple accounts were targeted in spray attack",
          "config": {
            "conditions": {
              "operator": "AND",
              "conditions": [
                {
                  "field": "$.trigger.alert.targeted_account_count",
                  "operator": "greater_than",
                  "value": "5"
                }
              ],
              "groups": []
            },
            "expression": "$.trigger.alert.targeted_account_count > 5",
            "default_branch": "no"
          }
        }
      },
      {
        "id": "ps-4",
        "type": "signal",
        "position": { "x": 340, "y": 540 },
        "data": {
          "kind": "respond",
          "title": "Lock Targeted Accounts",
          "summary": "Disable all accounts that received failed login attempts from spray source",
          "config": {
            "response_type": "integration_action",
            "integration_instance_id": "microsoft_graph",
            "action_type": "disable_accounts_bulk",
            "params": {
              "user_ids": "$.trigger.alert.targeted_user_ids",
              "reason": "Password spray attack detected — automated lockout of targeted accounts"
            },
            "requires_approval": false,
            "priority": "high"
          }
        }
      },
      {
        "id": "ps-5",
        "type": "signal",
        "position": { "x": 340, "y": 700 },
        "data": {
          "kind": "respond",
          "title": "Block Source IP",
          "summary": "Block attacker source IP on perimeter firewall for 48 hours",
          "config": {
            "response_type": "integration_action",
            "integration_instance_id": "palo_alto_ngfw",
            "action_type": "block_ip",
            "params": {
              "ip_address": "$.trigger.alert.source_ip",
              "duration_hours": 48,
              "reason": "Password spray attack source"
            },
            "requires_approval": false,
            "priority": "high"
          }
        }
      },
      {
        "id": "ps-6",
        "type": "signal",
        "position": { "x": 340, "y": 860 },
        "data": {
          "kind": "analyze",
          "title": "Generate Executive Summary",
          "summary": "AI-generated executive summary of the password spray incident",
          "config": {
            "mode": "ai_analysis",
            "template_id": "executive_summary",
            "custom_instructions": "",
            "alert_path": "$.trigger.alert",
            "include_context": true
          }
        }
      },
      {
        "id": "ps-7",
        "type": "signal",
        "position": { "x": 340, "y": 1020 },
        "data": {
          "kind": "respond",
          "title": "Notify SOC on Slack",
          "summary": "Send Slack notification with password spray details and containment actions",
          "config": {
            "response_type": "notification",
            "channel": "slack",
            "slack_channel": "#soc-alerts",
            "message": "Password spray attack detected. {{$.trigger.alert.targeted_account_count}} accounts targeted from {{$.trigger.alert.source_ip}}. Accounts locked and source IP blocked for 48h. {{$.nodes.ps-6.result.summary}}",
            "requires_approval": false,
            "priority": "high"
          }
        }
      },
      {
        "id": "ps-8",
        "type": "signal",
        "position": { "x": 700, "y": 540 },
        "data": {
          "kind": "utility",
          "title": "Add Monitoring Note",
          "summary": "Log note that spray was limited scope and is being monitored",
          "config": {
            "operation": "add_note",
            "note": "Password spray alert reviewed. Fewer than 5 accounts targeted. Continuing to monitor for escalation."
          }
        }
      },
      {
        "id": "ps-9",
        "type": "signal",
        "position": { "x": 520, "y": 1180 },
        "data": {
          "kind": "end",
          "title": "Playbook Complete",
          "summary": "Password spray response finished",
          "config": {
            "disposition": "completed",
            "summary": "Password spray detection and response actions completed"
          }
        }
      }
    ],
    "edges": [
      { "id": "ps-e1", "source": "ps-1", "target": "ps-2", "animated": true, "type": "smoothstep" },
      { "id": "ps-e2", "source": "ps-2", "target": "ps-3", "animated": true, "type": "smoothstep" },
      { "id": "ps-e3", "source": "ps-3", "target": "ps-4", "sourceHandle": "yes", "label": "Yes", "animated": true, "type": "smoothstep" },
      { "id": "ps-e4", "source": "ps-3", "target": "ps-8", "sourceHandle": "no", "label": "No", "animated": true, "type": "smoothstep" },
      { "id": "ps-e5", "source": "ps-4", "target": "ps-5", "animated": true, "type": "smoothstep" },
      { "id": "ps-e6", "source": "ps-5", "target": "ps-6", "animated": true, "type": "smoothstep" },
      { "id": "ps-e7", "source": "ps-6", "target": "ps-7", "animated": true, "type": "smoothstep" },
      { "id": "ps-e8", "source": "ps-7", "target": "ps-9", "animated": true, "type": "smoothstep" },
      { "id": "ps-e9", "source": "ps-8", "target": "ps-9", "animated": true, "type": "smoothstep" }
    ]
  }
}