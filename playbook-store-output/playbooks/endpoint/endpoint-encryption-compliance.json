{
  "name": "Disk Encryption Compliance",
  "slug": "endpoint-encryption-compliance",
  "description": "Verifies disk encryption compliance on managed endpoints by checking BitLocker (Windows) or FileVault (macOS) status. Non-compliant endpoints receive an automated enforcement command to enable encryption. If enforcement fails, an approval gate escalates to the security team for manual remediation. Compliant endpoints are logged and closed.",
  "category": "endpoint",
  "subcategory": "encryption_compliance",
  "author": "T1 Agentics",
  "version": "1.0.0",
  "difficulty": "intermediate",
  "estimated_time": "10 minutes",
  "tags": ["encryption", "bitlocker", "filevault", "compliance", "endpoint", "disk_security"],
  "alert_types": ["encryption_compliance", "disk_encryption"],
  "severity_filter": ["medium", "high", "critical"],
  "trigger_conditions": {
    "alert_types": ["encryption_compliance", "disk_encryption", "compliance_scan"],
    "min_severity": "medium"
  },
  "required_integrations": [
    {
      "connector_id": "crowdstrike",
      "name": "CrowdStrike Falcon",
      "category": "edr",
      "reason": "Query disk encryption status and push enforcement commands"
    },
    {
      "connector_id": "microsoft_intune",
      "name": "Microsoft Intune",
      "category": "endpoint_management",
      "reason": "Enforce BitLocker/FileVault policy on non-compliant endpoints"
    }
  ],
  "canvas_data": {
    "nodes": [
      {
        "id": "trigger_1",
        "type": "signal",
        "position": { "x": 520, "y": 60 },
        "data": {
          "kind": "trigger",
          "label": "Encryption Compliance Alert",
          "config": {
            "alert_types": ["encryption_compliance", "disk_encryption", "compliance_scan"],
            "description": "Triggers when an endpoint fails a disk encryption compliance check"
          }
        }
      },
      {
        "id": "code_1",
        "type": "signal",
        "position": { "x": 520, "y": 220 },
        "data": {
          "kind": "code",
          "label": "Check Encryption Status",
          "config": {
            "runtime": "python3",
            "code": "os_type = alert.get('os_type', 'windows').lower()\nencryption_status = alert.get('encryption_status', 'unknown')\nis_encrypted = encryption_status in ['encrypted', 'enabled', 'on']\nencryption_tool = 'BitLocker' if 'windows' in os_type else 'FileVault'\nresult = {'is_encrypted': is_encrypted, 'os_type': os_type, 'encryption_tool': encryption_tool, 'current_status': encryption_status}",
            "description": "Determine the encryption status and identify the appropriate encryption tool for the OS"
          }
        }
      },
      {
        "id": "decision_1",
        "type": "signal",
        "position": { "x": 520, "y": 380 },
        "data": {
          "kind": "decision",
          "label": "Disk Encrypted?",
          "config": {
            "condition": "{{code_1.is_encrypted}} == true",
            "description": "Routes based on whether the endpoint's disk is currently encrypted"
          }
        }
      },
      {
        "id": "utility_1",
        "type": "signal",
        "position": { "x": 340, "y": 540 },
        "data": {
          "kind": "utility",
          "label": "Log: Compliant",
          "config": {
            "action": "add_note",
            "parameters": {
              "note": "Endpoint {{trigger_1.alert.hostname}} is compliant. {{code_1.encryption_tool}} is enabled (Status: {{code_1.current_status}}).",
              "close_alert": true
            },
            "description": "Document that the endpoint is encryption-compliant and close the alert"
          }
        }
      },
      {
        "id": "respond_1",
        "type": "signal",
        "position": { "x": 700, "y": 540 },
        "data": {
          "kind": "respond",
          "label": "Enforce Encryption",
          "config": {
            "integration_action": {
              "connector_id": "microsoft_intune",
              "action": "enforce_encryption_policy",
              "parameters": {
                "device_id": "{{trigger_1.alert.endpoint_id}}",
                "encryption_type": "{{code_1.encryption_tool}}",
                "hostname": "{{trigger_1.alert.hostname}}"
              }
            },
            "description": "Push encryption enforcement command via Intune to enable BitLocker or FileVault"
          }
        }
      },
      {
        "id": "delay_1",
        "type": "signal",
        "position": { "x": 700, "y": 700 },
        "data": {
          "kind": "delay",
          "label": "Wait 10 Minutes",
          "config": {
            "duration_seconds": 600,
            "description": "Wait for the encryption enforcement to take effect before verification"
          }
        }
      },
      {
        "id": "decision_2",
        "type": "signal",
        "position": { "x": 700, "y": 860 },
        "data": {
          "kind": "decision",
          "label": "Enforcement Successful?",
          "config": {
            "condition": "{{respond_1.status}} == 'success'",
            "description": "Routes based on whether the encryption enforcement command succeeded"
          }
        }
      },
      {
        "id": "respond_2",
        "type": "signal",
        "position": { "x": 520, "y": 1020 },
        "data": {
          "kind": "respond",
          "label": "Notify SOC on Slack",
          "config": {
            "notify": {
              "channel": "slack",
              "target": "#soc-alerts",
              "message": "ENCRYPTION ENFORCED\nHost: {{trigger_1.alert.hostname}}\nOS: {{code_1.os_type}}\nTool: {{code_1.encryption_tool}}\nPrevious Status: {{code_1.current_status}}\nAction: Encryption policy enforced via Intune"
            },
            "description": "Notify the SOC that encryption has been successfully enforced"
          }
        }
      },
      {
        "id": "approval_1",
        "type": "signal",
        "position": { "x": 880, "y": 1020 },
        "data": {
          "kind": "approval",
          "label": "Escalate for Manual Fix",
          "config": {
            "approver_role": "soc_analyst",
            "timeout_minutes": 60,
            "message": "Encryption enforcement FAILED on {{trigger_1.alert.hostname}} ({{code_1.os_type}}).\n{{code_1.encryption_tool}} could not be enabled automatically.\nPlease investigate and remediate manually.",
            "description": "Escalate to security team when automated encryption enforcement fails"
          }
        }
      },
      {
        "id": "end_1",
        "type": "signal",
        "position": { "x": 520, "y": 1180 },
        "data": {
          "kind": "end",
          "label": "End",
          "config": {
            "description": "Disk encryption compliance workflow complete"
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e_trigger_code",
        "source": "trigger_1",
        "target": "code_1",
        "type": "default"
      },
      {
        "id": "e_code_decision",
        "source": "code_1",
        "target": "decision_1",
        "type": "default"
      },
      {
        "id": "e_decision_yes",
        "source": "decision_1",
        "target": "utility_1",
        "type": "default",
        "sourceHandle": "yes",
        "label": "Yes"
      },
      {
        "id": "e_decision_no",
        "source": "decision_1",
        "target": "respond_1",
        "type": "default",
        "sourceHandle": "no",
        "label": "No"
      },
      {
        "id": "e_enforce_delay",
        "source": "respond_1",
        "target": "delay_1",
        "type": "default"
      },
      {
        "id": "e_delay_decision2",
        "source": "delay_1",
        "target": "decision_2",
        "type": "default"
      },
      {
        "id": "e_decision2_yes",
        "source": "decision_2",
        "target": "respond_2",
        "type": "default",
        "sourceHandle": "yes",
        "label": "Yes"
      },
      {
        "id": "e_decision2_no",
        "source": "decision_2",
        "target": "approval_1",
        "type": "default",
        "sourceHandle": "no",
        "label": "No"
      },
      {
        "id": "e_notify_end",
        "source": "respond_2",
        "target": "end_1",
        "type": "default"
      },
      {
        "id": "e_approval_end",
        "source": "approval_1",
        "target": "end_1",
        "type": "default"
      },
      {
        "id": "e_utility_end",
        "source": "utility_1",
        "target": "end_1",
        "type": "default"
      }
    ]
  }
}