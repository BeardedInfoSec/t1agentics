{
  "id": "fortinet_fortindr",
  "name": "Fortinet FortiNDR Cloud",
  "description": "Cloud-native network detection and response solution with AI-powered threat detection and automated investigation for enterprise networks",
  "version": "1.0.0",
  "category": "ndr",
  "vendor": "Fortinet",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "location": "header",
    "header_name": "Authorization",
    "prefix": "Bearer "
  },
  "base_url": "https://{host}/api/v1",
  "actions": [
    {
      "id": "get_detections",
      "name": "Get Detections",
      "description": "Retrieve detections that meet specified filter criteria",
      "http_method": "GET",
      "endpoint": "/detections",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "created_or_shared_start_date",
          "type": "string",
          "description": "Start date for detection interval in ISO 8601 format",
          "required": false
        },
        {
          "name": "created_or_shared_end_date",
          "type": "string",
          "description": "End date for detection interval in ISO 8601 format",
          "required": false
        },
        {
          "name": "status",
          "type": "string",
          "description": "Filter by detection status (active, resolved)",
          "required": false
        },
        {
          "name": "device_ip",
          "type": "string",
          "description": "Filter by device IP address",
          "required": false
        },
        {
          "name": "rule_uuid",
          "type": "string",
          "description": "Filter by detection rule UUID",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of detections to return",
          "required": false,
          "default": 100
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "get_detection_details",
      "name": "Get Detection Details",
      "description": "Retrieve detailed information about a specific detection",
      "http_method": "GET",
      "endpoint": "/detections/{detection_uuid}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "detection_uuid",
          "type": "string",
          "description": "The detection UUID",
          "required": true
        }
      ]
    },
    {
      "id": "get_detection_rules",
      "name": "Get Detection Rules",
      "description": "Retrieve a list of all detection rules",
      "http_method": "GET",
      "endpoint": "/detection_rules",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of rules to return",
          "required": false,
          "default": 100
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "get_sensors",
      "name": "Get Sensors",
      "description": "Retrieve a list of all FortiNDR sensors and their status",
      "http_method": "GET",
      "endpoint": "/sensors",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "get_devices",
      "name": "Get Devices",
      "description": "Retrieve a list of discovered network devices",
      "http_method": "GET",
      "endpoint": "/devices",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "ip_address",
          "type": "string",
          "description": "Filter by IP address",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of devices to return",
          "required": false,
          "default": 100
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "search_events",
      "name": "Search Events",
      "description": "Search for network events matching specified criteria",
      "http_method": "POST",
      "endpoint": "/events/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query string",
          "required": true
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_date",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of events to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "resolve_detection",
      "name": "Resolve Detection",
      "description": "Mark a detection as resolved",
      "http_method": "PUT",
      "endpoint": "/detections/{detection_uuid}/resolve",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "detection_uuid",
          "type": "string",
          "description": "The detection UUID to resolve",
          "required": true
        },
        {
          "name": "resolution",
          "type": "string",
          "description": "Resolution type (true_positive, false_positive, benign)",
          "required": true
        }
      ]
    },
    {
      "id": "create_detection_rule",
      "name": "Create Detection Rule",
      "description": "Create a new custom detection rule",
      "http_method": "POST",
      "endpoint": "/detection_rules",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "name",
          "type": "string",
          "description": "Name of the detection rule",
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "description": "Description of the rule",
          "required": true
        },
        {
          "name": "query",
          "type": "string",
          "description": "Detection query expression",
          "required": true
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Severity level (low, medium, high)",
          "required": true
        }
      ]
    }
  ]
}