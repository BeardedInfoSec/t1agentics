{
  "id": "cisco_stealthwatch",
  "name": "Cisco Secure Network Analytics",
  "description": "Network visibility and security analytics platform (formerly Stealthwatch) that detects threats using behavioral modeling and machine learning on network telemetry",
  "version": "1.0.0",
  "category": "ndr",
  "vendor": "Cisco",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Cookie",
    "location": "header",
    "note": "Uses session-based authentication via /token/v2/authenticate endpoint"
  },
  "base_url": "https://{host}/smc-configuration/rest/v1",
  "actions": [
    {
      "id": "get_security_events",
      "name": "Get Security Events",
      "description": "Retrieve security events and alerts from Secure Network Analytics",
      "http_method": "GET",
      "endpoint": "/tenants/{tenant_id}/security-events",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenant_id",
          "type": "number",
          "description": "Tenant (domain) ID",
          "required": true
        },
        {
          "name": "startTime",
          "type": "string",
          "description": "Start time in ISO 8601 format",
          "required": false
        },
        {
          "name": "endTime",
          "type": "string",
          "description": "End time in ISO 8601 format",
          "required": false
        }
      ]
    },
    {
      "id": "search_flows",
      "name": "Search Flows",
      "description": "Initialize a flow search based on specified criteria",
      "http_method": "POST",
      "endpoint": "/tenants/{tenant_id}/flow/queries",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenant_id",
          "type": "number",
          "description": "Tenant (domain) ID",
          "required": true
        },
        {
          "name": "startDateTime",
          "type": "string",
          "description": "Start time in ISO 8601 format",
          "required": true
        },
        {
          "name": "endDateTime",
          "type": "string",
          "description": "End time in ISO 8601 format",
          "required": true
        },
        {
          "name": "subject",
          "type": "object",
          "description": "Subject host filter criteria (ipAddresses, hostGroups)",
          "required": false
        },
        {
          "name": "peer",
          "type": "object",
          "description": "Peer host filter criteria (ipAddresses, hostGroups)",
          "required": false
        }
      ]
    },
    {
      "id": "get_flow_results",
      "name": "Get Flow Search Results",
      "description": "Retrieve results of a previously initiated flow search query",
      "http_method": "GET",
      "endpoint": "/tenants/{tenant_id}/flow/queries/{query_id}/results",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenant_id",
          "type": "number",
          "description": "Tenant (domain) ID",
          "required": true
        },
        {
          "name": "query_id",
          "type": "string",
          "description": "The query ID from the initiated flow search",
          "required": true
        }
      ]
    },
    {
      "id": "get_top_hosts",
      "name": "Get Top Hosts",
      "description": "Retrieve the top hosts by traffic or alarm activity",
      "http_method": "GET",
      "endpoint": "/tenants/{tenant_id}/top-hosts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenant_id",
          "type": "number",
          "description": "Tenant (domain) ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_host_groups",
      "name": "Get Host Groups",
      "description": "Retrieve all configured host groups",
      "http_method": "GET",
      "endpoint": "/tenants/{tenant_id}/tags",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenant_id",
          "type": "number",
          "description": "Tenant (domain) ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_tenants",
      "name": "Get Tenants",
      "description": "Retrieve all available tenants (domains) in the system",
      "http_method": "GET",
      "endpoint": "/tenants",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "get_threat_alerts",
      "name": "Get Global Threat Alerts",
      "description": "Retrieve global threat alerts detected by Secure Network Analytics",
      "http_method": "GET",
      "endpoint": "/tenants/{tenant_id}/threats",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenant_id",
          "type": "number",
          "description": "Tenant (domain) ID",
          "required": true
        },
        {
          "name": "startTime",
          "type": "string",
          "description": "Start time filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "endTime",
          "type": "string",
          "description": "End time filter in ISO 8601 format",
          "required": false
        }
      ]
    },
    {
      "id": "get_host_snapshot",
      "name": "Get Host Snapshot",
      "description": "Retrieve a snapshot of information about a specific host IP",
      "http_method": "GET",
      "endpoint": "/tenants/{tenant_id}/hosts/{ip_address}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenant_id",
          "type": "number",
          "description": "Tenant (domain) ID",
          "required": true
        },
        {
          "name": "ip_address",
          "type": "string",
          "description": "IP address of the host",
          "required": true
        }
      ]
    }
  ]
}