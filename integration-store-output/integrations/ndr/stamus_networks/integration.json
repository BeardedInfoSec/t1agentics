{
  "id": "stamus_networks",
  "name": "Stamus Networks",
  "description": "Suricata-based network detection and response platform providing IDS/IPS, network security monitoring, and automated threat detection with Host ID capabilities",
  "version": "1.0.0",
  "category": "ndr",
  "vendor": "Stamus Networks",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "location": "header",
    "header_name": "Authorization",
    "prefix": "Token "
  },
  "base_url": "https://{host}/rest",
  "actions": [
    {
      "id": "get_alerts",
      "name": "Get Alerts",
      "description": "Retrieve IDS alerts from Suricata detection engine",
      "http_method": "GET",
      "endpoint": "/rules/es/alerts/",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "from_date",
          "type": "string",
          "description": "Start date filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "to_date",
          "type": "string",
          "description": "End date filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "search",
          "type": "string",
          "description": "Full text search query",
          "required": false
        },
        {
          "name": "page",
          "type": "number",
          "description": "Page number for pagination",
          "required": false,
          "default": 1
        },
        {
          "name": "page_size",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_host_id",
      "name": "Get Host ID",
      "description": "Retrieve Host ID information for a specific IP address including all identification metadata",
      "http_method": "GET",
      "endpoint": "/appliances/host_id/{ip_address}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "ip_address",
          "type": "string",
          "description": "IP address of the host to retrieve identification data for",
          "required": true
        }
      ]
    },
    {
      "id": "get_rules",
      "name": "Get Rules",
      "description": "Retrieve Suricata rules and their status",
      "http_method": "GET",
      "endpoint": "/rules/rule/",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "search",
          "type": "string",
          "description": "Search query to filter rules",
          "required": false
        },
        {
          "name": "page",
          "type": "number",
          "description": "Page number for pagination",
          "required": false,
          "default": 1
        },
        {
          "name": "page_size",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_rulesets",
      "name": "Get Rulesets",
      "description": "Retrieve configured rulesets and their sources",
      "http_method": "GET",
      "endpoint": "/rules/ruleset/",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "get_threats",
      "name": "Get Threats",
      "description": "Retrieve identified threats from Stamus Security Platform",
      "http_method": "GET",
      "endpoint": "/rules/es/threats/",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "from_date",
          "type": "string",
          "description": "Start date filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "to_date",
          "type": "string",
          "description": "End date filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "search",
          "type": "string",
          "description": "Full text search query",
          "required": false
        },
        {
          "name": "page",
          "type": "number",
          "description": "Page number for pagination",
          "required": false,
          "default": 1
        }
      ]
    },
    {
      "id": "get_appliances",
      "name": "Get Appliances",
      "description": "Retrieve a list of managed sensor appliances and their status",
      "http_method": "GET",
      "endpoint": "/appliances/appliance/",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "enable_rule",
      "name": "Enable Rule",
      "description": "Enable a specific Suricata detection rule in a ruleset",
      "http_method": "POST",
      "endpoint": "/rules/rule/{rule_sid}/enable/",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "rule_sid",
          "type": "number",
          "description": "Suricata rule SID",
          "required": true
        },
        {
          "name": "ruleset_id",
          "type": "number",
          "description": "Ruleset ID to enable the rule in",
          "required": true
        }
      ]
    },
    {
      "id": "disable_rule",
      "name": "Disable Rule",
      "description": "Disable a specific Suricata detection rule in a ruleset",
      "http_method": "POST",
      "endpoint": "/rules/rule/{rule_sid}/disable/",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "rule_sid",
          "type": "number",
          "description": "Suricata rule SID",
          "required": true
        },
        {
          "name": "ruleset_id",
          "type": "number",
          "description": "Ruleset ID to disable the rule in",
          "required": true
        }
      ]
    }
  ]
}