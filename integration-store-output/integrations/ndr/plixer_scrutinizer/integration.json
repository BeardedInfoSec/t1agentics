{
  "id": "plixer_scrutinizer",
  "name": "Plixer Scrutinizer",
  "description": "Network traffic analytics and flow-based NDR platform providing deep visibility into network behavior with advanced anomaly detection and forensics",
  "version": "1.0.0",
  "category": "ndr",
  "vendor": "Plixer (Keysight)",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header",
    "prefix": "Bearer"
  },
  "base_url": "https://{host}/fcgi/scrut_fcgi.fcgi",
  "actions": [
    {
      "id": "run_report",
      "name": "Run Report",
      "description": "Execute a flow analytics report and retrieve network traffic data",
      "http_method": "POST",
      "endpoint": "/",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "rpt_json",
          "type": "string",
          "description": "JSON report definition including report type, timeframe, filters, and aggregation settings",
          "required": true
        },
        {
          "name": "data_requested",
          "type": "string",
          "description": "JSON specifying how to prepare data for graphs and table pagination",
          "required": true
        }
      ]
    },
    {
      "id": "get_alarms",
      "name": "Get Alarms",
      "description": "Retrieve active flow analytics alarms and security events",
      "http_method": "GET",
      "endpoint": "/alarms",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by alarm severity",
          "required": false
        },
        {
          "name": "status",
          "type": "string",
          "description": "Filter by alarm status (active, acknowledged, resolved)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of alarms to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_alarm_details",
      "name": "Get Alarm Details",
      "description": "Retrieve detailed information about a specific alarm",
      "http_method": "GET",
      "endpoint": "/alarms/{alarm_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alarm_id",
          "type": "number",
          "description": "The alarm ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_exporters",
      "name": "Get Exporters",
      "description": "Retrieve a list of all flow exporters (routers, switches, firewalls)",
      "http_method": "GET",
      "endpoint": "/exporters",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "search_flows",
      "name": "Search Flows",
      "description": "Search network flow records with filtering criteria",
      "http_method": "POST",
      "endpoint": "/flows/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "src_ip",
          "type": "string",
          "description": "Source IP address filter",
          "required": false
        },
        {
          "name": "dst_ip",
          "type": "string",
          "description": "Destination IP address filter",
          "required": false
        },
        {
          "name": "src_port",
          "type": "number",
          "description": "Source port filter",
          "required": false
        },
        {
          "name": "dst_port",
          "type": "number",
          "description": "Destination port filter",
          "required": false
        },
        {
          "name": "protocol",
          "type": "string",
          "description": "Protocol filter (TCP, UDP, ICMP)",
          "required": false
        },
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in ISO 8601 format",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of flow records to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "acknowledge_alarm",
      "name": "Acknowledge Alarm",
      "description": "Acknowledge an active alarm to indicate it is being investigated",
      "http_method": "PUT",
      "endpoint": "/alarms/{alarm_id}/acknowledge",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "alarm_id",
          "type": "number",
          "description": "The alarm ID to acknowledge",
          "required": true
        }
      ]
    },
    {
      "id": "get_system_status",
      "name": "Get System Status",
      "description": "Retrieve system health and status information",
      "http_method": "GET",
      "endpoint": "/system/status",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    }
  ]
}