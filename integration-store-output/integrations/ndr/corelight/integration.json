{
  "id": "corelight",
  "name": "Corelight",
  "description": "Open NDR platform built on Zeek that transforms network traffic into rich logs and detections for threat hunting and investigation",
  "version": "1.0.0",
  "category": "ndr",
  "vendor": "Corelight",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header",
    "prefix": "Bearer"
  },
  "base_url": "https://{host}/api/v1",
  "actions": [
    {
      "id": "get_alerts",
      "name": "Get Alerts",
      "description": "Retrieve alerts generated by Corelight sensors and detections",
      "http_method": "GET",
      "endpoint": "/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity level (low, medium, high, critical)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of alerts to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_alert_details",
      "name": "Get Alert Details",
      "description": "Retrieve detailed information about a specific alert",
      "http_method": "GET",
      "endpoint": "/alerts/{alert_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "The alert ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_sensors",
      "name": "Get Sensors",
      "description": "Retrieve a list of all Corelight sensors and their status",
      "http_method": "GET",
      "endpoint": "/sensors",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "get_sensor_details",
      "name": "Get Sensor Details",
      "description": "Retrieve detailed information about a specific sensor",
      "http_method": "GET",
      "endpoint": "/sensors/{sensor_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "sensor_id",
          "type": "string",
          "description": "The sensor ID",
          "required": true
        }
      ]
    },
    {
      "id": "search_connections",
      "name": "Search Connections",
      "description": "Search connection logs (conn.log) for network flow data",
      "http_method": "POST",
      "endpoint": "/connections/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "src_ip",
          "type": "string",
          "description": "Source IP address filter",
          "required": false
        },
        {
          "name": "dst_ip",
          "type": "string",
          "description": "Destination IP address filter",
          "required": false
        },
        {
          "name": "dst_port",
          "type": "number",
          "description": "Destination port filter",
          "required": false
        },
        {
          "name": "proto",
          "type": "string",
          "description": "Protocol filter (tcp, udp, icmp)",
          "required": false
        },
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in ISO 8601 format",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of results",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "search_dns",
      "name": "Search DNS Logs",
      "description": "Search DNS query and response logs",
      "http_method": "POST",
      "endpoint": "/dns/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "DNS query name to search for",
          "required": false
        },
        {
          "name": "src_ip",
          "type": "string",
          "description": "Source IP of the DNS query",
          "required": false
        },
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in ISO 8601 format",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of results",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_suricata_alerts",
      "name": "Get Suricata Alerts",
      "description": "Retrieve IDS alerts generated by Suricata rules",
      "http_method": "GET",
      "endpoint": "/suricata/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "severity",
          "type": "number",
          "description": "Suricata alert severity (1-3)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of alerts to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_system_health",
      "name": "Get System Health",
      "description": "Retrieve system health and performance metrics",
      "http_method": "GET",
      "endpoint": "/system/health",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    }
  ]
}