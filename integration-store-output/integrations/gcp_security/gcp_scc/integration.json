{
  "id": "gcp_scc",
  "name": "Google Cloud Security Command Center",
  "description": "Google Cloud centralized security management platform providing threat detection, vulnerability scanning, compliance monitoring, and asset discovery across GCP resources",
  "version": "1.0.0",
  "category": "gcp_security",
  "vendor": "Google Cloud",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "token_url": "https://oauth2.googleapis.com/token",
    "scope": "https://www.googleapis.com/auth/cloud-platform",
    "grant_type": "urn:ietf:params:oauth:grant-type:jwt-bearer"
  },
  "base_url": "https://securitycenter.googleapis.com/v1",
  "actions": [
    {
      "id": "list_findings",
      "name": "List Findings",
      "description": "List Security Command Center findings for an organization with optional filter and ordering",
      "http_method": "GET",
      "endpoint": "/organizations/{organizationId}/sources/-/findings",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "organizationId",
          "type": "string",
          "description": "GCP organization ID",
          "required": true
        },
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression (e.g., \"severity=\\\"CRITICAL\\\" AND state=\\\"ACTIVE\\\"\")",
          "required": false
        },
        {
          "name": "orderBy",
          "type": "string",
          "description": "Order by field (e.g., \"eventTime desc\")",
          "required": false
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Maximum findings to return per page",
          "required": false,
          "default": 100
        },
        {
          "name": "pageToken",
          "type": "string",
          "description": "Pagination token for next page",
          "required": false
        }
      ]
    },
    {
      "id": "get_finding",
      "name": "Get Finding Details",
      "description": "Retrieve detailed information about a specific SCC finding",
      "http_method": "GET",
      "endpoint": "/organizations/{organizationId}/sources/{sourceId}/findings/{findingId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "organizationId",
          "type": "string",
          "description": "GCP organization ID",
          "required": true
        },
        {
          "name": "sourceId",
          "type": "string",
          "description": "SCC source ID",
          "required": true
        },
        {
          "name": "findingId",
          "type": "string",
          "description": "Finding ID",
          "required": true
        }
      ]
    },
    {
      "id": "list_assets",
      "name": "List Assets",
      "description": "List cloud assets monitored by Security Command Center with security marks and attributes",
      "http_method": "GET",
      "endpoint": "/organizations/{organizationId}/assets",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "organizationId",
          "type": "string",
          "description": "GCP organization ID",
          "required": true
        },
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression (e.g., \"securityCenterProperties.resourceType=\\\"google.compute.Instance\\\"\")",
          "required": false
        },
        {
          "name": "orderBy",
          "type": "string",
          "description": "Order by field",
          "required": false
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Maximum assets to return per page",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "list_sources",
      "name": "List Sources",
      "description": "List all SCC sources including built-in and third-party sources",
      "http_method": "GET",
      "endpoint": "/organizations/{organizationId}/sources",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "organizationId",
          "type": "string",
          "description": "GCP organization ID",
          "required": true
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Maximum sources to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "list_notification_configs",
      "name": "List Notification Configs",
      "description": "List notification configurations for findings export to Pub/Sub",
      "http_method": "GET",
      "endpoint": "/organizations/{organizationId}/notificationConfigs",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "organizationId",
          "type": "string",
          "description": "GCP organization ID",
          "required": true
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Maximum configs to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "update_finding_state",
      "name": "Update Finding State",
      "description": "Update the state of a specific finding (active or inactive)",
      "http_method": "POST",
      "endpoint": "/organizations/{organizationId}/sources/{sourceId}/findings/{findingId}:setState",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "organizationId",
          "type": "string",
          "description": "GCP organization ID",
          "required": true
        },
        {
          "name": "sourceId",
          "type": "string",
          "description": "SCC source ID",
          "required": true
        },
        {
          "name": "findingId",
          "type": "string",
          "description": "Finding ID",
          "required": true
        },
        {
          "name": "state",
          "type": "string",
          "description": "New state (ACTIVE or INACTIVE)",
          "required": true
        }
      ]
    }
  ]
}