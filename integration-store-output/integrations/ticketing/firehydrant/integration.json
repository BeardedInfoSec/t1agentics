{
  "id": "firehydrant",
  "name": "FireHydrant",
  "description": "Integrates with FireHydrant REST API v1 for incident management, service cataloging, and reliability tracking",
  "version": "1.0.0",
  "category": "ticketing",
  "vendor": "FireHydrant",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://api.firehydrant.io/v1",
  "actions": [
    {
      "id": "create_incident",
      "name": "Create Incident",
      "description": "Declare a new incident in FireHydrant",
      "http_method": "POST",
      "endpoint": "/incidents",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "name", "type": "string", "description": "Incident name/title", "required": true},
        {"name": "description", "type": "string", "description": "Detailed incident description", "required": false},
        {"name": "severity", "type": "string", "description": "Severity slug (e.g. SEV1, SEV2)", "required": false},
        {"name": "priority", "type": "string", "description": "Priority slug (e.g. P1, P2)", "required": false},
        {"name": "impacts", "type": "string", "description": "JSON array of impact objects with type, id, and condition_id", "required": false},
        {"name": "labels", "type": "string", "description": "JSON object of label key-value pairs", "required": false}
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident",
      "description": "Retrieve details of a specific FireHydrant incident",
      "http_method": "GET",
      "endpoint": "/incidents/{incident_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "incident_id", "type": "string", "description": "Incident ID", "required": true}
      ]
    },
    {
      "id": "update_incident",
      "name": "Update Incident",
      "description": "Update an existing FireHydrant incident",
      "http_method": "PATCH",
      "endpoint": "/incidents/{incident_id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incident_id", "type": "string", "description": "Incident ID to update", "required": true},
        {"name": "name", "type": "string", "description": "Updated name", "required": false},
        {"name": "description", "type": "string", "description": "Updated description", "required": false},
        {"name": "severity", "type": "string", "description": "Updated severity slug", "required": false},
        {"name": "priority", "type": "string", "description": "Updated priority slug", "required": false}
      ]
    },
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "List and filter FireHydrant incidents",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "status", "type": "string", "description": "Filter by status (active, closed)", "required": false},
        {"name": "severity", "type": "string", "description": "Filter by severity slug", "required": false},
        {"name": "query", "type": "string", "description": "Search query string", "required": false},
        {"name": "page", "type": "number", "description": "Page number", "required": false, "default": 1},
        {"name": "per_page", "type": "number", "description": "Results per page", "required": false, "default": 20}
      ]
    },
    {
      "id": "add_note",
      "name": "Add Note",
      "description": "Add a note/event to an incident timeline",
      "http_method": "POST",
      "endpoint": "/incidents/{incident_id}/notes",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incident_id", "type": "string", "description": "Incident ID", "required": true},
        {"name": "body", "type": "string", "description": "Note content", "required": true}
      ]
    },
    {
      "id": "close_incident",
      "name": "Close Incident",
      "description": "Close a FireHydrant incident by updating its milestone",
      "http_method": "PATCH",
      "endpoint": "/incidents/{incident_id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incident_id", "type": "string", "description": "Incident ID to close", "required": true},
        {"name": "summary", "type": "string", "description": "Resolution summary", "required": false}
      ]
    }
  ]
}
