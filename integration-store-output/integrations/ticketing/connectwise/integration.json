{
  "id": "connectwise",
  "name": "ConnectWise Manage",
  "description": "Integrates with ConnectWise Manage REST API for service ticket management, project tracking, and IT business operations",
  "version": "1.0.0",
  "category": "ticketing",
  "vendor": "ConnectWise",
  "auth_type": "basic",
  "auth_config": {
    "type": "basic",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://api-{host}/v4_6_release/apis/3.0",
  "actions": [
    {
      "id": "create_ticket",
      "name": "Create Ticket",
      "description": "Create a new service ticket in ConnectWise Manage",
      "http_method": "POST",
      "endpoint": "/service/tickets",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "summary", "type": "string", "description": "Summary/title of the ticket", "required": true},
        {"name": "board_id", "type": "number", "description": "Service board ID", "required": true},
        {"name": "company_id", "type": "number", "description": "Company ID", "required": true},
        {"name": "initialDescription", "type": "string", "description": "Initial description of the ticket", "required": false},
        {"name": "priority_id", "type": "number", "description": "Priority ID", "required": false},
        {"name": "status_id", "type": "number", "description": "Status ID", "required": false},
        {"name": "type_id", "type": "number", "description": "Type ID", "required": false},
        {"name": "subType_id", "type": "number", "description": "Sub-type ID", "required": false},
        {"name": "contact_id", "type": "number", "description": "Contact ID", "required": false}
      ]
    },
    {
      "id": "get_ticket",
      "name": "Get Ticket",
      "description": "Retrieve a specific ConnectWise service ticket",
      "http_method": "GET",
      "endpoint": "/service/tickets/{id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "id", "type": "number", "description": "Ticket ID", "required": true}
      ]
    },
    {
      "id": "update_ticket",
      "name": "Update Ticket",
      "description": "Update an existing ConnectWise service ticket",
      "http_method": "PUT",
      "endpoint": "/service/tickets/{id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "id", "type": "number", "description": "Ticket ID to update", "required": true},
        {"name": "summary", "type": "string", "description": "Updated summary", "required": false},
        {"name": "status_id", "type": "number", "description": "New status ID", "required": false},
        {"name": "priority_id", "type": "number", "description": "New priority ID", "required": false},
        {"name": "owner_id", "type": "number", "description": "New owner member ID", "required": false}
      ]
    },
    {
      "id": "list_tickets",
      "name": "List Tickets",
      "description": "List and filter ConnectWise service tickets",
      "http_method": "GET",
      "endpoint": "/service/tickets",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "conditions", "type": "string", "description": "ConnectWise query conditions (e.g. status/name='New')", "required": false},
        {"name": "orderBy", "type": "string", "description": "Sort field and direction", "required": false},
        {"name": "pageSize", "type": "number", "description": "Results per page", "required": false, "default": 25},
        {"name": "page", "type": "number", "description": "Page number", "required": false, "default": 1}
      ]
    },
    {
      "id": "add_note",
      "name": "Add Note",
      "description": "Add a note to a ConnectWise service ticket",
      "http_method": "POST",
      "endpoint": "/service/tickets/{id}/notes",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "id", "type": "number", "description": "Ticket ID", "required": true},
        {"name": "text", "type": "string", "description": "Note content", "required": true},
        {"name": "detailDescriptionFlag", "type": "boolean", "description": "Include in detail description", "required": false, "default": false},
        {"name": "internalAnalysisFlag", "type": "boolean", "description": "Include in internal analysis", "required": false, "default": true},
        {"name": "resolutionFlag", "type": "boolean", "description": "Include in resolution", "required": false, "default": false}
      ]
    },
    {
      "id": "close_ticket",
      "name": "Close Ticket",
      "description": "Close a ConnectWise service ticket by updating its status",
      "http_method": "PUT",
      "endpoint": "/service/tickets/{id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "id", "type": "number", "description": "Ticket ID to close", "required": true},
        {"name": "status_id", "type": "number", "description": "Closed status ID for the board", "required": true}
      ]
    }
  ]
}
