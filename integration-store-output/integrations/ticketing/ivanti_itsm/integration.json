{
  "id": "ivanti_itsm",
  "name": "Ivanti ITSM",
  "description": "Integrates with Ivanti Neurons for ITSM REST API for incident management, service request automation, and IT operations",
  "version": "1.0.0",
  "category": "ticketing",
  "vendor": "Ivanti",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "location": "header",
    "header_name": "Authorization",
    "prefix": "rest_api_key="
  },
  "base_url": "https://{host}/api/odata/businessobject",
  "actions": [
    {
      "id": "create_incident",
      "name": "Create Incident",
      "description": "Create a new incident in Ivanti ITSM",
      "http_method": "POST",
      "endpoint": "/incidents",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "Subject",
          "type": "string",
          "description": "Subject/title of the incident",
          "required": true
        },
        {
          "name": "Symptom",
          "type": "string",
          "description": "Description of the incident symptoms",
          "required": true
        },
        {
          "name": "Priority",
          "type": "string",
          "description": "Priority level (1-Critical, 2-High, 3-Medium, 4-Low, 5-Very Low)",
          "required": false
        },
        {
          "name": "Urgency",
          "type": "string",
          "description": "Urgency level",
          "required": false
        },
        {
          "name": "Impact",
          "type": "string",
          "description": "Impact level",
          "required": false
        },
        {
          "name": "Category",
          "type": "string",
          "description": "Incident category",
          "required": false
        },
        {
          "name": "Owner",
          "type": "string",
          "description": "Owner/assignee of the incident",
          "required": false
        },
        {
          "name": "OwnerTeam",
          "type": "string",
          "description": "Team to assign the incident to",
          "required": false
        },
        {
          "name": "ProfileLink_RecID",
          "type": "string",
          "description": "RecID of the customer/requester profile",
          "required": false
        }
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident",
      "description": "Retrieve a specific incident from Ivanti ITSM",
      "http_method": "GET",
      "endpoint": "/incidents('{rec_id}')",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "rec_id",
          "type": "string",
          "description": "Record ID of the incident",
          "required": true
        }
      ]
    },
    {
      "id": "update_incident",
      "name": "Update Incident",
      "description": "Update an existing incident in Ivanti ITSM",
      "http_method": "PUT",
      "endpoint": "/incidents('{rec_id}')",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "rec_id",
          "type": "string",
          "description": "Record ID of the incident to update",
          "required": true
        },
        {
          "name": "Status",
          "type": "string",
          "description": "Updated status",
          "required": false
        },
        {
          "name": "Priority",
          "type": "string",
          "description": "Updated priority",
          "required": false
        },
        {
          "name": "Owner",
          "type": "string",
          "description": "New owner/assignee",
          "required": false
        },
        {
          "name": "Resolution",
          "type": "string",
          "description": "Resolution description",
          "required": false
        }
      ]
    },
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "List and filter incidents from Ivanti ITSM",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "$filter",
          "type": "string",
          "description": "OData filter expression (e.g. Status eq 'Active')",
          "required": false
        },
        {
          "name": "$orderby",
          "type": "string",
          "description": "Sort order (e.g. CreatedDateTime desc)",
          "required": false
        },
        {
          "name": "$top",
          "type": "number",
          "description": "Number of results to return",
          "required": false,
          "default": 50
        },
        {
          "name": "$skip",
          "type": "number",
          "description": "Number of results to skip for pagination",
          "required": false,
          "default": 0
        },
        {
          "name": "$select",
          "type": "string",
          "description": "Comma-separated list of fields to return",
          "required": false
        }
      ]
    },
    {
      "id": "add_journal",
      "name": "Add Journal Entry",
      "description": "Add a journal/note entry to an incident",
      "http_method": "POST",
      "endpoint": "/incidents('{rec_id}')/journals",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "rec_id",
          "type": "string",
          "description": "Record ID of the incident",
          "required": true
        },
        {
          "name": "JournalText",
          "type": "string",
          "description": "Journal entry text",
          "required": true
        },
        {
          "name": "Category",
          "type": "string",
          "description": "Journal category (Comment, Resolution, WorkAround)",
          "required": false
        }
      ]
    },
    {
      "id": "close_incident",
      "name": "Close Incident",
      "description": "Close an Ivanti ITSM incident",
      "http_method": "PUT",
      "endpoint": "/incidents('{rec_id}')",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "rec_id",
          "type": "string",
          "description": "Record ID of the incident to close",
          "required": true
        },
        {
          "name": "Resolution",
          "type": "string",
          "description": "Resolution description",
          "required": true
        },
        {
          "name": "CauseCode",
          "type": "string",
          "description": "Cause code for the resolution",
          "required": false
        }
      ]
    }
  ]
}