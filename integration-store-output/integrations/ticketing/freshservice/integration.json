{
  "id": "freshservice",
  "name": "Freshservice",
  "description": "Integrates with Freshservice REST API v2 for IT service management including ticket creation, tracking, and resolution",
  "version": "1.0.0",
  "category": "ticketing",
  "vendor": "Freshworks",
  "auth_type": "basic",
  "auth_config": {
    "type": "basic",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://{domain}.freshservice.com/api/v2",
  "actions": [
    {
      "id": "create_ticket",
      "name": "Create Ticket",
      "description": "Create a new service desk ticket in Freshservice",
      "http_method": "POST",
      "endpoint": "/tickets",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "subject", "type": "string", "description": "Subject of the ticket", "required": true},
        {"name": "description", "type": "string", "description": "HTML description of the ticket", "required": true},
        {"name": "email", "type": "string", "description": "Email address of the requester", "required": true},
        {"name": "priority", "type": "number", "description": "Priority (1=Low, 2=Medium, 3=High, 4=Urgent)", "required": true},
        {"name": "status", "type": "number", "description": "Status (2=Open, 3=Pending, 4=Resolved, 5=Closed)", "required": false, "default": 2},
        {"name": "source", "type": "number", "description": "Source (1=Email, 2=Portal, 3=Phone, etc.)", "required": false},
        {"name": "category", "type": "string", "description": "Category of the ticket", "required": false},
        {"name": "group_id", "type": "number", "description": "ID of the agent group to assign", "required": false},
        {"name": "responder_id", "type": "number", "description": "ID of the agent to assign", "required": false},
        {"name": "type", "type": "string", "description": "Type (Incident, Service Request)", "required": false}
      ]
    },
    {
      "id": "get_ticket",
      "name": "Get Ticket",
      "description": "Retrieve a specific Freshservice ticket by ID",
      "http_method": "GET",
      "endpoint": "/tickets/{ticket_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "ticket_id", "type": "number", "description": "Ticket ID to retrieve", "required": true},
        {"name": "include", "type": "string", "description": "Include additional info (conversations, requester, stats)", "required": false}
      ]
    },
    {
      "id": "update_ticket",
      "name": "Update Ticket",
      "description": "Update an existing Freshservice ticket",
      "http_method": "PUT",
      "endpoint": "/tickets/{ticket_id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "ticket_id", "type": "number", "description": "Ticket ID to update", "required": true},
        {"name": "status", "type": "number", "description": "Updated status (2=Open, 3=Pending, 4=Resolved, 5=Closed)", "required": false},
        {"name": "priority", "type": "number", "description": "Updated priority (1=Low, 2=Medium, 3=High, 4=Urgent)", "required": false},
        {"name": "group_id", "type": "number", "description": "New agent group ID", "required": false},
        {"name": "responder_id", "type": "number", "description": "New agent ID", "required": false},
        {"name": "subject", "type": "string", "description": "Updated subject", "required": false}
      ]
    },
    {
      "id": "list_tickets",
      "name": "List Tickets",
      "description": "List Freshservice tickets with optional filters",
      "http_method": "GET",
      "endpoint": "/tickets",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "filter", "type": "string", "description": "Predefined filter (new_and_my_open, monitored_by, spam, deleted)", "required": false},
        {"name": "requester_id", "type": "number", "description": "Filter by requester ID", "required": false},
        {"name": "email", "type": "string", "description": "Filter by requester email", "required": false},
        {"name": "updated_since", "type": "string", "description": "Filter tickets updated since date (ISO 8601)", "required": false},
        {"name": "type", "type": "string", "description": "Filter by type (Incident, Service Request)", "required": false},
        {"name": "per_page", "type": "number", "description": "Results per page (max 100)", "required": false, "default": 30},
        {"name": "page", "type": "number", "description": "Page number", "required": false, "default": 1}
      ]
    },
    {
      "id": "add_note",
      "name": "Add Note",
      "description": "Add a note or reply to a Freshservice ticket",
      "http_method": "POST",
      "endpoint": "/tickets/{ticket_id}/notes",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "ticket_id", "type": "number", "description": "Ticket ID", "required": true},
        {"name": "body", "type": "string", "description": "Content of the note in HTML", "required": true},
        {"name": "private", "type": "boolean", "description": "Whether the note is private (true) or public (false)", "required": false, "default": true}
      ]
    },
    {
      "id": "close_ticket",
      "name": "Close Ticket",
      "description": "Close a Freshservice ticket by setting status to Closed",
      "http_method": "PUT",
      "endpoint": "/tickets/{ticket_id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "ticket_id", "type": "number", "description": "Ticket ID to close", "required": true}
      ]
    }
  ]
}
