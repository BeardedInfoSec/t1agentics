{
  "id": "servicenow_itsm",
  "name": "ServiceNow ITSM",
  "description": "Integrates with ServiceNow ITSM Table API for incident and ticket management, enabling automated creation, retrieval, update, and resolution of IT service incidents",
  "version": "1.0.0",
  "category": "ticketing",
  "vendor": "ServiceNow",
  "auth_type": "basic",
  "auth_config": {
    "type": "basic",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://{instance}.service-now.com/api/now",
  "actions": [
    {
      "id": "create_incident",
      "name": "Create Incident",
      "description": "Create a new incident record in ServiceNow ITSM",
      "http_method": "POST",
      "endpoint": "/table/incident",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "short_description",
          "type": "string",
          "description": "Brief description of the incident",
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "description": "Detailed description of the incident",
          "required": false
        },
        {
          "name": "urgency",
          "type": "string",
          "description": "Urgency level (1=High, 2=Medium, 3=Low)",
          "required": false
        },
        {
          "name": "impact",
          "type": "string",
          "description": "Impact level (1=High, 2=Medium, 3=Low)",
          "required": false
        },
        {
          "name": "priority",
          "type": "string",
          "description": "Priority level (1=Critical, 2=High, 3=Moderate, 4=Low, 5=Planning)",
          "required": false
        },
        {
          "name": "assignment_group",
          "type": "string",
          "description": "Sys ID of the assignment group",
          "required": false
        },
        {
          "name": "assigned_to",
          "type": "string",
          "description": "Sys ID of the user assigned to the incident",
          "required": false
        },
        {
          "name": "category",
          "type": "string",
          "description": "Category of the incident",
          "required": false
        },
        {
          "name": "caller_id",
          "type": "string",
          "description": "Sys ID of the caller/requester",
          "required": false
        }
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident",
      "description": "Retrieve a specific incident record by sys_id",
      "http_method": "GET",
      "endpoint": "/table/incident/{sys_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "sys_id",
          "type": "string",
          "description": "Unique sys_id of the incident record",
          "required": true
        },
        {
          "name": "sysparm_display_value",
          "type": "string",
          "description": "Return display values (true), actual values (false), or both (all)",
          "required": false,
          "default": "true"
        },
        {
          "name": "sysparm_fields",
          "type": "string",
          "description": "Comma-separated list of fields to return",
          "required": false
        }
      ]
    },
    {
      "id": "update_incident",
      "name": "Update Incident",
      "description": "Update an existing incident record in ServiceNow",
      "http_method": "PUT",
      "endpoint": "/table/incident/{sys_id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "sys_id",
          "type": "string",
          "description": "Unique sys_id of the incident to update",
          "required": true
        },
        {
          "name": "state",
          "type": "string",
          "description": "Incident state (1=New, 2=In Progress, 3=On Hold, 6=Resolved, 7=Closed)",
          "required": false
        },
        {
          "name": "short_description",
          "type": "string",
          "description": "Updated brief description",
          "required": false
        },
        {
          "name": "assigned_to",
          "type": "string",
          "description": "Sys ID of the new assignee",
          "required": false
        },
        {
          "name": "work_notes",
          "type": "string",
          "description": "Internal work notes to add",
          "required": false
        },
        {
          "name": "close_notes",
          "type": "string",
          "description": "Notes for closing the incident",
          "required": false
        },
        {
          "name": "close_code",
          "type": "string",
          "description": "Close code for resolution",
          "required": false
        }
      ]
    },
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "Query and retrieve a list of incidents using encoded query parameters",
      "http_method": "GET",
      "endpoint": "/table/incident",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "sysparm_query",
          "type": "string",
          "description": "Encoded query string (e.g. priority=1^state=1)",
          "required": false
        },
        {
          "name": "sysparm_limit",
          "type": "number",
          "description": "Maximum number of records to return",
          "required": false,
          "default": 50
        },
        {
          "name": "sysparm_offset",
          "type": "number",
          "description": "Starting record index for pagination",
          "required": false,
          "default": 0
        },
        {
          "name": "sysparm_fields",
          "type": "string",
          "description": "Comma-separated list of fields to return",
          "required": false
        },
        {
          "name": "sysparm_display_value",
          "type": "string",
          "description": "Return display values (true), actual values (false), or both (all)",
          "required": false,
          "default": "true"
        }
      ]
    },
    {
      "id": "add_comment",
      "name": "Add Comment",
      "description": "Add a comment or work note to an existing incident",
      "http_method": "PUT",
      "endpoint": "/table/incident/{sys_id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "sys_id",
          "type": "string",
          "description": "Unique sys_id of the incident",
          "required": true
        },
        {
          "name": "comments",
          "type": "string",
          "description": "Customer-visible comment to add",
          "required": false
        },
        {
          "name": "work_notes",
          "type": "string",
          "description": "Internal work note to add",
          "required": false
        }
      ]
    },
    {
      "id": "close_incident",
      "name": "Close Incident",
      "description": "Close an incident by setting its state to Resolved or Closed",
      "http_method": "PUT",
      "endpoint": "/table/incident/{sys_id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "sys_id",
          "type": "string",
          "description": "Unique sys_id of the incident to close",
          "required": true
        },
        {
          "name": "state",
          "type": "string",
          "description": "State to set (6=Resolved, 7=Closed)",
          "required": true,
          "default": "6"
        },
        {
          "name": "close_code",
          "type": "string",
          "description": "Resolution code (e.g. Solved (Permanently), Solved (Work Around))",
          "required": true
        },
        {
          "name": "close_notes",
          "type": "string",
          "description": "Resolution notes describing how the incident was resolved",
          "required": true
        }
      ]
    }
  ]
}