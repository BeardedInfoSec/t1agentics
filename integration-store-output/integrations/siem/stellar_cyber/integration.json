{
  "id": "stellar_cyber",
  "name": "Stellar Cyber Open XDR",
  "description": "Integrates with Stellar Cyber Open XDR Platform for alert management, incident investigation, data lake queries, asset inventory, and threat hunting via the Stellar Cyber REST API",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "Stellar Cyber",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "prefix": "Bearer",
    "location": "header"
  },
  "base_url": "https://{host}/connect/api",
  "actions": [
    {
      "id": "list_alerts",
      "name": "List Alerts",
      "description": "Retrieve security alerts from Stellar Cyber with filtering by severity and time",
      "http_method": "GET",
      "endpoint": "/v1/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity (critical, high, medium, low)",
          "required": false
        },
        {
          "name": "status",
          "type": "string",
          "description": "Filter by status (new, in_progress, resolved, dismissed)",
          "required": false
        },
        {
          "name": "from",
          "type": "string",
          "description": "Start time (ISO 8601)",
          "required": false
        },
        {
          "name": "to",
          "type": "string",
          "description": "End time (ISO 8601)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum alerts to return",
          "required": false,
          "default": 50
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "get_alert",
      "name": "Get Alert Details",
      "description": "Retrieve details for a specific alert",
      "http_method": "GET",
      "endpoint": "/v1/alerts/{alertId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alertId",
          "type": "string",
          "description": "Alert ID to retrieve",
          "required": true
        }
      ]
    },
    {
      "id": "update_alert",
      "name": "Update Alert",
      "description": "Update alert status, assignee, or add comments",
      "http_method": "PUT",
      "endpoint": "/v1/alerts/{alertId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "alertId",
          "type": "string",
          "description": "Alert ID to update",
          "required": true
        },
        {
          "name": "status",
          "type": "string",
          "description": "New status (new, in_progress, resolved, dismissed)",
          "required": false
        },
        {
          "name": "assignee",
          "type": "string",
          "description": "User to assign to",
          "required": false
        },
        {
          "name": "comment",
          "type": "string",
          "description": "Comment to add",
          "required": false
        }
      ]
    },
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "Retrieve correlated incidents from the Stellar Cyber platform",
      "http_method": "GET",
      "endpoint": "/v1/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "status",
          "type": "string",
          "description": "Filter by incident status",
          "required": false
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity",
          "required": false
        },
        {
          "name": "from",
          "type": "string",
          "description": "Start time",
          "required": false
        },
        {
          "name": "to",
          "type": "string",
          "description": "End time",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum incidents to return",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "query_data_lake",
      "name": "Query Data Lake",
      "description": "Execute a query against the Stellar Cyber data lake for threat hunting",
      "http_method": "POST",
      "endpoint": "/v1/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query string",
          "required": true
        },
        {
          "name": "from",
          "type": "string",
          "description": "Start time (ISO 8601)",
          "required": true
        },
        {
          "name": "to",
          "type": "string",
          "description": "End time (ISO 8601)",
          "required": true
        },
        {
          "name": "index",
          "type": "string",
          "description": "Data source index to search",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum results to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "list_assets",
      "name": "List Assets",
      "description": "Retrieve assets discovered by Stellar Cyber",
      "http_method": "GET",
      "endpoint": "/v1/assets",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "type",
          "type": "string",
          "description": "Filter by asset type (server, workstation, network_device)",
          "required": false
        },
        {
          "name": "search",
          "type": "string",
          "description": "Search by hostname or IP",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum assets to return",
          "required": false,
          "default": 50
        }
      ],
      "observable_type": "ip"
    },
    {
      "id": "list_connectors",
      "name": "List Connectors",
      "description": "Retrieve configured data source connectors",
      "http_method": "GET",
      "endpoint": "/v1/connectors",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "status",
          "type": "string",
          "description": "Filter by connector status (active, inactive, error)",
          "required": false
        }
      ]
    }
  ]
}
