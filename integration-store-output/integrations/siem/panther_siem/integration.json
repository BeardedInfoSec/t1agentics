{
  "id": "panther_siem",
  "name": "Panther SIEM",
  "description": "Integrates with Panther cloud SIEM for alert management, detection rule configuration, saved query execution, and log source management via the Panther REST API",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "Panther Labs",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "X-API-Key",
    "location": "header"
  },
  "base_url": "https://{host}/api/v1",
  "actions": [
    {
      "id": "list_alerts",
      "name": "List Alerts",
      "description": "Retrieve alerts from Panther with filtering by severity and status",
      "http_method": "GET",
      "endpoint": "/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity (INFO, LOW, MEDIUM, HIGH, CRITICAL)",
          "required": false
        },
        {
          "name": "status",
          "type": "string",
          "description": "Filter by status (OPEN, TRIAGED, CLOSED, RESOLVED)",
          "required": false
        },
        {
          "name": "createdAfter",
          "type": "string",
          "description": "Filter alerts created after this time (ISO 8601)",
          "required": false
        },
        {
          "name": "createdBefore",
          "type": "string",
          "description": "Filter alerts created before this time",
          "required": false
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Number of alerts per page",
          "required": false,
          "default": 25
        },
        {
          "name": "pageToken",
          "type": "string",
          "description": "Pagination token for next page",
          "required": false
        }
      ]
    },
    {
      "id": "get_alert",
      "name": "Get Alert Details",
      "description": "Retrieve details for a specific alert including triggering events",
      "http_method": "GET",
      "endpoint": "/alerts/{alertId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alertId",
          "type": "string",
          "description": "Alert ID to retrieve",
          "required": true
        }
      ]
    },
    {
      "id": "update_alert",
      "name": "Update Alert",
      "description": "Update alert status, assignee, or add comments",
      "http_method": "PATCH",
      "endpoint": "/alerts/{alertId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "alertId",
          "type": "string",
          "description": "Alert ID to update",
          "required": true
        },
        {
          "name": "status",
          "type": "string",
          "description": "New status (OPEN, TRIAGED, CLOSED, RESOLVED)",
          "required": false
        },
        {
          "name": "assigneeId",
          "type": "string",
          "description": "User ID to assign the alert to",
          "required": false
        }
      ]
    },
    {
      "id": "list_rules",
      "name": "List Detection Rules",
      "description": "List all detection rules (Python-based) configured in Panther",
      "http_method": "GET",
      "endpoint": "/rules",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "enabled",
          "type": "boolean",
          "description": "Filter by enabled/disabled",
          "required": false
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity",
          "required": false
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Results per page",
          "required": false,
          "default": 25
        }
      ]
    },
    {
      "id": "run_query",
      "name": "Run Query",
      "description": "Execute a saved SQL query or a new query against Panther's data lake",
      "http_method": "POST",
      "endpoint": "/queries",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "sql",
          "type": "string",
          "description": "SQL query to execute against the Panther data lake",
          "required": true
        },
        {
          "name": "maxResults",
          "type": "number",
          "description": "Maximum results to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "list_log_sources",
      "name": "List Log Sources",
      "description": "List configured log sources and their ingestion status",
      "http_method": "GET",
      "endpoint": "/log-sources",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "integrationType",
          "type": "string",
          "description": "Filter by integration type (s3, sqs, cloudwatch, etc.)",
          "required": false
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Results per page",
          "required": false,
          "default": 25
        }
      ]
    },
    {
      "id": "list_alert_comments",
      "name": "List Alert Comments",
      "description": "Retrieve comments/notes on an alert",
      "http_method": "GET",
      "endpoint": "/alerts/{alertId}/comments",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alertId",
          "type": "string",
          "description": "Alert ID to retrieve comments for",
          "required": true
        }
      ]
    }
  ]
}
