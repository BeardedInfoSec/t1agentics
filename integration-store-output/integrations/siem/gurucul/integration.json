{
  "id": "gurucul",
  "name": "Gurucul",
  "description": "Integrates with Gurucul Security Analytics and Operations (SIEM/UEBA) for risk-based incident management, anomaly detection, case management, and identity analytics via the Gurucul REST API",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "Gurucul",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "prefix": "Bearer",
    "location": "header"
  },
  "base_url": "https://{host}/api/v1",
  "actions": [
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "Retrieve security incidents from Gurucul with risk-based prioritization",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "status",
          "type": "string",
          "description": "Filter by incident status (Open, In Progress, Closed)",
          "required": false
        },
        {
          "name": "riskScoreMin",
          "type": "number",
          "description": "Minimum risk score filter",
          "required": false
        },
        {
          "name": "riskScoreMax",
          "type": "number",
          "description": "Maximum risk score filter",
          "required": false
        },
        {
          "name": "fromDate",
          "type": "string",
          "description": "Start date for filtering (ISO 8601)",
          "required": false
        },
        {
          "name": "toDate",
          "type": "string",
          "description": "End date for filtering",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum incidents to return",
          "required": false,
          "default": 50
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident Details",
      "description": "Retrieve details for a specific incident",
      "http_method": "GET",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "incidentId",
          "type": "string",
          "description": "Incident ID to retrieve",
          "required": true
        }
      ]
    },
    {
      "id": "update_incident",
      "name": "Update Incident",
      "description": "Update incident status, priority, or assignee",
      "http_method": "PUT",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "incidentId",
          "type": "string",
          "description": "Incident ID to update",
          "required": true
        },
        {
          "name": "status",
          "type": "string",
          "description": "New status",
          "required": false
        },
        {
          "name": "assignee",
          "type": "string",
          "description": "User to assign to",
          "required": false
        },
        {
          "name": "comment",
          "type": "string",
          "description": "Comment to add",
          "required": false
        }
      ]
    },
    {
      "id": "get_anomalies",
      "name": "Get Anomalies",
      "description": "Retrieve ML-detected anomalies from Gurucul analytics engine",
      "http_method": "GET",
      "endpoint": "/anomalies",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "entityType",
          "type": "string",
          "description": "Entity type filter (user, device, application)",
          "required": false
        },
        {
          "name": "fromDate",
          "type": "string",
          "description": "Start date",
          "required": false
        },
        {
          "name": "toDate",
          "type": "string",
          "description": "End date",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum results",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "get_risk_scores",
      "name": "Get Risk Scores",
      "description": "Retrieve risk scores for users and entities",
      "http_method": "GET",
      "endpoint": "/risk/scores",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "entityType",
          "type": "string",
          "description": "Entity type (user, device, application)",
          "required": false
        },
        {
          "name": "minScore",
          "type": "number",
          "description": "Minimum risk score threshold",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum results",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "search_events",
      "name": "Search Events",
      "description": "Search for security events in Gurucul data lake",
      "http_method": "POST",
      "endpoint": "/search/events",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query string",
          "required": true
        },
        {
          "name": "fromDate",
          "type": "string",
          "description": "Start date (ISO 8601)",
          "required": true
        },
        {
          "name": "toDate",
          "type": "string",
          "description": "End date (ISO 8601)",
          "required": true
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum events to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "list_cases",
      "name": "List Cases",
      "description": "Retrieve cases from Gurucul case management",
      "http_method": "GET",
      "endpoint": "/cases",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "status",
          "type": "string",
          "description": "Filter by case status",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum cases to return",
          "required": false,
          "default": 50
        }
      ]
    }
  ]
}
