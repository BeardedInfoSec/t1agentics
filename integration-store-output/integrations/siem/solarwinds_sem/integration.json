{
  "id": "solarwinds_sem",
  "name": "SolarWinds Security Event Manager",
  "description": "Integrates with SolarWinds Security Event Manager (SEM) for event log monitoring, alert management, active response actions, and compliance reporting via the SEM REST API",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "SolarWinds",
  "auth_type": "basic",
  "auth_config": {
    "type": "basic",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://{host}:8443/api",
  "actions": [
    {
      "id": "list_events",
      "name": "List Events",
      "description": "Retrieve security events from SEM with filtering",
      "http_method": "GET",
      "endpoint": "/events",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "startTime",
          "type": "string",
          "description": "Start time for event retrieval (ISO 8601)",
          "required": false
        },
        {
          "name": "endTime",
          "type": "string",
          "description": "End time for event retrieval",
          "required": false
        },
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression for events",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum events to return",
          "required": false,
          "default": 100
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "list_alerts",
      "name": "List Alerts",
      "description": "Retrieve active and historical alerts from SEM",
      "http_method": "GET",
      "endpoint": "/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "status",
          "type": "string",
          "description": "Filter by alert status (active, cleared)",
          "required": false
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity (low, medium, high, critical)",
          "required": false
        },
        {
          "name": "startTime",
          "type": "string",
          "description": "Start time filter",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum alerts to return",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "get_alert",
      "name": "Get Alert Details",
      "description": "Retrieve details for a specific alert",
      "http_method": "GET",
      "endpoint": "/alerts/{alertId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alertId",
          "type": "string",
          "description": "Alert ID to retrieve",
          "required": true
        }
      ]
    },
    {
      "id": "acknowledge_alert",
      "name": "Acknowledge Alert",
      "description": "Acknowledge an active alert in SEM",
      "http_method": "PUT",
      "endpoint": "/alerts/{alertId}/acknowledge",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "alertId",
          "type": "string",
          "description": "Alert ID to acknowledge",
          "required": true
        },
        {
          "name": "comment",
          "type": "string",
          "description": "Comment to add with acknowledgement",
          "required": false
        }
      ]
    },
    {
      "id": "search_events",
      "name": "Search Events",
      "description": "Search for events using SEM query syntax",
      "http_method": "POST",
      "endpoint": "/events/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query in SEM query syntax",
          "required": true
        },
        {
          "name": "startTime",
          "type": "string",
          "description": "Start time (ISO 8601)",
          "required": true
        },
        {
          "name": "endTime",
          "type": "string",
          "description": "End time (ISO 8601)",
          "required": true
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum events to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "list_connectors",
      "name": "List Connectors",
      "description": "Retrieve configured log source connectors and their status",
      "http_method": "GET",
      "endpoint": "/connectors",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "status",
          "type": "string",
          "description": "Filter by connector status (active, disabled)",
          "required": false
        }
      ]
    }
  ]
}
