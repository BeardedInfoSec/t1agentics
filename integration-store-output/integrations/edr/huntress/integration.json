{
  "id": "huntress",
  "name": "Huntress",
  "description": "Integrates with Huntress REST API v1 for managed EDR, incident report management, agent monitoring, and automated threat response",
  "version": "1.0.0",
  "category": "edr",
  "vendor": "Huntress",
  "auth_type": "basic",
  "auth_config": {
    "type": "basic",
    "header_name": "Authorization",
    "prefix": "Basic",
    "note": "Base64 encoded api_key:api_secret"
  },
  "base_url": "https://api.huntress.io/v1",
  "actions": [
    {
      "id": "list_organizations",
      "name": "List Organizations",
      "description": "Retrieve the list of organizations managed in the Huntress account",
      "http_method": "GET",
      "endpoint": "/organizations",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "page",
          "type": "number",
          "description": "Page number for pagination",
          "required": false,
          "default": 1
        },
        {
          "name": "per_page",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "list_agents",
      "name": "List Agents",
      "description": "Retrieve the list of Huntress agents deployed across managed endpoints",
      "http_method": "GET",
      "endpoint": "/organizations/{organization_id}/agents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "organization_id",
          "type": "number",
          "description": "The organization ID to list agents for",
          "required": true
        },
        {
          "name": "page",
          "type": "number",
          "description": "Page number for pagination",
          "required": false,
          "default": 1
        },
        {
          "name": "per_page",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 50
        }
      ],
      "observable_type": "hostname"
    },
    {
      "id": "get_agent",
      "name": "Get Agent Details",
      "description": "Retrieve detailed information about a specific Huntress agent",
      "http_method": "GET",
      "endpoint": "/organizations/{organization_id}/agents/{agent_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "organization_id",
          "type": "number",
          "description": "The organization ID",
          "required": true
        },
        {
          "name": "agent_id",
          "type": "number",
          "description": "The unique identifier of the agent",
          "required": true
        }
      ],
      "observable_type": "hostname"
    },
    {
      "id": "list_incident_reports",
      "name": "List Incident Reports",
      "description": "Retrieve the list of incident reports generated by Huntress managed threat detection",
      "http_method": "GET",
      "endpoint": "/incident_reports",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "page",
          "type": "number",
          "description": "Page number for pagination",
          "required": false,
          "default": 1
        },
        {
          "name": "per_page",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 50
        },
        {
          "name": "status",
          "type": "string",
          "description": "Filter by status (sent, closed, actionRequired)",
          "required": false
        }
      ]
    },
    {
      "id": "get_incident_report",
      "name": "Get Incident Report",
      "description": "Retrieve detailed information about a specific incident report",
      "http_method": "GET",
      "endpoint": "/incident_reports/{report_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "report_id",
          "type": "number",
          "description": "The unique identifier of the incident report",
          "required": true
        }
      ]
    },
    {
      "id": "resolve_incident_report",
      "name": "Resolve Incident Report",
      "description": "Resolve an incident report by approving or rejecting recommended remediations",
      "http_method": "PATCH",
      "endpoint": "/incident_reports/{report_id}",
      "action_type": "correct",
      "read_only": false,
      "parameters": [
        {
          "name": "report_id",
          "type": "number",
          "description": "The unique identifier of the incident report",
          "required": true
        },
        {
          "name": "status",
          "type": "string",
          "description": "Resolution status: resolved, dismissed",
          "required": true
        }
      ]
    },
    {
      "id": "list_escalations",
      "name": "List Escalations",
      "description": "Retrieve the list of escalations requiring attention",
      "http_method": "GET",
      "endpoint": "/escalations",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "page",
          "type": "number",
          "description": "Page number for pagination",
          "required": false,
          "default": 1
        },
        {
          "name": "per_page",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "resolve_escalation",
      "name": "Resolve Escalation",
      "description": "Resolve an escalation that has been reviewed and addressed",
      "http_method": "PATCH",
      "endpoint": "/escalations/{escalation_id}",
      "action_type": "correct",
      "read_only": false,
      "parameters": [
        {
          "name": "escalation_id",
          "type": "number",
          "description": "The unique identifier of the escalation",
          "required": true
        },
        {
          "name": "resolution",
          "type": "string",
          "description": "Resolution description",
          "required": true
        }
      ]
    },
    {
      "id": "list_billing_reports",
      "name": "List Billing Reports",
      "description": "Retrieve billing reports for managed organizations",
      "http_method": "GET",
      "endpoint": "/billing_reports",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "page",
          "type": "number",
          "description": "Page number for pagination",
          "required": false,
          "default": 1
        },
        {
          "name": "per_page",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 50
        }
      ]
    }
  ]
}