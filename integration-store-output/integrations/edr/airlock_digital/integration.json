      "endpoint": "/actions/block_hash",
      "action_type": "contain",
      "read_only": false,
      "cacheable": false,
      "cache_ttl_days": 0,
      "parameters": [
        {
          "name": "hash",
          "type": "string",
          "description": "Hash(SHA256) of file(s) to ban/block",
          "required": true,
          "contains": [
            "sha256"
          ]
        },
        {
          "name": "blocklistid",
          "type": "string",
          "description": "Blocklist ID",
          "required": true,
          "contains": [
            "airlockdigital blocklistid"
          ]
        }
      ],
      "observable_type": "file_hash"
    },
    {
