{
  "id": "ibm_security_verify",
  "name": "IBM Security Verify",
  "description": "Identity and access management through IBM Security Verify REST API for managing users, groups, applications, MFA, and audit events",
  "version": "1.0.0",
  "category": "identity",
  "vendor": "IBM",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "token_url": "https://{tenant}.verify.ibm.com/v1.0/endpoint/default/token",
    "grant_type": "client_credentials"
  },
  "base_url": "https://{tenant}.verify.ibm.com",
  "actions": [
    {
      "id": "list_users",
      "name": "List Users",
      "description": "List all users in the IBM Security Verify directory",
      "http_method": "GET",
      "endpoint": "/v2.0/Users",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "filter",
          "type": "string",
          "description": "SCIM filter expression (e.g. userName eq \"john\")",
          "required": false
        },
        {
          "name": "count",
          "type": "number",
          "description": "Maximum number of results per page",
          "required": false
        },
        {
          "name": "startIndex",
          "type": "number",
          "description": "Starting index for pagination",
          "required": false
        }
      ]
    },
    {
      "id": "get_user",
      "name": "Get User",
      "description": "Retrieve details of a specific user",
      "http_method": "GET",
      "endpoint": "/v2.0/Users/{userId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "userId",
          "type": "string",
          "description": "User ID",
          "required": true
        }
      ]
    },
    {
      "id": "disable_user",
      "name": "Disable User",
      "description": "Disable a user account by setting active to false",
      "http_method": "PATCH",
      "endpoint": "/v2.0/Users/{userId}",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "userId",
          "type": "string",
          "description": "User ID to disable",
          "required": true
        }
      ]
    },
    {
      "id": "enable_user",
      "name": "Enable User",
      "description": "Enable a previously disabled user account",
      "http_method": "PATCH",
      "endpoint": "/v2.0/Users/{userId}",
      "action_type": "correct",
      "read_only": false,
      "parameters": [
        {
          "name": "userId",
          "type": "string",
          "description": "User ID to enable",
          "required": true
        }
      ]
    },
    {
      "id": "reset_password",
      "name": "Reset Password",
      "description": "Reset a user's password",
      "http_method": "PUT",
      "endpoint": "/v2.0/Users/{userId}/password",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "userId",
          "type": "string",
          "description": "User ID",
          "required": true
        },
        {
          "name": "newPassword",
          "type": "string",
          "description": "New password to set",
          "required": true
        }
      ]
    },
    {
      "id": "list_groups",
      "name": "List Groups",
      "description": "List all groups in the directory",
      "http_method": "GET",
      "endpoint": "/v2.0/Groups",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "filter",
          "type": "string",
          "description": "SCIM filter expression for groups",
          "required": false
        },
        {
          "name": "count",
          "type": "number",
          "description": "Maximum number of results",
          "required": false
        }
      ]
    },
    {
      "id": "get_group",
      "name": "Get Group",
      "description": "Retrieve details of a specific group",
      "http_method": "GET",
      "endpoint": "/v2.0/Groups/{groupId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "groupId",
          "type": "string",
          "description": "Group ID",
          "required": true
        }
      ]
    },
    {
      "id": "list_applications",
      "name": "List Applications",
      "description": "List all configured applications",
      "http_method": "GET",
      "endpoint": "/v1.0/applications",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "list_mfa_enrollments",
      "name": "List MFA Enrollments",
      "description": "List MFA factor enrollments for a user",
      "http_method": "GET",
      "endpoint": "/v2.0/factors/Users/{userId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "userId",
          "type": "string",
          "description": "User ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_audit_events",
      "name": "Get Audit Events",
      "description": "Retrieve audit events for compliance and investigation",
      "http_method": "GET",
      "endpoint": "/v1.0/audit/events",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "from",
          "type": "string",
          "description": "Start time for audit events (ISO 8601)",
          "required": false
        },
        {
          "name": "to",
          "type": "string",
          "description": "End time for audit events (ISO 8601)",
          "required": false
        },
        {
          "name": "size",
          "type": "number",
          "description": "Maximum number of events to return",
          "required": false
        }
      ]
    }
  ]
}