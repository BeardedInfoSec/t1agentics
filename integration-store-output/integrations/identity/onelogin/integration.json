{
  "id": "onelogin",
  "name": "OneLogin",
  "description": "Identity and access management through OneLogin REST API for managing users, groups, roles, apps, and authentication events",
  "version": "1.0.0",
  "category": "identity",
  "vendor": "One Identity",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "token_url": "https://{subdomain}.onelogin.com/auth/oauth2/v2/token",
    "grant_type": "client_credentials"
  },
  "base_url": "https://{subdomain}.onelogin.com/api/2",
  "actions": [
    {
      "id": "list_users",
      "name": "List Users",
      "description": "List all users with optional filtering and pagination",
      "http_method": "GET",
      "endpoint": "/users",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "email",
          "type": "string",
          "description": "Filter by email address",
          "required": false
        },
        {
          "name": "username",
          "type": "string",
          "description": "Filter by username",
          "required": false
        },
        {
          "name": "firstname",
          "type": "string",
          "description": "Filter by first name",
          "required": false
        },
        {
          "name": "lastname",
          "type": "string",
          "description": "Filter by last name",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of results per page",
          "required": false
        }
      ]
    },
    {
      "id": "get_user",
      "name": "Get User",
      "description": "Retrieve details of a specific user by ID",
      "http_method": "GET",
      "endpoint": "/users/{userId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "userId",
          "type": "string",
          "description": "User ID",
          "required": true
        }
      ]
    },
    {
      "id": "lock_user",
      "name": "Lock User",
      "description": "Lock a user account to prevent login",
      "http_method": "PUT",
      "endpoint": "/users/{userId}/lock_user",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "userId",
          "type": "string",
          "description": "User ID to lock",
          "required": true
        },
        {
          "name": "locked_until",
          "type": "number",
          "description": "Lock duration in minutes (0 for permanent lock)",
          "required": false
        }
      ]
    },
    {
      "id": "set_user_state",
      "name": "Set User State",
      "description": "Set the user state (active, suspended, etc.)",
      "http_method": "PUT",
      "endpoint": "/users/{userId}/set_state",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "userId",
          "type": "string",
          "description": "User ID",
          "required": true
        },
        {
          "name": "state",
          "type": "number",
          "description": "User state value (0=unapproved, 1=approved, 2=rejected, 3=unlicensed)",
          "required": true
        }
      ]
    },
    {
      "id": "set_password",
      "name": "Set Password",
      "description": "Set a temporary password for a user",
      "http_method": "PUT",
      "endpoint": "/users/set_password_clear_text/{userId}",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "userId",
          "type": "string",
          "description": "User ID",
          "required": true
        },
        {
          "name": "password",
          "type": "string",
          "description": "New password for the user",
          "required": true
        },
        {
          "name": "password_confirmation",
          "type": "string",
          "description": "Password confirmation",
          "required": true
        }
      ]
    },
    {
      "id": "list_groups",
      "name": "List Groups",
      "description": "List all groups in the OneLogin account",
      "http_method": "GET",
      "endpoint": "/groups",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "get_group",
      "name": "Get Group",
      "description": "Retrieve details of a specific group",
      "http_method": "GET",
      "endpoint": "/groups/{groupId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "groupId",
          "type": "string",
          "description": "Group ID",
          "required": true
        }
      ]
    },
    {
      "id": "list_roles",
      "name": "List Roles",
      "description": "List all roles in the OneLogin account",
      "http_method": "GET",
      "endpoint": "/roles",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "get_role",
      "name": "Get Role",
      "description": "Retrieve details of a specific role",
      "http_method": "GET",
      "endpoint": "/roles/{roleId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "roleId",
          "type": "string",
          "description": "Role ID",
          "required": true
        }
      ]
    },
    {
      "id": "list_apps",
      "name": "List Apps",
      "description": "List all applications configured in OneLogin",
      "http_method": "GET",
      "endpoint": "/apps",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "get_events",
      "name": "Get Events",
      "description": "Retrieve audit events and login activity logs",
      "http_method": "GET",
      "endpoint": "/events",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "event_type_id",
          "type": "number",
          "description": "Filter by event type ID",
          "required": false
        },
        {
          "name": "since",
          "type": "string",
          "description": "Start date (ISO 8601)",
          "required": false
        },
        {
          "name": "until",
          "type": "string",
          "description": "End date (ISO 8601)",
          "required": false
        },
        {
          "name": "user_id",
          "type": "string",
          "description": "Filter by user ID",
          "required": false
        }
      ]
    }
  ]
}