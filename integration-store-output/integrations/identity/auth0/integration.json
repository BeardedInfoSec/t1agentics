{
  "id": "auth0",
  "name": "Auth0",
  "description": "Identity platform management through Auth0 Management API v2 for managing users, connections, roles, organizations, and logs",
  "version": "1.0.0",
  "category": "identity",
  "vendor": "Okta (Auth0)",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "token_url": "https://{domain}.auth0.com/oauth/token",
    "grant_type": "client_credentials",
    "audience": "https://{domain}.auth0.com/api/v2/"
  },
  "base_url": "https://{domain}.auth0.com/api/v2",
  "actions": [
    {
      "id": "list_users",
      "name": "List Users",
      "description": "List or search all users in the Auth0 tenant",
      "http_method": "GET",
      "endpoint": "/users",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "q",
          "type": "string",
          "description": "Lucene query string to search users",
          "required": false
        },
        {
          "name": "search_engine",
          "type": "string",
          "description": "Search engine version (v3 recommended)",
          "required": false,
          "default": "v3"
        },
        {
          "name": "per_page",
          "type": "number",
          "description": "Number of results per page (max 100)",
          "required": false
        },
        {
          "name": "page",
          "type": "number",
          "description": "Page number (zero-indexed)",
          "required": false
        }
      ]
    },
    {
      "id": "get_user",
      "name": "Get User",
      "description": "Retrieve details of a specific user by user_id",
      "http_method": "GET",
      "endpoint": "/users/{id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "User ID (e.g. auth0|abc123)",
          "required": true
        }
      ]
    },
    {
      "id": "block_user",
      "name": "Block User",
      "description": "Block a user account to prevent login",
      "http_method": "PATCH",
      "endpoint": "/users/{id}",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "User ID to block",
          "required": true
        }
      ]
    },
    {
      "id": "unblock_user",
      "name": "Unblock User",
      "description": "Unblock a previously blocked user account",
      "http_method": "PATCH",
      "endpoint": "/users/{id}",
      "action_type": "correct",
      "read_only": false,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "User ID to unblock",
          "required": true
        }
      ]
    },
    {
      "id": "reset_password",
      "name": "Reset Password",
      "description": "Send a password reset email to a user via a change password ticket",
      "http_method": "POST",
      "endpoint": "/tickets/password-change",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "user_id",
          "type": "string",
          "description": "User ID to reset password for",
          "required": true
        },
        {
          "name": "result_url",
          "type": "string",
          "description": "URL to redirect after password reset",
          "required": false
        }
      ]
    },
    {
      "id": "invalidate_sessions",
      "name": "Invalidate Sessions",
      "description": "Invalidate all remembered browsers and active sessions for a user",
      "http_method": "POST",
      "endpoint": "/users/{id}/multifactor/actions/invalidate-remember-browser",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "User ID",
          "required": true
        }
      ]
    },
    {
      "id": "list_roles",
      "name": "List Roles",
      "description": "List all roles defined in the Auth0 tenant",
      "http_method": "GET",
      "endpoint": "/roles",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "per_page",
          "type": "number",
          "description": "Number of results per page",
          "required": false
        }
      ]
    },
    {
      "id": "get_user_roles",
      "name": "Get User Roles",
      "description": "List all roles assigned to a specific user",
      "http_method": "GET",
      "endpoint": "/users/{id}/roles",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "User ID",
          "required": true
        }
      ]
    },
    {
      "id": "list_connections",
      "name": "List Connections",
      "description": "List all identity provider connections",
      "http_method": "GET",
      "endpoint": "/connections",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "strategy",
          "type": "string",
          "description": "Filter by connection strategy type",
          "required": false
        }
      ]
    },
    {
      "id": "list_organizations",
      "name": "List Organizations",
      "description": "List all organizations in the Auth0 tenant",
      "http_method": "GET",
      "endpoint": "/organizations",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "per_page",
          "type": "number",
          "description": "Number of results per page",
          "required": false
        }
      ]
    },
    {
      "id": "get_logs",
      "name": "Get Logs",
      "description": "Retrieve log events for authentication and admin activity auditing",
      "http_method": "GET",
      "endpoint": "/logs",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "q",
          "type": "string",
          "description": "Lucene query string for filtering log events",
          "required": false
        },
        {
          "name": "from",
          "type": "string",
          "description": "Log ID to start from",
          "required": false
        },
        {
          "name": "per_page",
          "type": "number",
          "description": "Number of results per page",
          "required": false
        }
      ]
    }
  ]
}