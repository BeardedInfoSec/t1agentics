{
  "id": "strongdm",
  "name": "StrongDM",
  "description": "Infrastructure access management through StrongDM API for managing accounts, resources, roles, access rules, and audit logs",
  "version": "1.0.0",
  "category": "identity",
  "vendor": "StrongDM",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "x-sdm-authentication",
    "location": "header"
  },
  "base_url": "https://app.strongdm.com/api/v1",
  "actions": [
    {
      "id": "list_accounts",
      "name": "List Accounts",
      "description": "List all user and service accounts in StrongDM",
      "http_method": "GET",
      "endpoint": "/accounts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression for accounts",
          "required": false
        }
      ]
    },
    {
      "id": "get_account",
      "name": "Get Account",
      "description": "Retrieve details of a specific account",
      "http_method": "GET",
      "endpoint": "/accounts/{id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "Account ID",
          "required": true
        }
      ]
    },
    {
      "id": "suspend_account",
      "name": "Suspend Account",
      "description": "Suspend an account to revoke all access",
      "http_method": "PUT",
      "endpoint": "/accounts/{id}",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "Account ID to suspend",
          "required": true
        }
      ]
    },
    {
      "id": "list_resources",
      "name": "List Resources",
      "description": "List all resources (databases, servers, clusters, etc.)",
      "http_method": "GET",
      "endpoint": "/resources",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression for resources",
          "required": false
        }
      ]
    },
    {
      "id": "get_resource",
      "name": "Get Resource",
      "description": "Retrieve details of a specific resource",
      "http_method": "GET",
      "endpoint": "/resources/{id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "Resource ID",
          "required": true
        }
      ]
    },
    {
      "id": "list_roles",
      "name": "List Roles",
      "description": "List all roles defined in StrongDM",
      "http_method": "GET",
      "endpoint": "/roles",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression for roles",
          "required": false
        }
      ]
    },
    {
      "id": "list_access_rules",
      "name": "List Access Rules",
      "description": "List all access rules that grant resource access to roles",
      "http_method": "GET",
      "endpoint": "/access-rules",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression for access rules",
          "required": false
        }
      ]
    },
    {
      "id": "list_account_grants",
      "name": "List Account Grants",
      "description": "List all role grants for an account",
      "http_method": "GET",
      "endpoint": "/account-grants",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression (e.g. account_id:abc123)",
          "required": false
        }
      ]
    },
    {
      "id": "delete_account_grant",
      "name": "Revoke Account Grant",
      "description": "Revoke a role grant from an account",
      "http_method": "DELETE",
      "endpoint": "/account-grants/{id}",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "Account grant ID to revoke",
          "required": true
        }
      ]
    },
    {
      "id": "list_queries",
      "name": "List Queries",
      "description": "List recorded queries/commands for auditing",
      "http_method": "GET",
      "endpoint": "/queries",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression for queries",
          "required": false
        }
      ]
    }
  ]
}