{
  "id": "sprinto",
  "name": "Sprinto",
  "description": "Integrates with Sprinto Developer API for compliance automation including controls monitoring, evidence management, and risk assessment across frameworks",
  "version": "1.0.0",
  "category": "grc",
  "vendor": "Sprinto",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "x-api-key",
    "location": "header"
  },
  "base_url": "https://app.sprinto.com/dev-api",
  "actions": [
    {
      "id": "list_controls",
      "name": "List Controls",
      "description": "Query controls and their compliance status via GraphQL",
      "http_method": "POST",
      "endpoint": "/graphql",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "query", "type": "string", "description": "GraphQL query for controls (e.g. { controls { id name status } })", "required": true},
        {"name": "variables", "type": "string", "description": "JSON object of GraphQL variables", "required": false}
      ]
    },
    {
      "id": "list_evidence",
      "name": "List Evidence",
      "description": "Query evidence items and their status via GraphQL",
      "http_method": "POST",
      "endpoint": "/graphql",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "query", "type": "string", "description": "GraphQL query for evidence items", "required": true},
        {"name": "variables", "type": "string", "description": "JSON object of GraphQL variables", "required": false}
      ]
    },
    {
      "id": "list_risks",
      "name": "List Risks",
      "description": "Query risk register entries via GraphQL",
      "http_method": "POST",
      "endpoint": "/graphql",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "query", "type": "string", "description": "GraphQL query for risk entries", "required": true},
        {"name": "variables", "type": "string", "description": "JSON object of GraphQL variables", "required": false}
      ]
    },
    {
      "id": "list_frameworks",
      "name": "List Frameworks",
      "description": "Query compliance frameworks and readiness status via GraphQL",
      "http_method": "POST",
      "endpoint": "/graphql",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "query", "type": "string", "description": "GraphQL query for frameworks", "required": true},
        {"name": "variables", "type": "string", "description": "JSON object of GraphQL variables", "required": false}
      ]
    },
    {
      "id": "upload_evidence",
      "name": "Upload Evidence",
      "description": "Upload evidence document for a control via GraphQL mutation",
      "http_method": "POST",
      "endpoint": "/graphql",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "query", "type": "string", "description": "GraphQL mutation for uploading evidence", "required": true},
        {"name": "variables", "type": "string", "description": "JSON object with upload variables (controlId, file, description)", "required": true}
      ]
    },
    {
      "id": "list_personnel",
      "name": "List Personnel",
      "description": "Query personnel and their compliance readiness via GraphQL",
      "http_method": "POST",
      "endpoint": "/graphql",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "query", "type": "string", "description": "GraphQL query for personnel records", "required": true},
        {"name": "variables", "type": "string", "description": "JSON object of GraphQL variables", "required": false}
      ]
    }
  ]
}
