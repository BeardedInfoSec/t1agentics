{
  "id": "rapid7_insightappsec",
  "name": "Rapid7 InsightAppSec",
  "description": "Cloud-based DAST solution for automated web application security testing and vulnerability management",
  "version": "1.0.0",
  "category": "code_security",
  "vendor": "Rapid7",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "X-Api-Key",
    "location": "header"
  },
  "base_url": "https://us.api.insight.rapid7.com/ias/v1",
  "actions": [
    {
      "id": "list_apps",
      "name": "List Applications",
      "description": "List all applications configured for scanning",
      "http_method": "GET",
      "endpoint": "/apps",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "index",
          "type": "integer",
          "description": "Page index (0-based)",
          "required": false,
          "location": "query"
        },
        {
          "name": "size",
          "type": "integer",
          "description": "Page size",
          "required": false,
          "location": "query"
        },
        {
          "name": "sort",
          "type": "string",
          "description": "Sort field and direction (e.g., app.name,ASC)",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "list_scans",
      "name": "List Scans",
      "description": "List all scans with status and results summary",
      "http_method": "GET",
      "endpoint": "/scans",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "index",
          "type": "integer",
          "description": "Page index",
          "required": false,
          "location": "query"
        },
        {
          "name": "size",
          "type": "integer",
          "description": "Page size",
          "required": false,
          "location": "query"
        },
        {
          "name": "sort",
          "type": "string",
          "description": "Sort by field (e.g., scan.submit_time,DESC)",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "get_scan",
      "name": "Get Scan Details",
      "description": "Retrieve detailed information about a specific scan",
      "http_method": "GET",
      "endpoint": "/scans/{scan_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "scan_id",
          "type": "string",
          "description": "Scan UUID",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "list_vulnerabilities",
      "name": "List Vulnerabilities",
      "description": "Search and list vulnerabilities discovered across scans",
      "http_method": "GET",
      "endpoint": "/vulnerabilities",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "index",
          "type": "integer",
          "description": "Page index",
          "required": false,
          "location": "query"
        },
        {
          "name": "size",
          "type": "integer",
          "description": "Page size",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "get_vulnerability",
      "name": "Get Vulnerability Details",
      "description": "Retrieve detailed information about a specific vulnerability",
      "http_method": "GET",
      "endpoint": "/vulnerabilities/{vulnerability_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "vulnerability_id",
          "type": "string",
          "description": "Vulnerability UUID",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "list_attack_templates",
      "name": "List Attack Templates",
      "description": "List available scan attack templates",
      "http_method": "GET",
      "endpoint": "/attack-templates",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    }
  ]
}
