{
  "id": "semgrep",
  "name": "Semgrep",
  "description": "Lightweight static analysis tool for finding bugs, security vulnerabilities, and enforcing code standards using custom and community rules",
  "version": "1.0.0",
  "category": "code_security",
  "vendor": "Semgrep (r2c)",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "prefix": "Bearer ",
    "location": "header"
  },
  "base_url": "https://semgrep.dev/api/v1",
  "actions": [
    {
      "id": "list_deployments",
      "name": "List Deployments",
      "description": "List all deployments (organizations) accessible by the API token",
      "http_method": "GET",
      "endpoint": "/deployments",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "list_findings",
      "name": "List Findings",
      "description": "List security findings for a deployment with optional filtering",
      "http_method": "GET",
      "endpoint": "/deployments/{deployment_slug}/findings",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "deployment_slug",
          "type": "string",
          "description": "Deployment slug identifier",
          "required": true,
          "location": "path"
        },
        {
          "name": "repos",
          "type": "string",
          "description": "Comma-separated list of repository names to filter",
          "required": false,
          "location": "query"
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity: error, warning, info",
          "required": false,
          "location": "query"
        },
        {
          "name": "rule",
          "type": "string",
          "description": "Filter by specific rule ID",
          "required": false,
          "location": "query"
        },
        {
          "name": "cursor",
          "type": "string",
          "description": "Pagination cursor for next page of results",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "list_projects",
      "name": "List Projects",
      "description": "List all projects (repositories) in a deployment",
      "http_method": "GET",
      "endpoint": "/deployments/{deployment_slug}/projects",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "deployment_slug",
          "type": "string",
          "description": "Deployment slug identifier",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "list_scans",
      "name": "List Scans",
      "description": "List recent scans for a deployment",
      "http_method": "GET",
      "endpoint": "/deployments/{deployment_slug}/scans",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "deployment_slug",
          "type": "string",
          "description": "Deployment slug identifier",
          "required": true,
          "location": "path"
        },
        {
          "name": "repo",
          "type": "string",
          "description": "Filter by repository name",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "get_finding",
      "name": "Get Finding Details",
      "description": "Retrieve detailed information about a specific finding",
      "http_method": "GET",
      "endpoint": "/deployments/{deployment_slug}/findings/{finding_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "deployment_slug",
          "type": "string",
          "description": "Deployment slug identifier",
          "required": true,
          "location": "path"
        },
        {
          "name": "finding_id",
          "type": "string",
          "description": "Finding ID",
          "required": true,
          "location": "path"
        }
      ]
    }
  ]
}
