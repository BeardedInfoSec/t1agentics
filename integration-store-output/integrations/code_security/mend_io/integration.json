{
  "id": "mend_io",
  "name": "Mend.io",
  "description": "Software composition analysis and application security platform for open source vulnerability detection, license compliance, and automated remediation",
  "version": "1.0.0",
  "category": "code_security",
  "vendor": "Mend.io",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "prefix": "Bearer ",
    "location": "header",
    "token_endpoint": "/api/v2.0/login",
    "description": "JWT token obtained via login endpoint using user key, valid for 30 minutes"
  },
  "base_url": "https://api-sca.mend.io/api/v2.0",
  "actions": [
    {
      "id": "list_organizations",
      "name": "List Organizations",
      "description": "List all organizations accessible to the authenticated user",
      "http_method": "GET",
      "endpoint": "/orgs",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "list_products",
      "name": "List Products",
      "description": "List all products in an organization",
      "http_method": "GET",
      "endpoint": "/orgs/{org_uuid}/products",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "org_uuid",
          "type": "string",
          "description": "Organization UUID",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "list_projects",
      "name": "List Projects",
      "description": "List all projects within a product",
      "http_method": "GET",
      "endpoint": "/orgs/{org_uuid}/products/{product_uuid}/projects",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "org_uuid",
          "type": "string",
          "description": "Organization UUID",
          "required": true,
          "location": "path"
        },
        {
          "name": "product_uuid",
          "type": "string",
          "description": "Product UUID",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "list_alerts",
      "name": "List Security Alerts",
      "description": "List security vulnerability alerts for a project",
      "http_method": "GET",
      "endpoint": "/orgs/{org_uuid}/projects/{project_uuid}/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "org_uuid",
          "type": "string",
          "description": "Organization UUID",
          "required": true,
          "location": "path"
        },
        {
          "name": "project_uuid",
          "type": "string",
          "description": "Project UUID",
          "required": true,
          "location": "path"
        },
        {
          "name": "type",
          "type": "string",
          "description": "Alert type filter: SECURITY_VULNERABILITY, LICENSE, MULTIPLE_LIBRARY_VERSIONS",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "get_vulnerable_libraries_by_cve",
      "name": "Get Vulnerable Libraries by CVE",
      "description": "Find libraries affected by a specific CVE across the organization",
      "http_method": "GET",
      "endpoint": "/orgs/{org_uuid}/vulnerabilities/{vulnerability_name}/libraries",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "org_uuid",
          "type": "string",
          "description": "Organization UUID",
          "required": true,
          "location": "path"
        },
        {
          "name": "vulnerability_name",
          "type": "string",
          "description": "CVE identifier (e.g., CVE-2021-44228)",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "list_libraries",
      "name": "List Project Libraries",
      "description": "List all libraries used in a project",
      "http_method": "GET",
      "endpoint": "/orgs/{org_uuid}/projects/{project_uuid}/libraries",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "org_uuid",
          "type": "string",
          "description": "Organization UUID",
          "required": true,
          "location": "path"
        },
        {
          "name": "project_uuid",
          "type": "string",
          "description": "Project UUID",
          "required": true,
          "location": "path"
        }
      ]
    }
  ]
}
