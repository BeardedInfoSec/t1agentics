{
  "id": "threatcrowd",
  "name": "ThreatCrowd",
  "description": "This app provides free investigative actions",
  "version": "2.1.3",
  "category": "threat_intel",
  "vendor": "ThreatCrowd",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "http://ci-www.threatcrowd.org/",
  "actions": [
    {
      "id": "lookup_domain",
      "name": "Lookup Domain",
      "description": "Queries ThreatCrowd for domain info",
      "http_method": "GET",
      "endpoint": "/actions/lookup_domain",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "domain",
          "type": "string",
          "description": "Domain to query",
          "required": true,
          "contains": [
            "domain"
          ]
        },
        {
          "name": "response_limit",
          "type": "number",
          "description": "Response length limit (0 = all, default 10)",
          "required": false,
          "default": 10
        }
      ],
      "observable_type": "domain"
    },
    {
      "id": "lookup_email",
      "name": "Lookup Email",
      "description": "Queries ThreatCrowd for email info",
      "http_method": "GET",
      "endpoint": "/actions/lookup_email",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "email",
          "type": "string",
          "description": "Email to query",
          "required": true,
          "contains": [
            "email"
          ]
        },
        {
          "name": "response_limit",
          "type": "number",
          "description": "Response length limit (0 = all, default 10)",
          "required": false,
          "default": 10
        }
      ],
      "observable_type": "email"
    },
    {
      "id": "lookup_ip",
      "name": "Lookup Ip",
      "description": "Queries ThreatCrowd for IP info",
      "http_method": "GET",
      "endpoint": "/actions/lookup_ip",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "ip",
          "type": "string",
          "description": "IP to query",
          "required": true,
          "contains": [
            "ip",
            "ipv6"
          ]
        },
        {
          "name": "response_limit",
          "type": "number",
          "description": "Response length limit (0 = all, default 10)",
          "required": false,
          "default": 10
        }
      ],
      "observable_type": "ip"
    },
    {
      "id": "file_reputation",
      "name": "File Reputation",
      "description": "Queries ThreatCrowd for file reputation",
      "http_method": "GET",
      "endpoint": "/actions/file_reputation",
      "action_type": "investigate",
      "read_only": true,
