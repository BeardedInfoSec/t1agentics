{
  "id": "censys",
  "name": "Censys",
  "description": "This app implements investigative actions to get information from the Censys search engine",
  "version": "2.2.4",
  "category": "threat_intel",
  "vendor": "Censys, Inc.",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://search.censys.io",
  "actions": [
    {
      "id": "lookup_certificate",
      "name": "Lookup Certificate",
      "description": "Lookup certificate info",
      "http_method": "GET",
      "endpoint": "/actions/lookup_certificate",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "sha256",
          "type": "string",
          "description": "SHA256 fingerprint of certificate",
          "required": true,
          "contains": [
            "hash",
            "sha256"
          ]
        }
      ],
      "observable_type": "file_hash"
    },
    {
      "id": "lookup_ip",
      "name": "Lookup Ip",
      "description": "Lookup IP info",
      "http_method": "GET",
      "endpoint": "/actions/lookup_ip",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "ip",
          "type": "string",
          "description": "IP to get info of",
          "required": true,
          "contains": [
            "ip",
            "ipv6"
          ]
        }
      ],
      "observable_type": "ip"
    },
    {
      "id": "lookup_domain",
      "name": "Lookup Domain",
      "description": "Lookup Domain info",
      "http_method": "GET",
      "endpoint": "/actions/lookup_domain",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "domain",
          "type": "string",
          "description": "Domain to lookup",
          "required": true,
          "contains": [
            "domain"
          ]
        }
      ],
      "observable_type": "domain"
    },
    {
      "id": "query_domain",
      "name": "Query Domain",
      "description": "Query the domain dataset",
      "http_method": "GET",
      "endpoint": "/actions/query_domain",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Censys.IO query string to use",
          "required": true
        }
      ],
      "observable_type": "domain"
    },
    {
      "id": "query_certificate",
      "name": "Query Certificate",
      "description": "Query the certificate dataset",
      "http_method": "GET",
      "endpoint": "/actions/query_certificate",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Censys.IO query string to use",
          "required": true
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Number of results to fetch",
          "required": false,
          "default": 200
        }
      ]
    },
    {
      "id": "query_ip",
      "name": "Query Ip",
      "description": "Query the IP dataset",
      "http_method": "GET",
      "endpoint": "/actions/query_ip",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Censys.IO query string to use",
          "required": true
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Number of results to fetch",
          "required": false,
          "default": 200
        }
      ],
      "observable_type": "ip"
    }
  ],
