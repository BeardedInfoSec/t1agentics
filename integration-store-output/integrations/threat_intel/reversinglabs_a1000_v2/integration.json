    {
      "id": "detonate_file",
      "name": "Detonate File",
      "description": "Upload file to A1000",
      "http_method": "GET",
      "endpoint": "/actions/detonate_file",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "vault_id",
          "type": "string",
          "description": "Vault ID of file to detonate",
          "required": true,
          "contains": [
            "vault id"
          ]
        },
        {
          "name": "file_name",
          "type": "string",
          "description": "Filename to use",
          "required": false
        },
        {
          "name": "custom_file_name",
          "type": "string",
          "description": "Custom file name for upload",
          "required": false,
          "contains": [
            "file name"
          ]
        },
        {
          "name": "archive_password",
          "type": "password",
          "description": "Password for the file if it is password protected",
          "required": false
        },
        {
          "name": "rl_cloud_sandbox_platform",
          "type": "string",
          "description": "Cloud Sandbox platform",
          "required": false
        },
        {
          "name": "tags",
          "type": "string",
          "description": "Comma separated list of tags to assign to sample",
          "required": false
        },
        {
          "name": "comment",
          "type": "string",
          "description": "Comment to add to a sample",
          "required": false
        },
        {
          "name": "cloud_analysis",
          "type": "boolean",
          "description": "Use cloud analysis",
          "required": false
        }
      ],
      "observable_type": "file_hash"
    },
