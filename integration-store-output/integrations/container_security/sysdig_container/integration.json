{
  "id": "sysdig_container",
  "name": "Sysdig Secure",
  "description": "Container and Kubernetes security platform providing runtime threat detection, vulnerability management, compliance, and forensics",
  "version": "1.0.0",
  "category": "container_security",
  "vendor": "Sysdig",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "prefix": "Bearer ",
    "location": "header"
  },
  "base_url": "https://{region}.app.sysdig.com/api",
  "actions": [
    {
      "id": "list_runtime_results",
      "name": "List Runtime Vulnerability Results",
      "description": "List vulnerability scan results for running workloads",
      "http_method": "GET",
      "endpoint": "/scanning/v2/results",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression for results",
          "required": false,
          "location": "query"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max results to return",
          "required": false,
          "location": "query"
        },
        {
          "name": "cursor",
          "type": "string",
          "description": "Pagination cursor",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "get_image_vulnerabilities",
      "name": "Get Image Vulnerabilities",
      "description": "Retrieve vulnerabilities found in a specific container image",
      "http_method": "GET",
      "endpoint": "/scanning/v2/results/{result_id}/vulnPkgs",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "result_id",
          "type": "string",
          "description": "Scan result ID",
          "required": true,
          "location": "path"
        },
        {
          "name": "filter",
          "type": "string",
          "description": "Filter vulnerabilities (e.g., by severity)",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "list_policies",
      "name": "List Scanning Policies",
      "description": "List vulnerability management scanning policies",
      "http_method": "GET",
      "endpoint": "/scanning/v2/policies",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "list_runtime_alerts",
      "name": "List Runtime Alerts",
      "description": "List runtime security alerts from Falco-based threat detection",
      "http_method": "GET",
      "endpoint": "/v1/secureEvents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "from",
          "type": "integer",
          "description": "Start time in epoch seconds",
          "required": false,
          "location": "query"
        },
        {
          "name": "to",
          "type": "integer",
          "description": "End time in epoch seconds",
          "required": false,
          "location": "query"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max results to return",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "get_compliance_results",
      "name": "Get Compliance Results",
      "description": "Retrieve compliance benchmark results for Kubernetes and container environments",
      "http_method": "GET",
      "endpoint": "/cspm/v1/compliance/results",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "framework",
          "type": "string",
          "description": "Compliance framework (e.g., CIS, NIST, PCI)",
          "required": false,
          "location": "query"
        }
      ]
    }
  ]
}
