{
  "id": "neuvector",
  "name": "NeuVector",
  "description": "Open source full-lifecycle container security platform with runtime protection, network segmentation, vulnerability scanning, and compliance",
  "version": "1.0.0",
  "category": "container_security",
  "vendor": "SUSE",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "prefix": "Bearer ",
    "location": "header",
    "token_endpoint": "/v1/auth",
    "description": "POST username/password to /v1/auth to obtain token; DELETE /v1/auth to logout"
  },
  "base_url": "https://{host}/v1",
  "actions": [
    {
      "id": "list_workloads",
      "name": "List Workloads",
      "description": "List all container workloads with security status",
      "http_method": "GET",
      "endpoint": "/workload",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "brief",
          "type": "boolean",
          "description": "Return brief workload information",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "get_workload_vulnerabilities",
      "name": "Get Workload Vulnerabilities",
      "description": "Retrieve vulnerabilities for a specific running container workload",
      "http_method": "GET",
      "endpoint": "/scan/workload/{workload_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "workload_id",
          "type": "string",
          "description": "Workload/container ID",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "scan_repository",
      "name": "Scan Repository Image",
      "description": "Trigger a vulnerability scan for a container image in a registry",
      "http_method": "POST",
      "endpoint": "/scan/repository",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "repository",
          "type": "string",
          "description": "Full repository path (e.g., docker.io/library/nginx)",
          "required": true,
          "location": "body"
        },
        {
          "name": "tag",
          "type": "string",
          "description": "Image tag to scan",
          "required": true,
          "location": "body"
        }
      ]
    },
    {
      "id": "get_compliance_profile",
      "name": "Get Compliance Profile",
      "description": "Retrieve compliance check results including CIS benchmarks and custom checks",
      "http_method": "GET",
      "endpoint": "/compliance/profile",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "list_security_events",
      "name": "List Security Events",
      "description": "List runtime security violation events and threat alerts",
      "http_method": "GET",
      "endpoint": "/log/security",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "start",
          "type": "integer",
          "description": "Pagination start index",
          "required": false,
          "location": "query"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max number of events",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "quarantine_workload",
      "name": "Quarantine Workload",
      "description": "Quarantine a container workload to isolate it from network communication",
      "http_method": "PATCH",
      "endpoint": "/workload/{workload_id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "workload_id",
          "type": "string",
          "description": "Workload/container ID to quarantine",
          "required": true,
          "location": "path"
        },
        {
          "name": "quarantine",
          "type": "boolean",
          "description": "Set to true to quarantine, false to unquarantine",
          "required": true,
          "location": "body"
        }
      ]
    }
  ]
}
