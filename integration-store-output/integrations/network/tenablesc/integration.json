      "http_method": "GET",
      "endpoint": "/actions/list_vulnerabilities",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "ip_hostname",
          "type": "string",
          "description": "IP / host name of host to query",
          "required": false,
          "contains": [
            "ip",
            "host name"
          ]
        },
        {
          "name": "cve_id",
          "type": "string",
          "description": "CVEID to query",
          "required": false
