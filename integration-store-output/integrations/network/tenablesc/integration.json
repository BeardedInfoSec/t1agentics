{
  "id": "tenablesc",
  "name": "Tenable.sc",
  "description": "This app integrates with Tenable's SecurityCenter to provide endpoint-based investigative actions",
  "version": "2.4.0",
  "category": "network",
  "vendor": "Tenable",
  "auth_type": "basic_auth",
  "auth_config": {
    "type": "basic_auth",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "",
  "actions": [
    {
      "id": "scan_endpoint",
      "name": "Scan Endpoint",
      "description": "Runs a scan against a specified IP or host",
      "http_method": "GET",
      "endpoint": "/scan",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "scan_name",
          "type": "string",
          "description": "Title of the Tenable scan",
          "required": false,
          "default": "Scan launched from Splunk SOAR"
        },
        {
          "name": "ip_hostname",
          "type": "string",
          "description": "IP/Hostname to scan (comma-separated)",
          "required": true,
          "contains": [
            "ip",
            "host name"
          ]
        },
        {
          "name": "scan_policy_id",
          "type": "number",
          "description": "Scan Policy ID of the Tenable scan",
          "required": true,
          "contains": [
            "tenablesc scan policy id"
          ]
        },
        {
          "name": "repository_id",
          "type": "number",
          "description": "Repository ID of the Tenable scan",
          "required": false,
          "default": "1",
          "contains": [
            "tenablesc repository id"
          ]
        },
        {
          "name": "credential_id",
          "type": "number",
          "description": "Credential ID of the Tenable scan",
          "required": false,
          "contains": [
            "tenablesc credential id"
          ]
        },
        {
          "name": "report_id",
          "type": "number",
          "description": "Report ID of the Tenable scan",
          "required": false
        },
        {
          "name": "report_source",
          "type": "string",
          "description": "Resource from which to fetch report",
          "required": false,
          "default": "cumulative"
        }
      ]
    },
    {
      "id": "list_vulnerabilities",
      "name": "List Vulnerabilities",
