{
  "id": "wildfire",
  "name": "WildFire",
  "description": "This app supports file detonation for forensic file analysis on the Palo Alto Networks WildFire sandbox",
  "version": "3.0.5",
  "category": "sandbox",
  "vendor": "Palo Alto Networks",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "base_url",
  "actions": [
    {
      "id": "detonate_file",
      "name": "Detonate File",
      "description": "Run the file in the WildFire sandbox and retrieve the analysis results",
      "http_method": "GET",
      "endpoint": "/actions/detonate_file",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "vault_id",
          "type": "string",
          "description": "Vault ID of file to detonate",
          "required": true,
          "contains": [
            "pe file",
            "pdf",
            "flash",
            "apk",
            "jar",
            "doc",
            "xls",
            "ppt"
          ]
        },
        {
          "name": "file_name",
          "type": "string",
          "description": "Filename to use",
          "required": false,
          "contains": [
            "file name"
          ]
        }
      ],
      "observable_type": "file_hash"
    },
    {
      "id": "detonate_url",
      "name": "Detonate Url",
      "description": "Submit a single website link for WildFire analysis",
      "http_method": "GET",
      "endpoint": "/actions/detonate_url",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "url",
          "type": "string",
          "description": "URL to query. Starts with http:// or https://",
          "required": true,
          "contains": [
            "url"
          ]
        },
        {
          "name": "is_file",
          "type": "boolean",
          "description": "True if the URL points to a file (WildFire treats these differently)",
          "required": false,
          "default": false
        }
      ],
      "observable_type": "url"
    },
    {
      "id": "get_url_reputation",
      "name": "Url Reputation",
      "description": "Submit a single website link for WildFire verdict",
      "http_method": "GET",
      "endpoint": "/actions/get_url_reputation",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "url",
          "type": "string",
          "description": "URL to query. Starts with http:// or https://",
          "required": true,
          "contains": [
            "url"
          ]
        }
      ],
      "observable_type": "url"
    },
    {
      "id": "get_report",
      "name": "Get Report",
      "description": "Query for results of an already completed detonation in WildFire",
      "http_method": "GET",
      "endpoint": "/get/report",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "File MD5 or Sha256 to get the results of",
          "required": true,
          "contains": [
            "md5",
            "sha256",
            "wildfire task id"
          ]
        }
      ]
    },
    {
      "id": "get_sample",
      "name": "Get File",
      "description": "Download a sample from WildFire and add it to the vault",
      "http_method": "GET",
      "endpoint": "/get/sample",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "hash",
          "type": "string",
          "description": "Hash of file/sample to download",
          "required": true,
          "contains": [
            "md5",
            "sha256",
            "wildfire task id"
          ]
        }
      ],
      "observable_type": "file_hash"
    },
    {
      "id": "get_pcap",
      "name": "Get Pcap",
      "description": "Download the pcap file of a sample from WildFire and add it to the vault",
      "http_method": "GET",
      "endpoint": "/get/pcap",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "hash",
          "type": "string",
          "description": "Hash of file/sample to download pcap of",
          "required": true,
          "contains": [
            "md5",
            "sha256",
            "wildfire task id"
          ]
        },
        {
          "name": "platform",
          "type": "string",
          "description": "Platform of file/sample to download pcap of",
          "required": true
        }
      ],
      "observable_type": "file_hash"
    },
    {
      "id": "save_report",
      "name": "Save Report",
      "description": "Save a PDF of the detonation report to the vault",
      "http_method": "GET",
      "endpoint": "/actions/save_report",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "File MD5 or Sha256 to get the results of",
          "required": true,
          "contains": [
            "md5",
            "sha256",
            "wildfire task id"
          ]
        }
      ]
    }
  ],
  "source_metadata": {
    "original_name": "WildFire",
    "original_type": "sandbox",
    "converted_at": "2025-12-18T16:25:29.310649",
    "source_version": "3.0.5"
  }
}