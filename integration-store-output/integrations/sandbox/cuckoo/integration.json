{
  "id": "cuckoo",
  "name": "Cuckoo",
  "description": "This app supports executing various investigative and generic actions on the Cuckoo sandbox",
  "version": "2.2.2",
  "category": "sandbox",
  "vendor": "Cuckoo",
  "auth_type": "basic_auth",
  "auth_config": {
    "type": "basic_auth",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "{scheme}://{host}:{port}{append_uri}",
  "actions": [
    {
      "id": "detonate_file",
      "name": "Detonate File",
      "description": "Run the file in the sandbox and retrieve the analysis results",
      "http_method": "GET",
      "endpoint": "/actions/detonate_file",
      "action_type": "generic",
      "read_only": false,
      "cacheable": false,
      "cache_ttl_days": 0,
      "parameters": [
        {
          "name": "vault_id",
          "type": "string",
          "description": "Vault ID of file to detonate",
          "required": true,
          "contains": [
            "vault id",
            "sha1"
          ]
        },
        {
          "name": "file_name",
          "type": "string",
          "description": "Filename to use",
          "required": false,
          "contains": [
            "file name"
          ]
        },
        {
          "name": "zip_and_encrypt",
          "type": "boolean",
          "description": "Option to zip and encrypt file, WARNING: password visible as zip command line argument",
          "required": false,
          "default": false
        }
      ],
      "observable_type": "file_hash"
    },
    {
      "id": "get_report",
      "name": "Get Report",
      "description": "Query for results of an already completed detonation",
      "http_method": "GET",
      "endpoint": "/actions/get_report",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "description": "Task ID to get the results of",
          "required": true,
          "contains": [
            "cuckoo task id"
          ]
        }
      ]
    },
    {
      "id": "detonate_url",
      "name": "Detonate Url",
      "description": "Load a URL in the Cuckoo sandbox and retrieve the analysis results",
      "http_method": "GET",
      "endpoint": "/actions/detonate_url",
      "action_type": "generic",
      "read_only": false,
      "cacheable": false,
      "cache_ttl_days": 0,
      "parameters": [
        {
          "name": "url",
          "type": "string",
          "description": "URL to detonate",
          "required": true,
          "contains": [
            "url",
            "domain"
          ]
        }
      ],
      "observable_type": "url"
    },
    {
      "id": "submit_strings",
      "name": "Submit Strings",
      "description": "Add VirusTotal compatible URL/Domain to the list of pending tasks",
      "http_method": "GET",
      "endpoint": "/actions/submit_strings",
      "action_type": "generic",
      "read_only": false,
      "cacheable": false,
      "cache_ttl_days": 0,
      "parameters": [
        {
          "name": "url",
          "type": "string",
          "description": "Single VirusTotal compatible URL/Domain",
          "required": true,
          "contains": [
            "url",
            "domain"
          ]
        }
      ],
      "observable_type": "url"
    }
  ],
  "source_metadata": {
    "original_name": "Cuckoo",
    "original_type": "sandbox",
    "converted_at": "2025-12-18T16:25:28.717447",
    "source_version": "2.2.2"
  }
}