{
  "id": "azure_defender_cloud_apps",
  "name": "Microsoft Defender for Cloud Apps",
  "description": "Cloud Access Security Broker (CASB) providing visibility, data control, and threat protection for cloud applications and services",
  "version": "1.0.0",
  "category": "azure_security",
  "vendor": "Microsoft Azure",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "token_url": "https://login.microsoftonline.com/{tenantId}/oauth2/v2.0/token",
    "scope": "https://graph.microsoft.com/.default",
    "grant_type": "client_credentials"
  },
  "base_url": "https://graph.microsoft.com/v1.0/security",
  "actions": [
    {
      "id": "list_alerts",
      "name": "List Cloud App Alerts",
      "description": "List security alerts generated by Defender for Cloud Apps",
      "http_method": "GET",
      "endpoint": "/alerts_v2",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "$filter",
          "type": "string",
          "description": "OData filter (e.g., \"serviceSource eq 'microsoftCloudAppSecurity' and severity eq 'high'\")",
          "required": false
        },
        {
          "name": "$top",
          "type": "number",
          "description": "Maximum alerts to return",
          "required": false,
          "default": 100
        },
        {
          "name": "$orderby",
          "type": "string",
          "description": "Order by expression",
          "required": false
        }
      ]
    },
    {
      "id": "get_alert",
      "name": "Get Alert Details",
      "description": "Retrieve detailed information about a specific cloud app security alert",
      "http_method": "GET",
      "endpoint": "/alerts_v2/{alertId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alertId",
          "type": "string",
          "description": "The unique identifier of the alert",
          "required": true
        }
      ]
    },
    {
      "id": "list_incidents",
      "name": "List Cloud App Incidents",
      "description": "List security incidents related to cloud applications",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "$filter",
          "type": "string",
          "description": "OData filter expression",
          "required": false
        },
        {
          "name": "$top",
          "type": "number",
          "description": "Maximum incidents to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "list_discovered_apps",
      "name": "List Discovered Apps",
      "description": "List cloud applications discovered through traffic analysis (Shadow IT)",
      "http_method": "GET",
      "endpoint": "/cloudAppDiscovery/uploadedStreams/{streamId}/microsoftGraphSecurity.discoveredCloudAppInfo",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "streamId",
          "type": "string",
          "description": "Discovery stream ID",
          "required": true
        },
        {
          "name": "$top",
          "type": "number",
          "description": "Maximum apps to return",
          "required": false,
          "default": 100
        },
        {
          "name": "$orderby",
          "type": "string",
          "description": "Order by expression (e.g., \"riskScore desc\")",
          "required": false
        }
      ]
    },
    {
      "id": "list_activities",
      "name": "List Activities",
      "description": "List user and admin activities in monitored cloud applications",
      "http_method": "GET",
      "endpoint": "/cloudAppDiscovery/uploadedStreams/{streamId}/microsoftGraphSecurity.discoveredCloudAppUser",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "streamId",
          "type": "string",
          "description": "Discovery stream ID",
          "required": true
        },
        {
          "name": "$top",
          "type": "number",
          "description": "Maximum activities to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "update_alert",
      "name": "Update Alert",
      "description": "Update the status or classification of a cloud app security alert",
      "http_method": "PATCH",
      "endpoint": "/alerts_v2/{alertId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "alertId",
          "type": "string",
          "description": "The unique identifier of the alert",
          "required": true
        },
        {
          "name": "status",
          "type": "string",
          "description": "New status (new, inProgress, resolved)",
          "required": false
        },
        {
          "name": "classification",
          "type": "string",
          "description": "Classification (truePositive, falsePositive, benignPositive)",
          "required": false
        }
      ]
    }
  ]
}