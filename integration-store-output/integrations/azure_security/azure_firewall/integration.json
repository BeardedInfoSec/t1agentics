{
  "id": "azure_firewall",
  "name": "Azure Firewall",
  "description": "Azure cloud-native stateful firewall service providing network and application level protection with built-in high availability and threat intelligence integration",
  "version": "1.0.0",
  "category": "azure_security",
  "vendor": "Microsoft Azure",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "token_url": "https://login.microsoftonline.com/{tenantId}/oauth2/v2.0/token",
    "scope": "https://management.azure.com/.default",
    "grant_type": "client_credentials"
  },
  "base_url": "https://management.azure.com",
  "actions": [
    {
      "id": "list_firewalls",
      "name": "List Firewalls",
      "description": "List all Azure Firewalls in a subscription",
      "http_method": "GET",
      "endpoint": "/subscriptions/{subscriptionId}/providers/Microsoft.Network/azureFirewalls",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "subscriptionId",
          "type": "string",
          "description": "Azure subscription ID",
          "required": true
        },
        {
          "name": "api-version",
          "type": "string",
          "description": "API version",
          "required": true,
          "default": "2023-09-01"
        }
      ]
    },
    {
      "id": "get_firewall",
      "name": "Get Firewall Details",
      "description": "Retrieve details of a specific Azure Firewall including rules and configuration",
      "http_method": "GET",
      "endpoint": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/azureFirewalls/{firewallName}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "subscriptionId",
          "type": "string",
          "description": "Azure subscription ID",
          "required": true
        },
        {
          "name": "resourceGroupName",
          "type": "string",
          "description": "Resource group name",
          "required": true
        },
        {
          "name": "firewallName",
          "type": "string",
          "description": "Firewall name",
          "required": true
        },
        {
          "name": "api-version",
          "type": "string",
          "description": "API version",
          "required": true,
          "default": "2023-09-01"
        }
      ]
    },
    {
      "id": "list_firewall_policies",
      "name": "List Firewall Policies",
      "description": "List Azure Firewall policies in a subscription",
      "http_method": "GET",
      "endpoint": "/subscriptions/{subscriptionId}/providers/Microsoft.Network/firewallPolicies",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "subscriptionId",
          "type": "string",
          "description": "Azure subscription ID",
          "required": true
        },
        {
          "name": "api-version",
          "type": "string",
          "description": "API version",
          "required": true,
          "default": "2023-09-01"
        }
      ]
    },
    {
      "id": "get_firewall_policy",
      "name": "Get Firewall Policy",
      "description": "Retrieve details of a specific firewall policy including rule collection groups",
      "http_method": "GET",
      "endpoint": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/firewallPolicies/{firewallPolicyName}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "subscriptionId",
          "type": "string",
          "description": "Azure subscription ID",
          "required": true
        },
        {
          "name": "resourceGroupName",
          "type": "string",
          "description": "Resource group name",
          "required": true
        },
        {
          "name": "firewallPolicyName",
          "type": "string",
          "description": "Firewall policy name",
          "required": true
        },
        {
          "name": "api-version",
          "type": "string",
          "description": "API version",
          "required": true,
          "default": "2023-09-01"
        }
      ]
    },
    {
      "id": "list_rule_collection_groups",
      "name": "List Rule Collection Groups",
      "description": "List rule collection groups within a firewall policy",
      "http_method": "GET",
      "endpoint": "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.Network/firewallPolicies/{firewallPolicyName}/ruleCollectionGroups",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "subscriptionId",
          "type": "string",
          "description": "Azure subscription ID",
          "required": true
        },
        {
          "name": "resourceGroupName",
          "type": "string",
          "description": "Resource group name",
          "required": true
        },
        {
          "name": "firewallPolicyName",
          "type": "string",
          "description": "Firewall policy name",
          "required": true
        },
        {
          "name": "api-version",
          "type": "string",
          "description": "API version",
          "required": true,
          "default": "2023-09-01"
        }
      ]
    }
  ]
}