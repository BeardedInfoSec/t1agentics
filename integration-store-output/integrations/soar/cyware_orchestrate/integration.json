{
  "id": "cyware_orchestrate",
  "name": "Cyware Orchestrate",
  "description": "Cyware security orchestration and threat response platform (CFTR) for incident management, playbook automation, and coordinated threat response across security tools.",
  "version": "1.0.0",
  "category": "soar",
  "vendor": "Cyware",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "location": "header",
    "token_prefix": "Bearer"
  },
  "base_url": "https://{host}/api/v1",
  "actions": [
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "Retrieve a list of incidents from Cyware Respond.",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "page", "type": "integer", "description": "Page number.", "required": false},
        {"name": "limit", "type": "integer", "description": "Results per page.", "required": false},
        {"name": "status", "type": "string", "description": "Filter by status.", "required": false},
        {"name": "severity", "type": "string", "description": "Filter by severity.", "required": false},
        {"name": "startDate", "type": "string", "description": "Start date in ISO 8601.", "required": false},
        {"name": "endDate", "type": "string", "description": "End date in ISO 8601.", "required": false}
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident",
      "description": "Retrieve details of a specific incident.",
      "http_method": "GET",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true}
      ]
    },
    {
      "id": "create_incident",
      "name": "Create Incident",
      "description": "Create a new incident in Cyware Respond.",
      "http_method": "POST",
      "endpoint": "/incidents",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "title", "type": "string", "description": "Incident title.", "required": true},
        {"name": "description", "type": "string", "description": "Incident description.", "required": false},
        {"name": "severity", "type": "string", "description": "Severity: 'Low', 'Medium', 'High', 'Critical'.", "required": false},
        {"name": "type", "type": "string", "description": "Incident type.", "required": false},
        {"name": "assignee", "type": "string", "description": "Assigned analyst.", "required": false},
        {"name": "source", "type": "string", "description": "Incident source.", "required": false}
      ]
    },
    {
      "id": "update_incident",
      "name": "Update Incident",
      "description": "Update an existing incident.",
      "http_method": "PUT",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true},
        {"name": "title", "type": "string", "description": "Updated title.", "required": false},
        {"name": "severity", "type": "string", "description": "Updated severity.", "required": false},
        {"name": "status", "type": "string", "description": "Updated status.", "required": false},
        {"name": "assignee", "type": "string", "description": "Updated assignee.", "required": false}
      ]
    },
    {
      "id": "close_incident",
      "name": "Close Incident",
      "description": "Close an incident with resolution.",
      "http_method": "PUT",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true},
        {"name": "status", "type": "string", "description": "Set to 'closed'.", "required": true},
        {"name": "resolution", "type": "string", "description": "Resolution summary.", "required": true},
        {"name": "closureReason", "type": "string", "description": "Reason for closure.", "required": false}
      ]
    },
    {
      "id": "run_playbook",
      "name": "Run Playbook",
      "description": "Execute an Orchestrate playbook on an incident.",
      "http_method": "POST",
      "endpoint": "/playbooks/{playbookId}/execute",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "playbookId", "type": "string", "description": "The playbook ID.", "required": true},
        {"name": "incidentId", "type": "string", "description": "The incident ID to run against.", "required": false},
        {"name": "parameters", "type": "object", "description": "Input parameters for the playbook.", "required": false}
      ]
    },
    {
      "id": "list_playbooks",
      "name": "List Playbooks",
      "description": "Retrieve a list of available Orchestrate playbooks.",
      "http_method": "GET",
      "endpoint": "/playbooks",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "page", "type": "integer", "description": "Page number.", "required": false},
        {"name": "limit", "type": "integer", "description": "Results per page.", "required": false}
      ]
    },
    {
      "id": "get_playbook_status",
      "name": "Get Playbook Status",
      "description": "Get the execution status of a playbook run.",
      "http_method": "GET",
      "endpoint": "/playbooks/executions/{executionId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "executionId", "type": "string", "description": "The playbook execution ID.", "required": true}
      ]
    },
    {
      "id": "add_artifact",
      "name": "Add Artifact",
      "description": "Add an indicator/artifact to an incident.",
      "http_method": "POST",
      "endpoint": "/incidents/{incidentId}/artifacts",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true},
        {"name": "type", "type": "string", "description": "Artifact type.", "required": true},
        {"name": "value", "type": "string", "description": "Artifact value.", "required": true},
        {"name": "description", "type": "string", "description": "Description.", "required": false}
      ]
    },
    {
      "id": "add_comment",
      "name": "Add Comment",
      "description": "Add a comment to an incident.",
      "http_method": "POST",
      "endpoint": "/incidents/{incidentId}/comments",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true},
        {"name": "comment", "type": "string", "description": "Comment text.", "required": true}
      ]
    }
  ]
}
