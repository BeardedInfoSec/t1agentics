{
  "id": "tines",
  "name": "Tines",
  "description": "No-code security automation platform for building and managing stories (workflows), cases, and automated actions across security tools.",
  "version": "1.0.0",
  "category": "soar",
  "vendor": "Tines",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "location": "header",
    "token_prefix": "Bearer"
  },
  "base_url": "https://{tenant}.tines.com/api/v1",
  "actions": [
    {
      "id": "list_stories",
      "name": "List Stories",
      "description": "Retrieve a paginated list of all stories (workflows) in the tenant.",
      "http_method": "GET",
      "endpoint": "/stories",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "page", "type": "integer", "description": "Page number for pagination.", "required": false},
        {"name": "per_page", "type": "integer", "description": "Number of results per page (default 20).", "required": false},
        {"name": "team_id", "type": "integer", "description": "Filter stories by team ID.", "required": false}
      ]
    },
    {
      "id": "get_story",
      "name": "Get Story",
      "description": "Retrieve details of a specific story by ID.",
      "http_method": "GET",
      "endpoint": "/stories/{story_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "story_id", "type": "integer", "description": "The story ID.", "required": true}
      ]
    },
    {
      "id": "create_story",
      "name": "Create Story",
      "description": "Create a new story (workflow).",
      "http_method": "POST",
      "endpoint": "/stories",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "name", "type": "string", "description": "Name of the story.", "required": true},
        {"name": "description", "type": "string", "description": "Story description.", "required": false},
        {"name": "team_id", "type": "integer", "description": "Team ID to assign the story to.", "required": true},
        {"name": "folder_id", "type": "integer", "description": "Folder ID to organize the story.", "required": false},
        {"name": "keep_events_for", "type": "integer", "description": "Number of seconds to retain events.", "required": false}
      ]
    },
    {
      "id": "list_actions",
      "name": "List Actions",
      "description": "Retrieve a list of all actions in the tenant or for a specific story.",
      "http_method": "GET",
      "endpoint": "/actions",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "story_id", "type": "integer", "description": "Filter actions by story ID.", "required": false},
        {"name": "page", "type": "integer", "description": "Page number.", "required": false},
        {"name": "per_page", "type": "integer", "description": "Results per page.", "required": false}
      ]
    },
    {
      "id": "get_action",
      "name": "Get Action",
      "description": "Retrieve details of a specific action by ID.",
      "http_method": "GET",
      "endpoint": "/actions/{action_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "action_id", "type": "integer", "description": "The action ID.", "required": true}
      ]
    },
    {
      "id": "create_action",
      "name": "Create Action",
      "description": "Create a new action within a story or group.",
      "http_method": "POST",
      "endpoint": "/actions",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "name", "type": "string", "description": "Name of the action.", "required": true},
        {"name": "story_id", "type": "integer", "description": "Story ID to add the action to.", "required": false},
        {"name": "group_id", "type": "integer", "description": "Group ID to add the action to.", "required": false},
        {"name": "type", "type": "string", "description": "Action type (e.g., 'httpRequestAction', 'eventTransformationAction').", "required": true},
        {"name": "options", "type": "object", "description": "Configuration options for the action.", "required": false},
        {"name": "position", "type": "object", "description": "Position object with 'x' and 'y' coordinates.", "required": false}
      ]
    },
    {
      "id": "list_cases",
      "name": "List Cases",
      "description": "Retrieve a list of cases for case management.",
      "http_method": "GET",
      "endpoint": "/../api/v2/cases",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "page", "type": "integer", "description": "Page number.", "required": false},
        {"name": "per_page", "type": "integer", "description": "Results per page.", "required": false},
        {"name": "status", "type": "string", "description": "Filter by case status.", "required": false},
        {"name": "priority", "type": "string", "description": "Filter by priority.", "required": false}
      ]
    },
    {
      "id": "get_case",
      "name": "Get Case",
      "description": "Retrieve details of a specific case by ID.",
      "http_method": "GET",
      "endpoint": "/../api/v2/cases/{case_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "case_id", "type": "integer", "description": "The case ID.", "required": true}
      ]
    },
    {
      "id": "create_case",
      "name": "Create Case",
      "description": "Create a new case for tracking incidents.",
      "http_method": "POST",
      "endpoint": "/../api/v2/cases",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "name", "type": "string", "description": "Name of the case.", "required": true},
        {"name": "description", "type": "string", "description": "Case description.", "required": false},
        {"name": "priority", "type": "string", "description": "Case priority level.", "required": false},
        {"name": "status", "type": "string", "description": "Initial case status.", "required": false},
        {"name": "team_id", "type": "integer", "description": "Team ID to assign the case to.", "required": false},
        {"name": "tags", "type": "array", "description": "Array of tag strings.", "required": false}
      ]
    },
    {
      "id": "list_case_actions",
      "name": "List Case Actions",
      "description": "Retrieve all actions associated with a case.",
      "http_method": "GET",
      "endpoint": "/../api/v2/cases/{case_id}/actions",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "case_id", "type": "integer", "description": "The case ID.", "required": true}
      ]
    },
    {
      "id": "list_case_activities",
      "name": "List Case Activities",
      "description": "Retrieve the activity timeline for a case.",
      "http_method": "GET",
      "endpoint": "/../api/v2/cases/{case_id}/activities",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "case_id", "type": "integer", "description": "The case ID.", "required": true},
        {"name": "type", "type": "string", "description": "Filter by activity type.", "required": false}
      ]
    },
    {
      "id": "list_resources",
      "name": "List Resources",
      "description": "Retrieve a list of global resources (shared variables/credentials).",
      "http_method": "GET",
      "endpoint": "/resources",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "page", "type": "integer", "description": "Page number.", "required": false},
        {"name": "per_page", "type": "integer", "description": "Results per page.", "required": false}
      ]
    }
  ]
}
