{
  "id": "microsoft_defender_office365",
  "name": "Microsoft Defender for Office 365",
  "description": "Cloud-based email filtering service protecting against advanced threats in email, links, and collaboration tools with Safe Links and Safe Attachments",
  "version": "1.0.0",
  "category": "email_security",
  "vendor": "Microsoft",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "header_name": "Authorization",
    "location": "header",
    "prefix": "Bearer",
    "token_url": "https://login.microsoftonline.com/{tenant_id}/oauth2/v2.0/token"
  },
  "base_url": "https://graph.microsoft.com/v1.0",
  "actions": [
    {
      "id": "get_threat_emails",
      "name": "Get Threat Emails",
      "description": "Retrieve emails containing threats detected by Defender for Office 365",
      "http_method": "GET",
      "endpoint": "/security/threatIntelligence/emailThreats",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "$filter",
          "type": "string",
          "description": "OData filter expression for querying threats",
          "required": false
        },
        {
          "name": "$top",
          "type": "number",
          "description": "Maximum number of results to return",
          "required": false,
          "default": 50
        },
        {
          "name": "$skip",
          "type": "number",
          "description": "Number of results to skip for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "get_email_details",
      "name": "Get Email Threat Details",
      "description": "Retrieve detailed threat information for a specific email including Safe Links/Attachments verdicts",
      "http_method": "GET",
      "endpoint": "/security/threatIntelligence/emailThreats/{email_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "email_id",
          "type": "string",
          "description": "The email threat ID",
          "required": true
        }
      ]
    },
    {
      "id": "list_quarantine_messages",
      "name": "List Quarantine Messages",
      "description": "List messages in quarantine with filtering options",
      "http_method": "GET",
      "endpoint": "/security/threatManagement/quarantine/messages",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "$filter",
          "type": "string",
          "description": "OData filter expression",
          "required": false
        },
        {
          "name": "$top",
          "type": "number",
          "description": "Maximum number of results to return",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "release_quarantine_message",
      "name": "Release Quarantine Message",
      "description": "Release a message from quarantine back to the recipient's inbox",
      "http_method": "POST",
      "endpoint": "/security/threatManagement/quarantine/messages/{message_id}/release",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "message_id",
          "type": "string",
          "description": "The quarantine message ID to release",
          "required": true
        }
      ]
    },
    {
      "id": "soft_delete_email",
      "name": "Soft Delete Email",
      "description": "Soft delete an email message from user mailboxes",
      "http_method": "POST",
      "endpoint": "/security/threatManagement/emailRemediation",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "networkMessageIds",
          "type": "array",
          "description": "Array of network message IDs to soft delete",
          "required": true
        },
        {
          "name": "action",
          "type": "string",
          "description": "Remediation action (softDelete, hardDelete, moveToInbox, moveToDeletedItems)",
          "required": true,
          "default": "softDelete"
        }
      ]
    },
    {
      "id": "get_safe_links_report",
      "name": "Get Safe Links Report",
      "description": "Retrieve Safe Links URL click tracking and verdict reports",
      "http_method": "GET",
      "endpoint": "/reports/security/getSafeLinksDetailReport",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        }
      ]
    },
    {
      "id": "get_safe_attachments_report",
      "name": "Get Safe Attachments Report",
      "description": "Retrieve Safe Attachments detonation and verdict reports",
      "http_method": "GET",
      "endpoint": "/reports/security/getSafeAttachmentsDetailReport",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        }
      ]
    },
    {
      "id": "submit_threat_report",
      "name": "Submit Threat Report",
      "description": "Submit a user-reported phishing email for analysis",
      "http_method": "POST",
      "endpoint": "/security/threatSubmission/emailThreats",
      "action_type": "investigate",
      "read_only": false,
      "parameters": [
        {
          "name": "category",
          "type": "string",
          "description": "Submission category (spam, phish, malware, notJunk)",
          "required": true
        },
        {
          "name": "recipientEmailAddress",
          "type": "string",
          "description": "Email address of the recipient",
          "required": true
        },
        {
          "name": "messageUrl",
          "type": "string",
          "description": "URL of the email message",
          "required": true
        }
      ]
    }
  ]
}