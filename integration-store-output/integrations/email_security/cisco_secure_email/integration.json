{
  "id": "cisco_secure_email",
  "name": "Cisco Secure Email",
  "description": "Enterprise email security gateway (AsyncOS) providing anti-spam, anti-malware, DLP, and advanced threat protection with message tracking and quarantine APIs",
  "version": "1.0.0",
  "category": "email_security",
  "vendor": "Cisco",
  "auth_type": "basic",
  "auth_config": {
    "type": "basic",
    "location": "header"
  },
  "base_url": "https://{host}/esa/api/v2.0",
  "actions": [
    {
      "id": "search_messages",
      "name": "Search Messages",
      "description": "Search for messages matching specified tracking criteria",
      "http_method": "GET",
      "endpoint": "/message-tracking/messages",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": true
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": true
        },
        {
          "name": "searchOption",
          "type": "string",
          "description": "Search option (messages, rejectedConnections)",
          "required": false,
          "default": "messages"
        },
        {
          "name": "envelopeSenderfilterOperator",
          "type": "string",
          "description": "Operator for sender filter (contains, is, begins_with)",
          "required": false
        },
        {
          "name": "envelopeSenderfilterValue",
          "type": "string",
          "description": "Sender email address to filter",
          "required": false
        },
        {
          "name": "envelopeRecipientfilterOperator",
          "type": "string",
          "description": "Operator for recipient filter",
          "required": false
        },
        {
          "name": "envelopeRecipientfilterValue",
          "type": "string",
          "description": "Recipient email address to filter",
          "required": false
        },
        {
          "name": "subjectfilterOperator",
          "type": "string",
          "description": "Operator for subject filter",
          "required": false
        },
        {
          "name": "subjectfilterValue",
          "type": "string",
          "description": "Subject string to filter",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum results to return",
          "required": false,
          "default": 100
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "get_message_details",
      "name": "Get Message Details",
      "description": "Retrieve detailed tracking information for a specific message",
      "http_method": "GET",
      "endpoint": "/message-tracking/details",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "mid",
          "type": "number",
          "description": "Message ID",
          "required": true
        },
        {
          "name": "icid",
          "type": "number",
          "description": "Injection Connection ID",
          "required": false
        }
      ]
    },
    {
      "id": "search_quarantine",
      "name": "Search Quarantine",
      "description": "Search messages in the spam quarantine",
      "http_method": "GET",
      "endpoint": "/quarantine/messages",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": true
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": true
        },
        {
          "name": "quarantineType",
          "type": "string",
          "description": "Quarantine type (spam, policy, virus, outbreak)",
          "required": false,
          "default": "spam"
        },
        {
          "name": "envelopeRecipientFilterValue",
          "type": "string",
          "description": "Recipient email filter",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum results to return",
          "required": false,
          "default": 100
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "release_quarantine_message",
      "name": "Release Quarantine Message",
      "description": "Release a message from quarantine for delivery",
      "http_method": "POST",
      "endpoint": "/quarantine/messages",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "mids",
          "type": "array",
          "description": "Array of message IDs to release",
          "required": true
        },
        {
          "name": "action",
          "type": "string",
          "description": "Action to perform (release, delete)",
          "required": true,
          "default": "release"
        }
      ]
    },
    {
      "id": "delete_quarantine_message",
      "name": "Delete Quarantine Message",
      "description": "Delete a message from quarantine",
      "http_method": "DELETE",
      "endpoint": "/quarantine/messages",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "mids",
          "type": "array",
          "description": "Array of message IDs to delete",
          "required": true
        }
      ]
    },
    {
      "id": "get_reporting_mail_summary",
      "name": "Get Mail Summary Report",
      "description": "Retrieve email traffic summary statistics",
      "http_method": "GET",
      "endpoint": "/reporting/mail_incoming_traffic_summary",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": true
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": true
        }
      ]
    },
    {
      "id": "add_blocklist_entry",
      "name": "Add Blocklist Entry",
      "description": "Add a sender to the blocklist",
      "http_method": "POST",
      "endpoint": "/config/blocklist",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "senderAddress",
          "type": "string",
          "description": "Sender email address or domain to block",
          "required": true
        },
        {
          "name": "action",
          "type": "string",
          "description": "Action to apply (reject, quarantine)",
          "required": true,
          "default": "reject"
        }
      ]
    }
  ]
}