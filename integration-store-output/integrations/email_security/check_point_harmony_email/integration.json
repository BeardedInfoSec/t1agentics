{
  "id": "check_point_harmony_email",
  "name": "Check Point Harmony Email & Collaboration",
  "description": "API-based email and collaboration security protecting Microsoft 365 and Google Workspace against phishing, BEC, malware, and data leaks",
  "version": "1.0.0",
  "category": "email_security",
  "vendor": "Check Point",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "header_name": "Authorization",
    "location": "header",
    "prefix": "Bearer",
    "token_url": "https://cloudinfra-gw.portal.checkpoint.com/auth/external"
  },
  "base_url": "https://cloudinfra-gw.portal.checkpoint.com/app/hec-api/v1.0",
  "actions": [
    {
      "id": "get_security_events",
      "name": "Get Security Events",
      "description": "Retrieve security events from Harmony Email & Collaboration",
      "http_method": "GET",
      "endpoint": "/event/query",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        },
        {
          "name": "saas",
          "type": "string",
          "description": "SaaS application filter (office365_emails, gmail)",
          "required": false
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity (critical, high, medium, low)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of events to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_event_details",
      "name": "Get Event Details",
      "description": "Retrieve detailed information about a specific security event",
      "http_method": "GET",
      "endpoint": "/event/{event_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "event_id",
          "type": "string",
          "description": "The event ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_quarantine",
      "name": "Get Quarantine",
      "description": "Retrieve emails and files in quarantine",
      "http_method": "GET",
      "endpoint": "/quarantine/query",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of items to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "restore_quarantine_item",
      "name": "Restore Quarantine Item",
      "description": "Restore a quarantined email or file to the user",
      "http_method": "POST",
      "endpoint": "/quarantine/{item_id}/restore",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "item_id",
          "type": "string",
          "description": "The quarantine item ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_email_info",
      "name": "Get Email Info",
      "description": "Retrieve detailed analysis information about a specific email",
      "http_method": "GET",
      "endpoint": "/email/{email_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "email_id",
          "type": "string",
          "description": "The email ID",
          "required": true
        }
      ]
    },
    {
      "id": "quarantine_email",
      "name": "Quarantine Email",
      "description": "Quarantine a specific email to prevent access",
      "http_method": "POST",
      "endpoint": "/email/{email_id}/quarantine",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "email_id",
          "type": "string",
          "description": "The email ID to quarantine",
          "required": true
        }
      ]
    },
    {
      "id": "get_exceptions",
      "name": "Get Exceptions",
      "description": "Retrieve configured exception rules and allow lists",
      "http_method": "GET",
      "endpoint": "/exception/query",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "add_exception",
      "name": "Add Exception",
      "description": "Add an exception rule to allow or block specific senders or domains",
      "http_method": "POST",
      "endpoint": "/exception",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "type",
          "type": "string",
          "description": "Exception type (sender, domain)",
          "required": true
        },
        {
          "name": "value",
          "type": "string",
          "description": "The sender address or domain",
          "required": true
        },
        {
          "name": "action",
          "type": "string",
          "description": "Action (allow, block)",
          "required": true
        }
      ]
    }
  ]
}