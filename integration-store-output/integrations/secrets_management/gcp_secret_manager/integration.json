{
  "id": "gcp_secret_manager",
  "name": "Google Cloud Secret Manager",
  "description": "Cloud secrets management through Google Cloud Secret Manager REST API for storing, managing, and accessing secrets and secret versions",
  "version": "1.0.0",
  "category": "secrets_management",
  "vendor": "Google Cloud",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "token_url": "https://oauth2.googleapis.com/token",
    "scope": "https://www.googleapis.com/auth/cloud-platform"
  },
  "base_url": "https://secretmanager.googleapis.com/v1",
  "actions": [
    {
      "id": "list_secrets",
      "name": "List Secrets",
      "description": "List all secrets in a Google Cloud project",
      "http_method": "GET",
      "endpoint": "/projects/{projectId}/secrets",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "projectId",
          "type": "string",
          "description": "Google Cloud project ID",
          "required": true
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Maximum number of results per page",
          "required": false
        },
        {
          "name": "pageToken",
          "type": "string",
          "description": "Pagination token from a previous request",
          "required": false
        },
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression for secrets",
          "required": false
        }
      ]
    },
    {
      "id": "get_secret",
      "name": "Get Secret",
      "description": "Retrieve metadata about a specific secret (not the secret value)",
      "http_method": "GET",
      "endpoint": "/projects/{projectId}/secrets/{secretId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "projectId",
          "type": "string",
          "description": "Google Cloud project ID",
          "required": true
        },
        {
          "name": "secretId",
          "type": "string",
          "description": "Secret ID",
          "required": true
        }
      ]
    },
    {
      "id": "access_secret_version",
      "name": "Access Secret Version",
      "description": "Access the payload (value) of a specific secret version",
      "http_method": "GET",
      "endpoint": "/projects/{projectId}/secrets/{secretId}/versions/{versionId}:access",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "projectId",
          "type": "string",
          "description": "Google Cloud project ID",
          "required": true
        },
        {
          "name": "secretId",
          "type": "string",
          "description": "Secret ID",
          "required": true
        },
        {
          "name": "versionId",
          "type": "string",
          "description": "Version number or 'latest'",
          "required": true,
          "default": "latest"
        }
      ]
    },
    {
      "id": "create_secret",
      "name": "Create Secret",
      "description": "Create a new secret in the project",
      "http_method": "POST",
      "endpoint": "/projects/{projectId}/secrets",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "projectId",
          "type": "string",
          "description": "Google Cloud project ID",
          "required": true
        },
        {
          "name": "secretId",
          "type": "string",
          "description": "ID for the new secret",
          "required": true
        },
        {
          "name": "replication",
          "type": "object",
          "description": "Replication policy (automatic or user_managed)",
          "required": false
        }
      ]
    },
    {
      "id": "add_secret_version",
      "name": "Add Secret Version",
      "description": "Add a new version with secret data to an existing secret",
      "http_method": "POST",
      "endpoint": "/projects/{projectId}/secrets/{secretId}:addVersion",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "projectId",
          "type": "string",
          "description": "Google Cloud project ID",
          "required": true
        },
        {
          "name": "secretId",
          "type": "string",
          "description": "Secret ID",
          "required": true
        },
        {
          "name": "payload",
          "type": "object",
          "description": "Secret payload data (base64-encoded)",
          "required": true
        }
      ]
    },
    {
      "id": "disable_secret_version",
      "name": "Disable Secret Version",
      "description": "Disable a secret version to prevent access",
      "http_method": "POST",
      "endpoint": "/projects/{projectId}/secrets/{secretId}/versions/{versionId}:disable",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "projectId",
          "type": "string",
          "description": "Google Cloud project ID",
          "required": true
        },
        {
          "name": "secretId",
          "type": "string",
          "description": "Secret ID",
          "required": true
        },
        {
          "name": "versionId",
          "type": "string",
          "description": "Version number to disable",
          "required": true
        }
      ]
    },
    {
      "id": "enable_secret_version",
      "name": "Enable Secret Version",
      "description": "Re-enable a previously disabled secret version",
      "http_method": "POST",
      "endpoint": "/projects/{projectId}/secrets/{secretId}/versions/{versionId}:enable",
      "action_type": "correct",
      "read_only": false,
      "parameters": [
        {
          "name": "projectId",
          "type": "string",
          "description": "Google Cloud project ID",
          "required": true
        },
        {
          "name": "secretId",
          "type": "string",
          "description": "Secret ID",
          "required": true
        },
        {
          "name": "versionId",
          "type": "string",
          "description": "Version number to enable",
          "required": true
        }
      ]
    },
    {
      "id": "destroy_secret_version",
      "name": "Destroy Secret Version",
      "description": "Permanently destroy a secret version (cannot be recovered)",
      "http_method": "POST",
      "endpoint": "/projects/{projectId}/secrets/{secretId}/versions/{versionId}:destroy",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "projectId",
          "type": "string",
          "description": "Google Cloud project ID",
          "required": true
        },
        {
          "name": "secretId",
          "type": "string",
          "description": "Secret ID",
          "required": true
        },
        {
          "name": "versionId",
          "type": "string",
          "description": "Version number to destroy",
          "required": true
        }
      ]
    },
    {
      "id": "list_secret_versions",
      "name": "List Secret Versions",
      "description": "List all versions of a specific secret",
      "http_method": "GET",
      "endpoint": "/projects/{projectId}/secrets/{secretId}/versions",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "projectId",
          "type": "string",
          "description": "Google Cloud project ID",
          "required": true
        },
        {
          "name": "secretId",
          "type": "string",
          "description": "Secret ID",
          "required": true
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Maximum number of results",
          "required": false
        }
      ]
    },
    {
      "id": "delete_secret",
      "name": "Delete Secret",
      "description": "Delete a secret and all its versions",
      "http_method": "DELETE",
      "endpoint": "/projects/{projectId}/secrets/{secretId}",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "projectId",
          "type": "string",
          "description": "Google Cloud project ID",
          "required": true
        },
        {
          "name": "secretId",
          "type": "string",
          "description": "Secret ID to delete",
          "required": true
        }
      ]
    }
  ]
}