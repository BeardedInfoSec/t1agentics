{
  "id": "sentinelone",
  "name": "SentinelOne",
  "description": "Integration with SentinelOne for security operations",
  "version": "1.0.0",
  "category": "edr",
  "vendor": "SentinelOne",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "",
  "actions": [
    {
      "id": "get_threats",
      "name": "Get Threats",
      "http_method": "GET",
      "endpoint": "/web/api/v2.1/threats",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Query threats detected by SentinelOne"
    },
    {
      "id": "get_agents",
      "name": "Get Agents",
      "http_method": "GET",
      "endpoint": "/web/api/v2.1/agents",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Query endpoint agents"
    },
    {
      "id": "disconnect_agent",
      "name": "Disconnect Agent",
      "http_method": "POST",
      "endpoint": "/web/api/v2.1/agents/actions/disconnect",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Network disconnect an endpoint"
    }
  ]
}