{
  "id": "windows_remote_management",
  "name": "Windows Remote Management",
  "description": "This app integrates with the Windows Remote Management service to execute various actions",
  "version": "2.3.3",
  "category": "edr",
  "vendor": "Microsoft",
  "auth_type": "basic_auth",
  "auth_config": {
    "type": "basic_auth",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "",
  "actions": [
    {
      "id": "run_command",
      "name": "Run Command",
      "description": "Execute a command on the endpoint",
      "http_method": "GET",
      "endpoint": "/actions/run_command",
      "action_type": "generic",
      "read_only": false,
      "cacheable": false,
      "cache_ttl_days": 0,
      "parameters": [
        {
          "name": "command",
          "type": "string",
          "description": "The command to be run",
          "required": false
        },
        {
          "name": "arguments",
          "type": "string",
          "description": "The arguments for the command",
          "required": false
        },
        {
          "name": "parser",
          "type": "string",
          "description": "The vault ID of a custom parser to use for output",
          "required": false,
          "contains": [
            "vault id"
          ]
        },
        {
          "name": "ip_hostname",
          "type": "string",
          "description": "IP/Hostname",
          "required": false,
          "contains": [
            "ip",
            "host name"
          ]
        },
        {
          "name": "async",
          "type": "boolean",
          "description": "Start the command, but don't wait for output",
          "required": false,
          "default": false
        },
        {
          "name": "command_id",
          "type": "string",
          "description": "Command ID of async command (Provide with shell_id)",
          "required": false,
          "contains": [
            "winrm command id"
          ]
        },
        {
          "name": "shell_id",
          "type": "string",
          "description": "Shell ID of async command (Provide with command_id)",
          "required": false,
          "contains": [
            "winrm shell id"
          ]
        }
      ]
    },
    {
      "id": "run_script",
      "name": "Run Script",
      "description": "Run a PowerShell script on the endpoint",
      "http_method": "GET",
      "endpoint": "/actions/run_script",
      "action_type": "generic",
      "read_only": false,
      "cacheable": false,
      "cache_ttl_days": 0,
      "parameters": [
        {
          "name": "script_file",
          "type": "string",
          "description": "The vault ID of a PowerShell script to run",
          "required": false,
          "contains": [
            "vault id"
          ]
        },
        {
          "name": "script_str",
          "type": "string",
          "description": "A PowerShell script to run",
          "required": false
        },
        {
          "name": "parser",
          "type": "string",
          "description": "The vault ID of a custom parser to use for output",
          "required": false,
          "contains": [
            "vault id"
          ]
        },
        {
          "name": "ip_hostname",
          "type": "string",
          "description": "IP/Hostname",
          "required": false,
          "contains": [
            "ip",
            "host name"
          ]
        },
        {
          "name": "async",
          "type": "boolean",
          "description": "Start the command, but don't wait for output",
          "required": false,
          "default": false
        },
        {
          "name": "command_id",
          "type": "string",
          "description": "Command ID of async command (Provide with shell_id)",
