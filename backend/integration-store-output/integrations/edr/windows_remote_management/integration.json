        },
        {
          "name": "other",
          "type": "string",
          "description": "JSON object of key value pairs of other fields to match",
          "required": false
        },
        {
          "name": "ip_hostname",
          "type": "string",
          "description": "IP/Hostname",
          "required": false,
          "contains": [
            "ip",
            "host name"
          ]
        }
      ]
