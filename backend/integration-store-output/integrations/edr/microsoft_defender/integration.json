{
  "id": "microsoft_defender",
  "name": "Microsoft Defender",
  "description": "Integration with Microsoft Defender for security operations",
  "version": "1.0.0",
  "category": "edr",
  "vendor": "Microsoft",
  "auth_type": "oauth2",
  "auth_config": {
    "type": "oauth2",
    "client_id": "",
    "client_secret": "",
    "tenant_id": "",
    "token_url": "https://login.microsoftonline.com/{tenant_id}/oauth2/v2.0/token"
  },
  "base_url": "https://api.securitycenter.microsoft.com/api",
  "actions": [
    {
      "id": "list_alerts",
      "name": "List Alerts",
      "http_method": "GET",
      "endpoint": "/alerts",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Get security alerts from Defender"
    },
    {
      "id": "get_machine",
      "name": "Get Machine Info",
      "http_method": "GET",
      "endpoint": "/machines/{machine_id}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Get information about a machine"
    },
    {
      "id": "isolate_machine",
      "name": "Isolate Machine",
      "http_method": "POST",
      "endpoint": "/machines/{machine_id}/isolate",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Isolate a machine from the network"
    }
  ]
}