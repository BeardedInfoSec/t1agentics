{
  "id": "crowdstrike",
  "name": "CrowdStrike Falcon",
  "description": "Integration with CrowdStrike Falcon for security operations",
  "version": "1.0.0",
  "category": "edr",
  "vendor": "CrowdStrike",
  "auth_type": "oauth2",
  "auth_config": {
    "type": "oauth2",
    "client_id": "",
    "client_secret": "",
    "token_url": "https://api.crowdstrike.com/oauth2/token"
  },
  "base_url": "https://api.crowdstrike.com",
  "actions": [
    {
      "id": "search_detections",
      "name": "Search Detections",
      "http_method": "GET",
      "endpoint": "/detects/queries/detects/v1",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Search for detections by various criteria"
    },
    {
      "id": "get_host_info",
      "name": "Get Host Info",
      "http_method": "GET",
      "endpoint": "/devices/entities/devices/v2",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Get detailed information about a host"
    },
    {
      "id": "contain_host",
      "name": "Contain Host",
      "http_method": "POST",
      "endpoint": "/devices/entities/devices-actions/v2",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Network contain a compromised host"
    }
  ]
}