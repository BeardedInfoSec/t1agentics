{
  "id": "slack",
  "name": "Slack",
  "description": "Integration with Slack for security operations",
  "version": "1.0.0",
  "category": "communication",
  "vendor": "Slack",
  "auth_type": "bearer_token",
  "auth_config": {
    "type": "bearer_token",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://slack.com/api",
  "actions": [
    {
      "id": "post_message",
      "name": "Post Message",
      "http_method": "POST",
      "endpoint": "/chat.postMessage",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Post a message to a Slack channel"
    },
    {
      "id": "post_alert",
      "name": "Post Alert Notification",
      "http_method": "POST",
      "endpoint": "/chat.postMessage",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Post a formatted alert notification",
      "observable_type": "alert"
    }
  ]
}