{
  "id": "rocket_chat",
  "name": "Rocket.Chat",
  "description": "Integrates with Rocket.Chat REST API v1 for team messaging, channel management, and collaboration",
  "version": "1.0.0",
  "category": "communication",
  "vendor": "Rocket.Chat",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "X-Auth-Token",
    "location": "header"
  },
  "base_url": "https://{host}/api/v1",
  "actions": [
    {
      "id": "send_message",
      "name": "Send Message",
      "description": "Send a message to a Rocket.Chat channel or direct message",
      "http_method": "POST",
      "endpoint": "/chat.sendMessage",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "rid", "type": "string", "description": "Room/channel ID to send the message to", "required": true},
        {"name": "msg", "type": "string", "description": "Message text content", "required": true},
        {"name": "alias", "type": "string", "description": "Override display name for the message", "required": false},
        {"name": "emoji", "type": "string", "description": "Override avatar with an emoji", "required": false},
        {"name": "tmid", "type": "string", "description": "Thread message ID for threaded replies", "required": false}
      ]
    },
    {
      "id": "list_channels",
      "name": "List Channels",
      "description": "List all public channels on the Rocket.Chat server",
      "http_method": "GET",
      "endpoint": "/channels.list",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "count", "type": "number", "description": "Number of results per page", "required": false, "default": 50},
        {"name": "offset", "type": "number", "description": "Pagination offset", "required": false, "default": 0},
        {"name": "sort", "type": "string", "description": "JSON sort object (e.g. {\"name\":1})", "required": false},
        {"name": "query", "type": "string", "description": "JSON query filter", "required": false}
      ]
    },
    {
      "id": "get_messages",
      "name": "Get Channel Messages",
      "description": "Retrieve messages from a Rocket.Chat channel",
      "http_method": "GET",
      "endpoint": "/channels.messages",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "roomId", "type": "string", "description": "Channel/room ID", "required": true},
        {"name": "count", "type": "number", "description": "Number of messages to return", "required": false, "default": 20},
        {"name": "offset", "type": "number", "description": "Pagination offset", "required": false, "default": 0},
        {"name": "sort", "type": "string", "description": "Sort order JSON (e.g. {\"ts\":-1})", "required": false}
      ]
    },
    {
      "id": "create_channel",
      "name": "Create Channel",
      "description": "Create a new Rocket.Chat public channel",
      "http_method": "POST",
      "endpoint": "/channels.create",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "name", "type": "string", "description": "Channel name (regex: [0-9a-zA-Z-_.])", "required": true},
        {"name": "members", "type": "string", "description": "JSON array of usernames to add", "required": false},
        {"name": "readOnly", "type": "boolean", "description": "Make channel read-only", "required": false, "default": false}
      ]
    },
    {
      "id": "post_message",
      "name": "Post Message",
      "description": "Post a message to one or more channels with advanced formatting",
      "http_method": "POST",
      "endpoint": "/chat.postMessage",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "channel", "type": "string", "description": "Channel name or ID (supports comma-separated for multi-channel)", "required": true},
        {"name": "text", "type": "string", "description": "Message text", "required": true},
        {"name": "alias", "type": "string", "description": "Override display name", "required": false},
        {"name": "emoji", "type": "string", "description": "Override avatar with emoji", "required": false},
        {"name": "attachments", "type": "string", "description": "JSON array of attachment objects", "required": false}
      ]
    },
    {
      "id": "get_channel_info",
      "name": "Get Channel Info",
      "description": "Get detailed information about a Rocket.Chat channel",
      "http_method": "GET",
      "endpoint": "/channels.info",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "roomId", "type": "string", "description": "Channel/room ID", "required": false},
        {"name": "roomName", "type": "string", "description": "Channel name", "required": false}
      ]
    }
  ]
}
