{
  "id": "pagerduty",
  "name": "PagerDuty",
  "description": "Integration with PagerDuty for security operations",
  "version": "1.0.0",
  "category": "communication",
  "vendor": "PagerDuty",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://api.pagerduty.com",
  "actions": [
    {
      "id": "create_incident",
      "name": "Create Incident",
      "http_method": "POST",
      "endpoint": "/incidents",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Create a new PagerDuty incident"
    },
    {
      "id": "trigger_event",
      "name": "Trigger Event",
      "http_method": "POST",
      "endpoint": "https://events.pagerduty.com/v2/enqueue",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Trigger an event via Events API v2"
    }
  ]
}