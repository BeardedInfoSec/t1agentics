{
  "id": "cloudflare_email",
  "name": "Cloudflare Email Security",
  "description": "Cloud-native email security (formerly Area 1) providing pre-emptive threat detection for phishing, BEC, and malware with comprehensive API for investigation and remediation",
  "version": "1.0.0",
  "category": "email_security",
  "vendor": "Cloudflare",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header",
    "prefix": "Bearer",
    "note": "Also supports X-Auth-Email and X-Auth-Key header pair"
  },
  "base_url": "https://api.cloudflare.com/client/v4",
  "actions": [
    {
      "id": "get_detections",
      "name": "Get Detections",
      "description": "Retrieve email threat detections with verdict and classification details",
      "http_method": "GET",
      "endpoint": "/accounts/{account_id}/email-security/investigate",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Cloudflare account ID",
          "required": true
        },
        {
          "name": "start",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "end",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        },
        {
          "name": "action_log",
          "type": "string",
          "description": "Filter by action (QUARANTINED, BLOCKED, DELIVERED)",
          "required": false
        },
        {
          "name": "final_disposition",
          "type": "string",
          "description": "Filter by final disposition (MALICIOUS, SUSPICIOUS, SPOOF, SPAM, BULK)",
          "required": false
        },
        {
          "name": "per_page",
          "type": "number",
          "description": "Results per page",
          "required": false,
          "default": 25
        },
        {
          "name": "page",
          "type": "number",
          "description": "Page number",
          "required": false,
          "default": 1
        }
      ]
    },
    {
      "id": "get_message_details",
      "name": "Get Message Details",
      "description": "Retrieve detailed information about a specific email message including detection results",
      "http_method": "GET",
      "endpoint": "/accounts/{account_id}/email-security/investigate/{postfix_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Cloudflare account ID",
          "required": true
        },
        {
          "name": "postfix_id",
          "type": "string",
          "description": "The postfix message ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_message_detection_details",
      "name": "Get Message Detection Details",
      "description": "Retrieve detection-specific details for a message",
      "http_method": "GET",
      "endpoint": "/accounts/{account_id}/email-security/investigate/{postfix_id}/detections",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Cloudflare account ID",
          "required": true
        },
        {
          "name": "postfix_id",
          "type": "string",
          "description": "The postfix message ID",
          "required": true
        }
      ]
    },
    {
      "id": "move_messages",
      "name": "Move Messages",
      "description": "Move multiple messages to a specified folder or quarantine",
      "http_method": "POST",
      "endpoint": "/accounts/{account_id}/email-security/investigate/move",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Cloudflare account ID",
          "required": true
        },
        {
          "name": "postfix_ids",
          "type": "array",
          "description": "Array of postfix message IDs to move",
          "required": true
        },
        {
          "name": "destination",
          "type": "string",
          "description": "Destination folder (quarantine, inbox, trash)",
          "required": true
        }
      ]
    },
    {
      "id": "release_quarantine",
      "name": "Release from Quarantine",
      "description": "Release messages from quarantine back to the inbox",
      "http_method": "POST",
      "endpoint": "/accounts/{account_id}/email-security/investigate/release",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Cloudflare account ID",
          "required": true
        },
        {
          "name": "postfix_ids",
          "type": "array",
          "description": "Array of postfix message IDs to release",
          "required": true
        }
      ]
    },
    {
      "id": "get_email_summary",
      "name": "Get Email Summary",
      "description": "Retrieve email security summary statistics",
      "http_method": "GET",
      "endpoint": "/accounts/{account_id}/email-security/summary",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Cloudflare account ID",
          "required": true
        },
        {
          "name": "start",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "end",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        }
      ]
    }
  ]
}