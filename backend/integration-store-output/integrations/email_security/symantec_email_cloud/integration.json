{
  "id": "symantec_email_cloud",
  "name": "Symantec Email Security.cloud",
  "description": "Cloud-based email security service providing anti-spam, anti-malware, DLP, and encryption with email quarantine management API",
  "version": "1.0.0",
  "category": "email_security",
  "vendor": "Broadcom",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "location": "header",
    "header_name": "Authorization",
    "prefix": "Bearer "
  },
  "base_url": "https://api.messagelabs.com/v1",
  "actions": [
    {
      "id": "get_quarantine_messages",
      "name": "Get Quarantine Messages",
      "description": "Retrieve quarantined email messages for authenticated user or domain",
      "http_method": "GET",
      "endpoint": "/quarantine/messages",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "domain",
          "type": "string",
          "description": "Domain to retrieve quarantined messages for",
          "required": false
        },
        {
          "name": "q",
          "type": "string",
          "description": "Search condition to filter quarantined messages",
          "required": false
        },
        {
          "name": "quarantineType",
          "type": "string",
          "description": "Filter by quarantine type (COMPLIANCE, DLP, SPAM, MALWARE)",
          "required": false
        },
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 50
        },
        {
          "name": "page",
          "type": "number",
          "description": "Page number",
          "required": false,
          "default": 1
        }
      ]
    },
    {
      "id": "get_quarantine_message_details",
      "name": "Get Quarantine Message Details",
      "description": "Retrieve detailed information about a specific quarantined message",
      "http_method": "GET",
      "endpoint": "/quarantine/messages/{message_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "message_id",
          "type": "string",
          "description": "The quarantine message ID",
          "required": true
        }
      ]
    },
    {
      "id": "release_quarantine_message",
      "name": "Release Quarantine Message",
      "description": "Release a quarantined message for delivery",
      "http_method": "POST",
      "endpoint": "/quarantine/messages/{message_id}/release",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "message_id",
          "type": "string",
          "description": "The quarantine message ID to release",
          "required": true
        }
      ]
    },
    {
      "id": "delete_quarantine_message",
      "name": "Delete Quarantine Message",
      "description": "Delete a message from quarantine",
      "http_method": "DELETE",
      "endpoint": "/quarantine/messages/{message_id}",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "message_id",
          "type": "string",
          "description": "The quarantine message ID to delete",
          "required": true
        }
      ]
    },
    {
      "id": "get_audit_log",
      "name": "Get Audit Log",
      "description": "Retrieve audit log for email quarantine actions",
      "http_method": "GET",
      "endpoint": "/quarantine/audit",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "q",
          "type": "string",
          "description": "Search condition for filtering audit data",
          "required": false
        },
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "get_data_feeds",
      "name": "Get Data Feeds",
      "description": "Retrieve threat data feeds including URL isolation and click-time protection events",
      "http_method": "GET",
      "endpoint": "/datafeeds/events",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        },
        {
          "name": "feedType",
          "type": "string",
          "description": "Feed type to retrieve (url_isolation, click_time)",
          "required": false
        }
      ]
    }
  ]
}