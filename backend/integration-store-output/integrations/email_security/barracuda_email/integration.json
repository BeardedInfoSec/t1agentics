{
  "id": "barracuda_email",
  "name": "Barracuda Email Security Gateway",
  "description": "Cloud-integrated email security gateway providing anti-spam, antivirus, encryption, and DLP with API-based configuration and quarantine management",
  "version": "1.0.0",
  "category": "email_security",
  "vendor": "Barracuda Networks",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header",
    "prefix": "Bearer"
  },
  "base_url": "https://{host}/cgi-mod/api.cgi",
  "actions": [
    {
      "id": "get_quarantine_messages",
      "name": "Get Quarantine Messages",
      "description": "Retrieve messages in the quarantine inbox",
      "http_method": "POST",
      "endpoint": "/",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "method",
          "type": "string",
          "description": "API method name",
          "required": true,
          "default": "quarantine.list"
        },
        {
          "name": "domain",
          "type": "string",
          "description": "Domain to filter quarantined messages",
          "required": false
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "Start date filter",
          "required": false
        },
        {
          "name": "end_date",
          "type": "string",
          "description": "End date filter",
          "required": false
        },
        {
          "name": "per_page",
          "type": "number",
          "description": "Results per page",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "release_quarantine_message",
      "name": "Release Quarantine Message",
      "description": "Release a message from quarantine for delivery to the recipient",
      "http_method": "POST",
      "endpoint": "/",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "method",
          "type": "string",
          "description": "API method name",
          "required": true,
          "default": "quarantine.release"
        },
        {
          "name": "msg_id",
          "type": "string",
          "description": "Message ID to release",
          "required": true
        }
      ]
    },
    {
      "id": "delete_quarantine_message",
      "name": "Delete Quarantine Message",
      "description": "Delete a message from quarantine",
      "http_method": "POST",
      "endpoint": "/",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "method",
          "type": "string",
          "description": "API method name",
          "required": true,
          "default": "quarantine.delete"
        },
        {
          "name": "msg_id",
          "type": "string",
          "description": "Message ID to delete",
          "required": true
        }
      ]
    },
    {
      "id": "get_block_list",
      "name": "Get Block List",
      "description": "Retrieve the current sender block list",
      "http_method": "POST",
      "endpoint": "/",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "method",
          "type": "string",
          "description": "API method name",
          "required": true,
          "default": "config.get"
        },
        {
          "name": "variable",
          "type": "string",
          "description": "Configuration variable to retrieve",
          "required": true,
          "default": "block_list"
        }
      ]
    },
    {
      "id": "add_block_entry",
      "name": "Add Block Entry",
      "description": "Add an email address or domain to the sender block list",
      "http_method": "POST",
      "endpoint": "/",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "method",
          "type": "string",
          "description": "API method name",
          "required": true,
          "default": "config.set"
        },
        {
          "name": "variable",
          "type": "string",
          "description": "Configuration variable to set",
          "required": true,
          "default": "block_list"
        },
        {
          "name": "value",
          "type": "string",
          "description": "Email address or domain to block",
          "required": true
        }
      ]
    },
    {
      "id": "get_allow_list",
      "name": "Get Allow List",
      "description": "Retrieve the current sender allow list",
      "http_method": "POST",
      "endpoint": "/",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "method",
          "type": "string",
          "description": "API method name",
          "required": true,
          "default": "config.get"
        },
        {
          "name": "variable",
          "type": "string",
          "description": "Configuration variable to retrieve",
          "required": true,
          "default": "allow_list"
        }
      ]
    },
    {
      "id": "get_spam_score",
      "name": "Get Spam Score Settings",
      "description": "Retrieve current spam scoring and blocking thresholds",
      "http_method": "POST",
      "endpoint": "/",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "method",
          "type": "string",
          "description": "API method name",
          "required": true,
          "default": "config.get"
        },
        {
          "name": "variable",
          "type": "string",
          "description": "Configuration variable",
          "required": true,
          "default": "scana_block_level"
        }
      ]
    }
  ]
}