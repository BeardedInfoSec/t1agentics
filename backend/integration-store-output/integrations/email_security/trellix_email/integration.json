{
  "id": "trellix_email",
  "name": "Trellix Email Security",
  "description": "Cloud-based email threat protection providing advanced threat detection, URL analysis, and attachment sandboxing with email trace and quarantine APIs",
  "version": "1.0.0",
  "category": "email_security",
  "vendor": "Trellix",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "x-fireeye-api-key",
    "location": "header"
  },
  "base_url": "https://{region}.api.manage.trellix.com/etp/v2",
  "actions": [
    {
      "id": "get_alerts",
      "name": "Get Alerts",
      "description": "Retrieve advanced threat alerts from email security analysis",
      "http_method": "GET",
      "endpoint": "/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "from_date",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "to_date",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        },
        {
          "name": "size",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 20
        }
      ]
    },
    {
      "id": "get_alert_details",
      "name": "Get Alert Details",
      "description": "Retrieve detailed information about a specific alert including ATI intelligence",
      "http_method": "GET",
      "endpoint": "/alerts/{alert_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "The alert ID",
          "required": true
        }
      ]
    },
    {
      "id": "trace_emails",
      "name": "Trace Emails",
      "description": "Search and trace email messages through the system",
      "http_method": "GET",
      "endpoint": "/trace",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "from_date",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "to_date",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        },
        {
          "name": "sender",
          "type": "string",
          "description": "Filter by sender email address",
          "required": false
        },
        {
          "name": "recipient",
          "type": "string",
          "description": "Filter by recipient email address",
          "required": false
        },
        {
          "name": "subject",
          "type": "string",
          "description": "Filter by email subject",
          "required": false
        },
        {
          "name": "status",
          "type": "string",
          "description": "Filter by delivery status (delivered, dropped, quarantined)",
          "required": false
        },
        {
          "name": "size",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 20
        }
      ]
    },
    {
      "id": "get_quarantine",
      "name": "Get Quarantine",
      "description": "Retrieve quarantined email messages",
      "http_method": "GET",
      "endpoint": "/quarantine",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "from_date",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "to_date",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        },
        {
          "name": "size",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 20
        }
      ]
    },
    {
      "id": "release_quarantine_message",
      "name": "Release Quarantine Message",
      "description": "Release an email from quarantine for delivery",
      "http_method": "POST",
      "endpoint": "/quarantine/{message_id}/release",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "message_id",
          "type": "string",
          "description": "The cloud message ID of the quarantined email",
          "required": true
        }
      ]
    },
    {
      "id": "delete_quarantine_message",
      "name": "Delete Quarantine Message",
      "description": "Delete an email from quarantine",
      "http_method": "DELETE",
      "endpoint": "/quarantine/{message_id}",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "message_id",
          "type": "string",
          "description": "The cloud message ID to delete",
          "required": true
        }
      ]
    }
  ]
}