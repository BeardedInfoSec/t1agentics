{
  "id": "ironscales",
  "name": "IRONSCALES",
  "description": "AI-powered email security platform combining automated phishing detection, remediation, and security awareness training with REST API for incident management",
  "version": "1.0.0",
  "category": "email_security",
  "vendor": "IRONSCALES",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "location": "header",
    "header_name": "Authorization",
    "prefix": "Bearer "
  },
  "base_url": "https://appapi.ironscales.com/api",
  "actions": [
    {
      "id": "get_incidents",
      "name": "Get Incidents",
      "description": "Retrieve email security incidents from IRONSCALES",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "company_id",
          "type": "string",
          "description": "Company ID",
          "required": true
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "Start date for incident retrieval in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_date",
          "type": "string",
          "description": "End date for incident retrieval in ISO 8601 format",
          "required": false
        },
        {
          "name": "classification",
          "type": "string",
          "description": "Filter by classification (phishing, spam, suspicious, clean)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of incidents (max 1000)",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_incident_details",
      "name": "Get Incident Details",
      "description": "Retrieve detailed information about a specific incident",
      "http_method": "GET",
      "endpoint": "/incidents/{incident_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "incident_id",
          "type": "string",
          "description": "The incident ID",
          "required": true
        },
        {
          "name": "company_id",
          "type": "string",
          "description": "Company ID",
          "required": true
        }
      ]
    },
    {
      "id": "classify_incident",
      "name": "Classify Incident",
      "description": "Update the classification of an incident",
      "http_method": "POST",
      "endpoint": "/incidents/{incident_id}/classify",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "incident_id",
          "type": "string",
          "description": "The incident ID",
          "required": true
        },
        {
          "name": "company_id",
          "type": "string",
          "description": "Company ID",
          "required": true
        },
        {
          "name": "classification",
          "type": "string",
          "description": "New classification (phishing, spam, suspicious, clean, attack_simulation)",
          "required": true
        }
      ]
    },
    {
      "id": "remediate_incident",
      "name": "Remediate Incident",
      "description": "Remediate an incident by removing malicious emails from mailboxes",
      "http_method": "POST",
      "endpoint": "/incidents/{incident_id}/remediate",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "incident_id",
          "type": "string",
          "description": "The incident ID",
          "required": true
        },
        {
          "name": "company_id",
          "type": "string",
          "description": "Company ID",
          "required": true
        },
        {
          "name": "action",
          "type": "string",
          "description": "Remediation action (delete, quarantine)",
          "required": true,
          "default": "delete"
        }
      ]
    },
    {
      "id": "get_reported_emails",
      "name": "Get Reported Emails",
      "description": "Retrieve emails reported by users through the phishing report button",
      "http_method": "GET",
      "endpoint": "/reported-emails",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "company_id",
          "type": "string",
          "description": "Company ID",
          "required": true
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_date",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of results",
          "required": false,
          "default": 100
        }
      ]
    }
  ]
}