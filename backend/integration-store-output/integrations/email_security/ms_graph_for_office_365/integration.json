          "description": "Sender email address to match",
          "required": false,
          "contains": [
            "email"
          ]
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum emails to return",
          "required": false
        },
        {
          "name": "query",
          "type": "string",
