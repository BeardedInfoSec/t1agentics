{
  "id": "perception_point",
  "name": "Perception Point",
  "description": "Advanced email and collaboration security platform using Hardware-Assisted Platform (HAP) and multiple detection engines for real-time threat prevention",
  "version": "1.0.0",
  "category": "email_security",
  "vendor": "Perception Point",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "location": "header",
    "header_name": "Authorization",
    "prefix": "Token "
  },
  "base_url": "https://api.perception-point.io/api/v1",
  "actions": [
    {
      "id": "scan_file",
      "name": "Scan File",
      "description": "Submit a file for scanning and threat analysis",
      "http_method": "POST",
      "endpoint": "/scans/files",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "file",
          "type": "string",
          "description": "Base64-encoded file content to scan",
          "required": true
        },
        {
          "name": "filename",
          "type": "string",
          "description": "Name of the file being scanned",
          "required": true
        }
      ]
    },
    {
      "id": "scan_url",
      "name": "Scan URL",
      "description": "Submit a URL for scanning and phishing/malware analysis",
      "http_method": "POST",
      "endpoint": "/scans/urls",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "url",
          "type": "string",
          "description": "URL to scan",
          "required": true
        }
      ]
    },
    {
      "id": "get_scan_result",
      "name": "Get Scan Result",
      "description": "Retrieve the scan result and verdict for a submitted file or URL",
      "http_method": "GET",
      "endpoint": "/scans/{scan_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "scan_id",
          "type": "string",
          "description": "The scan ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_quarantine",
      "name": "Get Quarantine",
      "description": "Retrieve quarantined emails and their scan verdicts",
      "http_method": "GET",
      "endpoint": "/quarantine",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "from",
          "type": "string",
          "description": "Start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "to",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        },
        {
          "name": "verdict",
          "type": "string",
          "description": "Filter by verdict (malicious, spam, restricted, clean)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of results",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "release_quarantine",
      "name": "Release from Quarantine",
      "description": "Release a quarantined email back to the user's inbox",
      "http_method": "POST",
      "endpoint": "/quarantine/{scan_id}/release",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "scan_id",
          "type": "string",
          "description": "The scan ID of the quarantined email",
          "required": true
        }
      ]
    },
    {
      "id": "change_verdict",
      "name": "Change Verdict",
      "description": "Override the scan verdict for a specific item",
      "http_method": "POST",
      "endpoint": "/scans/{scan_id}/verdict",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "scan_id",
          "type": "string",
          "description": "The scan ID",
          "required": true
        },
        {
          "name": "verdict",
          "type": "string",
          "description": "New verdict (malicious, spam, clean)",
          "required": true
        }
      ]
    },
    {
      "id": "request_investigation",
      "name": "Request Investigation",
      "description": "Request the IR team to investigate a scan result",
      "http_method": "POST",
      "endpoint": "/scans/{scan_id}/investigate",
      "action_type": "investigate",
      "read_only": false,
      "parameters": [
        {
          "name": "scan_id",
          "type": "string",
          "description": "The scan ID to investigate",
          "required": true
        },
        {
          "name": "suggested_verdict",
          "type": "string",
          "description": "Suggested verdict (malicious, spam, clean)",
          "required": false
        },
        {
          "name": "comment",
          "type": "string",
          "description": "Comment for the investigation request",
          "required": false
        }
      ]
    }
  ]
}