{
  "id": "okta",
  "name": "Okta",
  "description": "Integration with Okta for security operations",
  "version": "1.0.0",
  "category": "identity",
  "vendor": "Okta",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "",
  "actions": [
    {
      "id": "get_user",
      "name": "Get User",
      "http_method": "GET",
      "endpoint": "/api/v1/users/{user_id}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Get user details by ID or email",
      "observable_type": "email"
    },
    {
      "id": "list_user_factors",
      "name": "List User MFA Factors",
      "http_method": "GET",
      "endpoint": "/api/v1/users/{user_id}/factors",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "List enrolled MFA factors for a user"
    },
    {
      "id": "get_system_logs",
      "name": "Get System Logs",
      "http_method": "GET",
      "endpoint": "/api/v1/logs",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Get Okta system/audit logs"
    },
    {
      "id": "suspend_user",
      "name": "Suspend User",
      "http_method": "POST",
      "endpoint": "/api/v1/users/{user_id}/lifecycle/suspend",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Suspend a user account (response action)"
    },
    {
      "id": "clear_user_sessions",
      "name": "Clear User Sessions",
      "http_method": "DELETE",
      "endpoint": "/api/v1/users/{user_id}/sessions",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Clear all active sessions for a user"
    }
  ]
}