            "aws role session name"
          ]
        },
        {
          "name": "role_session_duration",
          "type": "number",
          "description": "Role Session Duration (Seconds)",
          "required": false,
          "default": 3600
        },
        {
          "name": "external_id",
          "type": "string",
          "description": "External ID",
          "required": false,
          "contains": [
            "aws external id"
          ]
        },
        {
          "name": "region",
          "type": "string",
          "description": "Region, overrides default region in asset configuration",
          "required": false
        }
      ]
    }
  ],
