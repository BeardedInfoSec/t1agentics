{
  "id": "thales_safenet",
  "name": "Thales SafeNet Trusted Access",
  "description": "Cloud-based access management and authentication through SafeNet Trusted Access REST API for managing users, groups, tokens, and authentication policies",
  "version": "1.0.0",
  "category": "identity",
  "vendor": "Thales",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "location": "header",
    "header_name": "X-API-Key",
    "prefix": ""
  },
  "base_url": "https://api.{region}.safenetid.com",
  "actions": [
    {
      "id": "list_users",
      "name": "List Users",
      "description": "List all users in the SafeNet Trusted Access tenant",
      "http_method": "GET",
      "endpoint": "/api/v1/tenants/{tenantId}/users",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenantId",
          "type": "string",
          "description": "Tenant ID",
          "required": true
        },
        {
          "name": "filter",
          "type": "string",
          "description": "Filter expression for user properties",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of results",
          "required": false
        }
      ]
    },
    {
      "id": "get_user",
      "name": "Get User",
      "description": "Retrieve details of a specific user",
      "http_method": "GET",
      "endpoint": "/api/v1/tenants/{tenantId}/users/{userId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenantId",
          "type": "string",
          "description": "Tenant ID",
          "required": true
        },
        {
          "name": "userId",
          "type": "string",
          "description": "User ID",
          "required": true
        }
      ]
    },
    {
      "id": "disable_user",
      "name": "Disable User",
      "description": "Disable a user account in SafeNet Trusted Access",
      "http_method": "PUT",
      "endpoint": "/api/v1/tenants/{tenantId}/users/{userId}",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "tenantId",
          "type": "string",
          "description": "Tenant ID",
          "required": true
        },
        {
          "name": "userId",
          "type": "string",
          "description": "User ID to disable",
          "required": true
        }
      ]
    },
    {
      "id": "list_groups",
      "name": "List Groups",
      "description": "List all groups in the tenant",
      "http_method": "GET",
      "endpoint": "/api/v1/tenants/{tenantId}/groups",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenantId",
          "type": "string",
          "description": "Tenant ID",
          "required": true
        }
      ]
    },
    {
      "id": "list_tokens",
      "name": "List Tokens",
      "description": "List all authentication tokens assigned to users",
      "http_method": "GET",
      "endpoint": "/api/v1/tenants/{tenantId}/tokens",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenantId",
          "type": "string",
          "description": "Tenant ID",
          "required": true
        },
        {
          "name": "userId",
          "type": "string",
          "description": "Filter tokens by user ID",
          "required": false
        }
      ]
    },
    {
      "id": "disable_token",
      "name": "Disable Token",
      "description": "Disable a specific authentication token",
      "http_method": "PUT",
      "endpoint": "/api/v1/tenants/{tenantId}/tokens/{tokenId}/disable",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "tenantId",
          "type": "string",
          "description": "Tenant ID",
          "required": true
        },
        {
          "name": "tokenId",
          "type": "string",
          "description": "Token ID to disable",
          "required": true
        }
      ]
    },
    {
      "id": "list_applications",
      "name": "List Applications",
      "description": "List all applications configured in SafeNet Trusted Access",
      "http_method": "GET",
      "endpoint": "/api/v1/tenants/{tenantId}/applications",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenantId",
          "type": "string",
          "description": "Tenant ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_authentication_logs",
      "name": "Get Authentication Logs",
      "description": "Retrieve authentication activity logs for auditing",
      "http_method": "GET",
      "endpoint": "/api/v1/tenants/{tenantId}/logs/authentications",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "tenantId",
          "type": "string",
          "description": "Tenant ID",
          "required": true
        },
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date for log retrieval (ISO 8601)",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date for log retrieval (ISO 8601)",
          "required": false
        }
      ]
    }
  ]
}