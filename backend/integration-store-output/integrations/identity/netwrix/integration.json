{
  "id": "netwrix",
  "name": "Netwrix Auditor",
  "description": "IT audit and compliance through Netwrix Auditor Integration API for querying activity records, change events, and generating audit reports",
  "version": "1.0.0",
  "category": "identity",
  "vendor": "Netwrix",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "header_prefix": "Bearer",
    "location": "header"
  },
  "base_url": "https://{host}:9699/api/v1",
  "actions": [
    {
      "id": "search_activity_records",
      "name": "Search Activity Records",
      "description": "Search audit activity records with flexible filtering",
      "http_method": "POST",
      "endpoint": "/activity/records/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date for the search (ISO 8601)",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date for the search (ISO 8601)",
          "required": false
        },
        {
          "name": "who",
          "type": "string",
          "description": "Filter by who performed the action",
          "required": false
        },
        {
          "name": "what",
          "type": "string",
          "description": "Filter by what was changed (object name)",
          "required": false
        },
        {
          "name": "where",
          "type": "string",
          "description": "Filter by where the change occurred (data source)",
          "required": false
        },
        {
          "name": "action",
          "type": "string",
          "description": "Filter by action type (Added, Removed, Modified, Read)",
          "required": false
        },
        {
          "name": "maxResults",
          "type": "number",
          "description": "Maximum number of results to return",
          "required": false
        }
      ]
    },
    {
      "id": "get_activity_record",
      "name": "Get Activity Record",
      "description": "Retrieve a specific activity record by ID",
      "http_method": "GET",
      "endpoint": "/activity/records/{recordId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "recordId",
          "type": "string",
          "description": "Activity record ID",
          "required": true
        }
      ]
    },
    {
      "id": "list_data_sources",
      "name": "List Data Sources",
      "description": "List all configured data sources in Netwrix Auditor",
      "http_method": "GET",
      "endpoint": "/datasources",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "list_monitoring_plans",
      "name": "List Monitoring Plans",
      "description": "List all monitoring plans configured in Netwrix Auditor",
      "http_method": "GET",
      "endpoint": "/monitoringplans",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "search_state_in_time",
      "name": "Search State-In-Time Data",
      "description": "Search state-in-time snapshots to understand the configuration at a specific point in time",
      "http_method": "POST",
      "endpoint": "/stateintime/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "date",
          "type": "string",
          "description": "Point-in-time date (ISO 8601)",
          "required": true
        },
        {
          "name": "dataSource",
          "type": "string",
          "description": "Data source to query",
          "required": false
        },
        {
          "name": "objectType",
          "type": "string",
          "description": "Object type to filter (User, Group, etc.)",
          "required": false
        }
      ]
    },
    {
      "id": "get_alert_events",
      "name": "Get Alert Events",
      "description": "Retrieve triggered alert events from Netwrix Auditor",
      "http_method": "GET",
      "endpoint": "/alerts/events",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date for alert events (ISO 8601)",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date for alert events (ISO 8601)",
          "required": false
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by alert severity (High, Medium, Low)",
          "required": false
        }
      ]
    },
    {
      "id": "search_permissions",
      "name": "Search Permission Changes",
      "description": "Search for permission and access right changes across data sources",
      "http_method": "POST",
      "endpoint": "/activity/records/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "objectType",
          "type": "string",
          "description": "Object type (Permission, Group Membership, etc.)",
          "required": true
        },
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date (ISO 8601)",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date (ISO 8601)",
          "required": false
        }
      ]
    }
  ]
}