{
  "id": "coverity",
  "name": "Coverity",
  "description": "Enterprise-grade static analysis platform for finding critical defects and security vulnerabilities in C, C++, Java, C#, and other languages",
  "version": "1.0.0",
  "category": "code_security",
  "vendor": "Synopsys",
  "auth_type": "basic",
  "auth_config": {
    "type": "basic",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://{host}/api/v2",
  "actions": [
    {
      "id": "list_projects",
      "name": "List Projects",
      "description": "List all Coverity projects accessible to the user",
      "http_method": "GET",
      "endpoint": "/projects",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "namePattern",
          "type": "string",
          "description": "Filter projects by name pattern (supports wildcards)",
          "required": false,
          "location": "query"
        },
        {
          "name": "offset",
          "type": "integer",
          "description": "Pagination offset",
          "required": false,
          "location": "query"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max number of results",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "list_streams",
      "name": "List Streams",
      "description": "List all streams associated with a project",
      "http_method": "GET",
      "endpoint": "/projects/{project_id}/streams",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "project_id",
          "type": "string",
          "description": "Project ID",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "list_defects",
      "name": "List Defects from View",
      "description": "Retrieve defects from a Coverity Connect view by view ID",
      "http_method": "GET",
      "endpoint": "/views/{view_id}/issues",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "view_id",
          "type": "integer",
          "description": "Coverity Connect view ID",
          "required": true,
          "location": "path"
        },
        {
          "name": "projectId",
          "type": "string",
          "description": "Filter by project ID",
          "required": false,
          "location": "query"
        },
        {
          "name": "offset",
          "type": "integer",
          "description": "Pagination offset",
          "required": false,
          "location": "query"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max number of results to return",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "get_issue",
      "name": "Get Issue Details",
      "description": "Retrieve detailed information about a specific issue/defect",
      "http_method": "GET",
      "endpoint": "/issues/{issue_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "issue_id",
          "type": "integer",
          "description": "Issue/defect CID",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "get_snapshots",
      "name": "Get Snapshots",
      "description": "List analysis snapshots for a stream to track scan history",
      "http_method": "GET",
      "endpoint": "/streams/{stream_id}/snapshots",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "stream_id",
          "type": "string",
          "description": "Stream ID",
          "required": true,
          "location": "path"
        }
      ]
    }
  ]
}
