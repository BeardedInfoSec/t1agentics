{
  "id": "checkmarx",
  "name": "Checkmarx SAST",
  "description": "Static application security testing platform for identifying security vulnerabilities, compliance issues, and business logic flaws in source code",
  "version": "1.0.0",
  "category": "code_security",
  "vendor": "Checkmarx",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "prefix": "Bearer ",
    "location": "header",
    "token_endpoint": "/auth/identity/connect/token",
    "token_grant_type": "password"
  },
  "base_url": "https://{host}/cxrestapi",
  "actions": [
    {
      "id": "list_projects",
      "name": "List Projects",
      "description": "Retrieve all SAST projects with details",
      "http_method": "GET",
      "endpoint": "/projects",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "projectName",
          "type": "string",
          "description": "Filter by project name",
          "required": false,
          "location": "query"
        },
        {
          "name": "teamId",
          "type": "string",
          "description": "Filter by team ID",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "get_project",
      "name": "Get Project Details",
      "description": "Retrieve details of a specific project by ID",
      "http_method": "GET",
      "endpoint": "/projects/{project_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "project_id",
          "type": "integer",
          "description": "Project ID",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "list_scans",
      "name": "List Scans",
      "description": "List all SAST scans with optional filtering",
      "http_method": "GET",
      "endpoint": "/sast/scans",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "projectId",
          "type": "integer",
          "description": "Filter by project ID",
          "required": false,
          "location": "query"
        },
        {
          "name": "scanStatus",
          "type": "string",
          "description": "Filter by scan status (e.g., Finished, Running)",
          "required": false,
          "location": "query"
        },
        {
          "name": "last",
          "type": "integer",
          "description": "Number of most recent scans to return",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "get_scan_results",
      "name": "Get Scan Results",
      "description": "Retrieve vulnerability results for a specific scan",
      "http_method": "GET",
      "endpoint": "/sast/scans/{scan_id}/resultsStatistics",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "scan_id",
          "type": "integer",
          "description": "Scan ID",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "get_scan_status",
      "name": "Get Scan Status",
      "description": "Check the current status of a SAST scan",
      "http_method": "GET",
      "endpoint": "/sast/scans/{scan_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "scan_id",
          "type": "integer",
          "description": "Scan ID to check status for",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "generate_scan_report",
      "name": "Generate Scan Report",
      "description": "Request generation of a vulnerability report for a scan",
      "http_method": "POST",
      "endpoint": "/reports/sastScan",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "reportType",
          "type": "string",
          "description": "Report format: PDF, RTF, CSV, XML",
          "required": true,
          "location": "body"
        },
        {
          "name": "scanId",
          "type": "integer",
          "description": "Scan ID to generate report for",
          "required": true,
          "location": "body"
        }
      ]
    }
  ]
}
