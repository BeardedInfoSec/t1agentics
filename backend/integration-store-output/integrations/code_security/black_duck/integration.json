{
  "id": "black_duck",
  "name": "Black Duck",
  "description": "Software composition analysis platform for identifying open source vulnerabilities, license compliance risks, and code quality issues",
  "version": "1.0.0",
  "category": "code_security",
  "vendor": "Synopsys",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "prefix": "Bearer ",
    "location": "header",
    "token_endpoint": "/api/tokens/authenticate",
    "description": "POST API token to /api/tokens/authenticate to receive bearer token"
  },
  "base_url": "https://{host}",
  "actions": [
    {
      "id": "list_projects",
      "name": "List Projects",
      "description": "Retrieve all Black Duck projects",
      "http_method": "GET",
      "endpoint": "/api/projects",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "q",
          "type": "string",
          "description": "Search query for project name",
          "required": false,
          "location": "query"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max number of results (default 10)",
          "required": false,
          "location": "query"
        },
        {
          "name": "offset",
          "type": "integer",
          "description": "Pagination offset",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "list_project_versions",
      "name": "List Project Versions",
      "description": "List all versions of a specific project",
      "http_method": "GET",
      "endpoint": "/api/projects/{project_id}/versions",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "project_id",
          "type": "string",
          "description": "Project UUID",
          "required": true,
          "location": "path"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max number of results",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "list_vulnerable_components",
      "name": "List Vulnerable BOM Components",
      "description": "List vulnerable components for a specific project version",
      "http_method": "GET",
      "endpoint": "/api/projects/{project_id}/versions/{version_id}/vulnerable-bom-components",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "project_id",
          "type": "string",
          "description": "Project UUID",
          "required": true,
          "location": "path"
        },
        {
          "name": "version_id",
          "type": "string",
          "description": "Version UUID",
          "required": true,
          "location": "path"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max results per page (default 10, max 1000)",
          "required": false,
          "location": "query"
        },
        {
          "name": "offset",
          "type": "integer",
          "description": "Pagination offset",
          "required": false,
          "location": "query"
        }
      ]
    },
    {
      "id": "get_vulnerability",
      "name": "Get Vulnerability Details",
      "description": "Retrieve details of a specific vulnerability by ID",
      "http_method": "GET",
      "endpoint": "/api/vulnerabilities/{vulnerability_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "vulnerability_id",
          "type": "string",
          "description": "Vulnerability ID (e.g., CVE-2021-44228 or BDSA identifier)",
          "required": true,
          "location": "path"
        }
      ]
    },
    {
      "id": "list_bom_components",
      "name": "List BOM Components",
      "description": "List all components in a project version bill of materials",
      "http_method": "GET",
      "endpoint": "/api/projects/{project_id}/versions/{version_id}/components",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "project_id",
          "type": "string",
          "description": "Project UUID",
          "required": true,
          "location": "path"
        },
        {
          "name": "version_id",
          "type": "string",
          "description": "Version UUID",
          "required": true,
          "location": "path"
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max results per page",
          "required": false,
          "location": "query"
        }
      ]
    }
  ]
}
