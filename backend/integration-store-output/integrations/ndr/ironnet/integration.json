{
  "id": "ironnet",
  "name": "IronNet IronDefense",
  "description": "Collective defense NDR platform that detects advanced threats using behavioral analytics and shares threat intelligence across organizations",
  "version": "1.0.0",
  "category": "ndr",
  "vendor": "IronNet Cybersecurity",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "location": "header",
    "header_name": "Authorization",
    "prefix": "Bearer "
  },
  "base_url": "https://{host}/api/v1",
  "actions": [
    {
      "id": "get_alerts",
      "name": "Get Alerts",
      "description": "Retrieve IronDefense alerts with optional filters",
      "http_method": "GET",
      "endpoint": "/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of alerts to return",
          "required": false,
          "default": 100
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        },
        {
          "name": "status",
          "type": "string",
          "description": "Alert status filter",
          "required": false
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Severity filter (low, moderate, critical, undecided)",
          "required": false
        },
        {
          "name": "category",
          "type": "string",
          "description": "Alert category filter",
          "required": false
        },
        {
          "name": "sub_category",
          "type": "string",
          "description": "Alert sub-category filter",
          "required": false
        },
        {
          "name": "created_start_date",
          "type": "string",
          "description": "Filter by creation start date in ISO 8601 format",
          "required": false
        },
        {
          "name": "created_end_date",
          "type": "string",
          "description": "Filter by creation end date in ISO 8601 format",
          "required": false
        }
      ]
    },
    {
      "id": "get_alert_details",
      "name": "Get Alert Details",
      "description": "Retrieve detailed information about a specific alert including events",
      "http_method": "GET",
      "endpoint": "/alerts/{alert_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "The alert ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_events",
      "name": "Get Events",
      "description": "Retrieve events associated with a specific alert",
      "http_method": "GET",
      "endpoint": "/alerts/{alert_id}/events",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "The alert ID",
          "required": true
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of events to return",
          "required": false,
          "default": 100
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "rate_alert",
      "name": "Rate Alert",
      "description": "Set the analyst severity rating for an alert",
      "http_method": "POST",
      "endpoint": "/alerts/{alert_id}/rate",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "The alert ID",
          "required": true
        },
        {
          "name": "analyst_severity",
          "type": "string",
          "description": "Analyst severity (benign, suspicious, malicious, undecided)",
          "required": true
        },
        {
          "name": "analyst_expectation",
          "type": "string",
          "description": "Analyst expectation (expected, unexpected)",
          "required": true
        },
        {
          "name": "comment",
          "type": "string",
          "description": "Comment for the rating",
          "required": false
        }
      ]
    },
    {
      "id": "update_alert_status",
      "name": "Update Alert Status",
      "description": "Update the status of an alert",
      "http_method": "POST",
      "endpoint": "/alerts/{alert_id}/status",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "The alert ID",
          "required": true
        },
        {
          "name": "status",
          "type": "string",
          "description": "New alert status",
          "required": true
        },
        {
          "name": "comment",
          "type": "string",
          "description": "Comment for the status update",
          "required": false
        }
      ]
    },
    {
      "id": "add_comment",
      "name": "Add Comment to Alert",
      "description": "Add a comment to an IronDefense alert",
      "http_method": "POST",
      "endpoint": "/alerts/{alert_id}/comments",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "The alert ID",
          "required": true
        },
        {
          "name": "comment",
          "type": "string",
          "description": "Comment text to add",
          "required": true
        }
      ]
    },
    {
      "id": "report_bad_activity",
      "name": "Report Bad Activity",
      "description": "Report observed bad activity to IronDome for collective defense sharing",
      "http_method": "POST",
      "endpoint": "/irondome/report",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "The alert ID to report",
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "description": "Description of the observed bad activity",
          "required": true
        }
      ]
    }
  ]
}