{
  "id": "arista_ndr",
  "name": "Arista NDR",
  "description": "AI-driven network detection and response platform (formerly Awake Security) using deep packet inspection and machine learning to detect threats",
  "version": "1.0.0",
  "category": "ndr",
  "vendor": "Arista Networks",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "location": "header",
    "header_name": "Authorization",
    "prefix": "Bearer "
  },
  "base_url": "https://{host}/api/v1",
  "actions": [
    {
      "id": "get_activities",
      "name": "Get Activities",
      "description": "Retrieve security activities and threat detections from the platform",
      "http_method": "GET",
      "endpoint": "/activities",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in ISO 8601 format",
          "required": false
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity (low, medium, high, critical)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of activities to return",
          "required": false,
          "default": 100
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "get_activity_details",
      "name": "Get Activity Details",
      "description": "Retrieve detailed information about a specific security activity",
      "http_method": "GET",
      "endpoint": "/activities/{activity_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "activity_id",
          "type": "string",
          "description": "The activity ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_devices",
      "name": "Get Devices",
      "description": "Retrieve network devices discovered by Arista NDR",
      "http_method": "GET",
      "endpoint": "/devices",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "ip_address",
          "type": "string",
          "description": "Filter by IP address",
          "required": false
        },
        {
          "name": "mac_address",
          "type": "string",
          "description": "Filter by MAC address",
          "required": false
        },
        {
          "name": "hostname",
          "type": "string",
          "description": "Filter by hostname",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of devices to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_device_details",
      "name": "Get Device Details",
      "description": "Retrieve detailed information about a specific device",
      "http_method": "GET",
      "endpoint": "/devices/{device_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "device_id",
          "type": "string",
          "description": "The device ID",
          "required": true
        }
      ]
    },
    {
      "id": "search_network_data",
      "name": "Search Network Data",
      "description": "Search network traffic metadata and protocol logs",
      "http_method": "POST",
      "endpoint": "/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query string",
          "required": true
        },
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in ISO 8601 format",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of results",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_threat_models",
      "name": "Get Threat Models",
      "description": "Retrieve available threat models and detection categories",
      "http_method": "GET",
      "endpoint": "/threat-models",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "get_situations",
      "name": "Get Situations",
      "description": "Retrieve correlated security situations combining multiple activities",
      "http_method": "GET",
      "endpoint": "/situations",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in ISO 8601 format",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in ISO 8601 format",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of situations to return",
          "required": false,
          "default": 100
        }
      ]
    }
  ]
}