{
  "id": "sophos_ndr",
  "name": "Sophos NDR",
  "description": "Network detection and response integrated with Sophos Central providing AI-powered threat detection for encrypted and unencrypted network traffic",
  "version": "1.0.0",
  "category": "ndr",
  "vendor": "Sophos",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "header_name": "Authorization",
    "location": "header",
    "prefix": "Bearer",
    "token_url": "https://id.sophos.com/api/v2/oauth2/token"
  },
  "base_url": "https://api.central.sophos.com",
  "actions": [
    {
      "id": "get_alerts",
      "name": "Get Alerts",
      "description": "Retrieve NDR alerts from Sophos Central",
      "http_method": "GET",
      "endpoint": "/common/v1/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "from_date",
          "type": "string",
          "description": "Start date filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "product",
          "type": "string",
          "description": "Filter by product (ndr)",
          "required": false,
          "default": "ndr"
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity (low, medium, high)",
          "required": false
        },
        {
          "name": "category",
          "type": "string",
          "description": "Alert category filter",
          "required": false
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "get_alert_details",
      "name": "Get Alert Details",
      "description": "Retrieve detailed information about a specific alert",
      "http_method": "GET",
      "endpoint": "/common/v1/alerts/{alert_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "The alert ID",
          "required": true
        }
      ]
    },
    {
      "id": "get_detections",
      "name": "Get NDR Detections",
      "description": "Retrieve network detections identified by Sophos NDR",
      "http_method": "GET",
      "endpoint": "/ndr/v1/detections",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "from_date",
          "type": "string",
          "description": "Start date filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "to_date",
          "type": "string",
          "description": "End date filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity",
          "required": false
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Number of results per page",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "get_integrations",
      "name": "Get NDR Integrations",
      "description": "Retrieve configured NDR sensor integrations and their status",
      "http_method": "GET",
      "endpoint": "/ndr/v1/integrations",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "get_queries",
      "name": "Get Threat Queries",
      "description": "Retrieve network threat query results from NDR analysis",
      "http_method": "GET",
      "endpoint": "/ndr/v1/queries",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "from_date",
          "type": "string",
          "description": "Start date filter in ISO 8601 format",
          "required": false
        },
        {
          "name": "to_date",
          "type": "string",
          "description": "End date filter in ISO 8601 format",
          "required": false
        }
      ]
    },
    {
      "id": "acknowledge_alert",
      "name": "Acknowledge Alert",
      "description": "Acknowledge an alert to mark it as reviewed",
      "http_method": "POST",
      "endpoint": "/common/v1/alerts/{alert_id}/actions",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "The alert ID to acknowledge",
          "required": true
        },
        {
          "name": "action",
          "type": "string",
          "description": "Action to take (acknowledge)",
          "required": true,
          "default": "acknowledge"
        }
      ]
    }
  ]
}