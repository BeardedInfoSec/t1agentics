{
  "id": "snyk",
  "name": "Snyk",
  "description": "Developer security platform providing cloud security, code analysis, open source vulnerability scanning, container security, and IaC scanning via REST API",
  "version": "1.0.0",
  "category": "cloud_security",
  "vendor": "Snyk",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "location": "header",
    "header_name": "Authorization",
    "prefix": "token "
  },
  "base_url": "https://api.snyk.io/v1",
  "actions": [
    {
      "id": "list_organizations",
      "name": "List Organizations",
      "description": "List all organizations the authenticated user has access to",
      "http_method": "GET",
      "endpoint": "/orgs",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "list_projects",
      "name": "List Projects",
      "description": "List all projects within a specific organization",
      "http_method": "GET",
      "endpoint": "/org/{orgId}/projects",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "orgId",
          "type": "string",
          "description": "Organization ID",
          "required": true
        }
      ]
    },
    {
      "id": "list_issues",
      "name": "List Issues",
      "description": "Retrieve all vulnerability issues for a specific project",
      "http_method": "POST",
      "endpoint": "/org/{orgId}/project/{projectId}/issues",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "orgId",
          "type": "string",
          "description": "Organization ID",
          "required": true
        },
        {
          "name": "projectId",
          "type": "string",
          "description": "Project ID",
          "required": true
        },
        {
          "name": "filters",
          "type": "object",
          "description": "Filter object (e.g., {\"severities\": [\"critical\", \"high\"], \"types\": [\"vuln\", \"license\"]})",
          "required": false
        }
      ]
    },
    {
      "id": "get_issue_details",
      "name": "Get Issue Details",
      "description": "Get detailed information about a specific vulnerability or license issue",
      "http_method": "GET",
      "endpoint": "/org/{orgId}/project/{projectId}/issue/{issueId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "orgId",
          "type": "string",
          "description": "Organization ID",
          "required": true
        },
        {
          "name": "projectId",
          "type": "string",
          "description": "Project ID",
          "required": true
        },
        {
          "name": "issueId",
          "type": "string",
          "description": "Issue ID",
          "required": true
        }
      ]
    },
    {
      "id": "test_package",
      "name": "Test Package",
      "description": "Test a specific package version for known vulnerabilities",
      "http_method": "GET",
      "endpoint": "/test/{packageManager}/{packageName}/{version}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "packageManager",
          "type": "string",
          "description": "Package manager (npm, pip, maven, rubygems, nuget, etc.)",
          "required": true
        },
        {
          "name": "packageName",
          "type": "string",
          "description": "Name of the package to test",
          "required": true
        },
        {
          "name": "version",
          "type": "string",
          "description": "Version of the package to test",
          "required": true
        }
      ]
    },
    {
      "id": "list_cloud_issues",
      "name": "List Cloud Issues",
      "description": "List cloud configuration issues found by Snyk IaC and Cloud scanning",
      "http_method": "GET",
      "endpoint": "/org/{orgId}/cloud/issues",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "orgId",
          "type": "string",
          "description": "Organization ID",
          "required": true
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity (critical, high, medium, low)",
          "required": false
        },
        {
          "name": "environment_id",
          "type": "string",
          "description": "Filter by cloud environment ID",
          "required": false
        }
      ]
    },
    {
      "id": "list_dependencies",
      "name": "List Dependencies",
      "description": "List all dependencies for a project including transitive dependencies",
      "http_method": "POST",
      "endpoint": "/org/{orgId}/dependencies",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "orgId",
          "type": "string",
          "description": "Organization ID",
          "required": true
        },
        {
          "name": "filters",
          "type": "object",
          "description": "Filter object for dependency search",
          "required": false
        },
        {
          "name": "page",
          "type": "number",
          "description": "Page number for pagination",
          "required": false,
          "default": 1
        }
      ]
    }
  ]
}