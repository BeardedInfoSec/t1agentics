{
  "id": "zscaler_posture",
  "name": "Zscaler Posture Control",
  "description": "Cloud security posture management platform providing CSPM, CIEM, IaC scanning, and compliance across multi-cloud environments",
  "version": "1.0.0",
  "category": "cloud_security",
  "vendor": "Zscaler",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "prefix": "Bearer",
    "location": "header",
    "note": "Authenticate via /api/v1/auth/login with API credentials to obtain Bearer token"
  },
  "base_url": "https://api.zcspm.{region}.zscaler.com",
  "actions": [
    {
      "id": "list_alerts",
      "name": "List Alerts",
      "description": "Retrieve security alerts for misconfigurations, policy violations, and threats",
      "http_method": "GET",
      "endpoint": "/api/v1/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity (Critical, High, Medium, Low)",
          "required": false
        },
        {
          "name": "status",
          "type": "string",
          "description": "Filter by status (open, resolved, suppressed)",
          "required": false
        },
        {
          "name": "cloud_type",
          "type": "string",
          "description": "Filter by cloud type (AWS, Azure, GCP)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum alerts to return",
          "required": false,
          "default": 100
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "list_policies",
      "name": "List Policies",
      "description": "List security policies and their configurations",
      "http_method": "GET",
      "endpoint": "/api/v1/policies",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "cloud_type",
          "type": "string",
          "description": "Filter by cloud type",
          "required": false
        },
        {
          "name": "enabled",
          "type": "boolean",
          "description": "Filter by enabled status",
          "required": false
        }
      ]
    },
    {
      "id": "get_compliance_status",
      "name": "Get Compliance Status",
      "description": "Retrieve compliance posture for a specific benchmark framework",
      "http_method": "GET",
      "endpoint": "/api/v1/compliance",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "framework",
          "type": "string",
          "description": "Compliance framework (e.g., CIS, NIST, SOC2, PCI-DSS, HIPAA)",
          "required": false
        },
        {
          "name": "cloud_account_id",
          "type": "string",
          "description": "Filter by cloud account ID",
          "required": false
        }
      ]
    },
    {
      "id": "list_assets",
      "name": "List Assets",
      "description": "List cloud assets and their security posture across connected accounts",
      "http_method": "GET",
      "endpoint": "/api/v1/inventory/assets",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "asset_type",
          "type": "string",
          "description": "Filter by asset type",
          "required": false
        },
        {
          "name": "cloud_type",
          "type": "string",
          "description": "Filter by cloud provider",
          "required": false
        },
        {
          "name": "region",
          "type": "string",
          "description": "Filter by cloud region",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum results to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "list_cloud_accounts",
      "name": "List Cloud Accounts",
      "description": "List onboarded cloud accounts and their scanning status",
      "http_method": "GET",
      "endpoint": "/api/v1/cloud-accounts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "cloud_type",
          "type": "string",
          "description": "Filter by cloud type (AWS, Azure, GCP)",
          "required": false
        }
      ]
    },
    {
      "id": "get_iam_risks",
      "name": "Get IAM Risks",
      "description": "Retrieve CIEM analysis results showing excessive permissions and IAM risks",
      "http_method": "GET",
      "endpoint": "/api/v1/iam/risks",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "risk_level",
          "type": "string",
          "description": "Filter by risk level (critical, high, medium, low)",
          "required": false
        },
        {
          "name": "identity_type",
          "type": "string",
          "description": "Filter by identity type (user, role, service_account, group)",
          "required": false
        }
      ]
    }
  ]
}