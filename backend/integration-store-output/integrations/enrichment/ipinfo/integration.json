{
  "id": "ipinfo",
  "name": "IPinfo",
  "description": "Integration with IPinfo for security operations",
  "version": "1.0.0",
  "category": "enrichment",
  "vendor": "IPinfo",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "token",
    "location": "query"
  },
  "base_url": "https://ipinfo.io",
  "actions": [
    {
      "id": "enrich_ip",
      "name": "IP Geolocation",
      "http_method": "GET",
      "endpoint": "/{ip}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 30,
      "description": "Get geolocation, ASN, and company info for an IP",
      "observable_type": "ip"
    }
  ]
}