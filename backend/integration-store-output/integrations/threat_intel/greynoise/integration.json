{
  "id": "greynoise",
  "name": "GreyNoise",
  "description": "Integration with GreyNoise for security operations",
  "version": "1.0.0",
  "category": "threat_intel",
  "vendor": "GreyNoise",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "key",
    "location": "header"
  },
  "base_url": "https://api.greynoise.io/v3",
  "actions": [
    {
      "id": "check_ip",
      "name": "IP Context",
      "http_method": "GET",
      "endpoint": "/community/{ip}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Get context about an IP - is it scanning the internet or targeting you specifically?",
      "observable_type": "ip"
    }
  ]
}