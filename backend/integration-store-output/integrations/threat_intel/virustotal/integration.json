{
  "id": "virustotal",
  "name": "VirusTotal",
  "description": "Integration with VirusTotal for security operations",
  "version": "1.0.0",
  "category": "threat_intel",
  "vendor": "VirusTotal",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "x-apikey",
    "location": "header"
  },
  "base_url": "https://www.virustotal.com/api/v3",
  "actions": [
    {
      "id": "enrich_file_hash",
      "name": "Get File Report",
      "http_method": "GET",
      "endpoint": "/files/{hash}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 30,
      "description": "Get detailed report for a file hash",
      "observable_type": "file_hash"
    },
    {
      "id": "enrich_ip",
      "name": "Get IP Address Report",
      "http_method": "GET",
      "endpoint": "/ip_addresses/{ip}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "description": "Get detailed report for an IP address",
      "observable_type": "ip"
    },
    {
      "id": "enrich_domain",
      "name": "Get Domain Report",
      "http_method": "GET",
      "endpoint": "/domains/{domain}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "description": "Get detailed report for a domain",
      "observable_type": "domain"
    },
    {
      "id": "enrich_url",
      "name": "Get URL Report",
      "http_method": "GET",
      "endpoint": "/urls/{url_id}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "description": "Get detailed report for a URL",
      "observable_type": "url"
    }
  ]
}