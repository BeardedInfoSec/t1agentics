{
  "id": "abuseipdb",
  "name": "AbuseIPDB",
  "description": "Integration with AbuseIPDB for security operations",
  "version": "1.0.0",
  "category": "threat_intel",
  "vendor": "AbuseIPDB",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Key",
    "location": "header"
