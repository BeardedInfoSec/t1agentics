  "base_url": "https://api.abuseipdb.com/api/v2",
  "actions": [
    {
      "id": "check_ip",
      "name": "Check IP Address",
      "http_method": "GET",
      "endpoint": "/check",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "description": "Check if an IP address has been reported for abuse",
      "observable_type": "ip"
    }
  ]
}