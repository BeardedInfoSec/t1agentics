{
  "id": "urlhaus",
  "name": "URLhaus",
  "description": "Integration with URLhaus for security operations",
  "version": "1.0.0",
  "category": "threat_intel",
  "vendor": "URLhaus",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "X-API-Key",
    "location": "header"
  },
  "base_url": "https://urlhaus-api.abuse.ch/v1",
  "actions": [
    {
      "id": "check_url",
      "name": "Check URL",
      "http_method": "POST",
      "endpoint": "/url/",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Check if a URL is associated with malware distribution",
      "observable_type": "url"
    },
    {
      "id": "check_host",
      "name": "Check Host",
      "http_method": "POST",
      "endpoint": "/host/",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Check if a domain/IP is hosting malware",
      "observable_type": "domain"
    }
  ]
}