{
  "id": "expanse",
  "name": "Expanse",
  "description": "Expanse allows you to perform enrichment using Expanse's Internet Asset data, including IP, Domain, Certificates, and more",
  "version": "1.1.4",
  "category": "threat_intel",
  "vendor": "Expanse",
  "auth_type": "bearer_token",
  "auth_config": {
    "type": "bearer_token",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://expander.expanse.co",
  "actions": [
    {
      "id": "lookup_ip",
      "name": "Lookup Ip",
      "description": "Check for the presence of an IP within a known IP range in Expanse",
      "http_method": "GET",
      "endpoint": "/api/v2/ip-range",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "ip",
          "type": "string",
          "description": "IP to lookup",
          "required": true,
          "contains": [
            "ip"
          ]
        }
      ],
      "observable_type": "ip"
    },
    {
      "id": "lookup_domain",
      "name": "Lookup Domain",
      "description": "Check for the presence of a known domain in Expanse",
      "http_method": "GET",
      "endpoint": "/api/v2/assets/domains",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "domain",
          "type": "string",
          "description": "Domain to lookup",
          "required": true,
          "contains": [
            "domain",
            "url"
          ]
        }
      ],
      "observable_type": "domain"
    },
    {
      "id": "lookup_certificate",
      "name": "Lookup Certificate",
      "description": "Returns certificates from Expanse for a full or partial common name",
      "http_method": "GET",
      "endpoint": "/actions/lookup_certificate",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "common_name",
          "type": "string",
          "description": "Search for given certificate value via a domain substring match",
          "required": true
        }
      ]
    },
    {
      "id": "lookup_behavior",
      "name": "Lookup Behavior",
      "description": "Returns Expanse behavior data for an IP. Limited to 30 flows within the last 30 days",
      "http_method": "GET",
      "endpoint": "/actions/lookup_behavior",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "ip",
          "type": "string",
          "description": "Internal IP address to search for",
          "required": true,
          "contains": [
            "ip"
          ]
        }
      ],
      "observable_type": "ip"
    }
  ],
