            "azuresql table schema"
          ]
        }
      ]
    },
    {
      "id": "list_columns",
      "name": "List Columns",
      "description": "Lists all the columns of a table existing within the database connected to your asset",
      "http_method": "GET",
      "endpoint": "/actions/list_columns",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "table_name",
          "type": "string",
