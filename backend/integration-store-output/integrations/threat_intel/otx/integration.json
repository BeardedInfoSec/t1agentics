{
  "id": "otx",
  "name": "AlienVault OTX",
  "description": "Integration with AlienVault OTX for security operations",
  "version": "1.0.0",
  "category": "threat_intel",
  "vendor": "AlienVault",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "X-OTX-API-KEY",
    "location": "header"
  },
  "base_url": "https://otx.alienvault.com/api/v1",
  "actions": [
    {
      "id": "check_ip",
      "name": "IP Reputation",
      "http_method": "GET",
      "endpoint": "/indicators/IPv4/{ip}/general",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "description": "Get threat intelligence for an IP address",
      "observable_type": "ip"
    },
    {
      "id": "check_domain",
      "name": "Domain Reputation",
      "http_method": "GET",
      "endpoint": "/indicators/domain/{domain}/general",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "description": "Get threat intelligence for a domain",
      "observable_type": "domain"
    },
    {
      "id": "check_hash",
      "name": "File Hash Reputation",
      "http_method": "GET",
      "endpoint": "/indicators/file/{hash}/general",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 30,
      "description": "Get threat intelligence for a file hash",
      "observable_type": "file_hash"
    },
    {
      "id": "check_url",
      "name": "URL Reputation",
      "http_method": "GET",
      "endpoint": "/indicators/url/{url_encoded}/general",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Get threat intelligence for a URL",
      "observable_type": "url"
    }
  ]
}