{
  "id": "hibp",
  "name": "Have I Been Pwned",
  "description": "Integration with Have I Been Pwned for security operations",
  "version": "1.0.0",
  "category": "threat_intel",
  "vendor": "Have I Been Pwned",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "hibp-api-key",
    "location": "header"
  },
  "base_url": "https://haveibeenpwned.com/api/v3",
  "actions": [
    {
      "id": "check_email",
      "name": "Check Email Breaches",
      "http_method": "GET",
      "endpoint": "/breachedaccount/{email}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "description": "Check if an email has been in known data breaches",
      "observable_type": "email"
    },
    {
      "id": "check_domain",
      "name": "Check Domain Breaches",
      "http_method": "GET",
      "endpoint": "/breaches?domain={domain}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "description": "Check if a domain has been in known data breaches",
      "observable_type": "domain"
    }
  ]
}