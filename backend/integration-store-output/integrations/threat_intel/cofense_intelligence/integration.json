      "http_method": "GET",
      "endpoint": "/actions/hunt_url",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "url",
          "type": "string",
          "description": "URL to hunt",
          "required": true,
