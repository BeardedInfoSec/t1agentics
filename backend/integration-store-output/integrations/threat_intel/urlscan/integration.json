{
  "id": "urlscan",
  "name": "URLScan.io",
  "description": "Integration with URLScan.io for security operations",
  "version": "1.0.0",
  "category": "threat_intel",
  "vendor": "URLscan.io",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "X-API-Key",
    "location": "header"
  },
  "base_url": "https://urlscan.io/api/v1",
  "actions": [
    {
      "id": "search_url",
      "name": "Search URL",
      "http_method": "GET",
      "endpoint": "/search/?q=page.url:\"{url_encoded}\"&size=1",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Search for existing scans of a URL",
      "observable_type": "url",
      "parameters": [
        {
          "name": "url",
          "type": "string",
          "in": "path"
        },
        {
          "name": "url_encoded",
          "type": "string",
          "in": "path"
        }
      ]
    },
    {
      "id": "search_domain",
      "name": "Search Domain",
      "http_method": "GET",
      "endpoint": "/search/?q=domain:{domain}&size=5",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Search for scans of a domain",
      "observable_type": "domain"
    },
    {
      "id": "search_ip",
      "name": "Search IP",
      "http_method": "GET",
      "endpoint": "/search/?q=page.ip:{ip}&size=5",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Search for scans associated with an IP address",
      "observable_type": "ip"
    },
    {
      "id": "submit_scan",
      "name": "Submit URL for Scan",
      "http_method": "POST",
      "endpoint": "/scan/",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Submit a URL for live scanning (requires API key)",
      "observable_type": "url"
    },
    {
      "id": "get_result",
      "name": "Get Scan Result",
      "http_method": "GET",
      "endpoint": "/result/{uuid}/",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "description": "Get the result of a previous scan by UUID"
    }
  ]
}