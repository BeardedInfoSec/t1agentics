{
  "id": "mxtoolbox",
  "name": "MxToolbox",
  "description": "This app implements investigative actions on domains and IPs",
  "version": "2.0.8",
  "category": "threat_intel",
  "vendor": "MxToolbox",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://mxtoolbox.com/api/v1/",
  "actions": [
    {
      "id": "lookup_domain",
      "name": "Lookup Domain",
      "description": "Returns the result of a lookup on a specific url",
      "http_method": "GET",
      "endpoint": "/actions/lookup_domain",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "domain",
          "type": "string",
          "description": "Domain to query",
          "required": true,
          "contains": [
            "domain"
          ]
        },
        {
          "name": "type",
          "type": "string",
          "description": "Type of domain lookup",
          "required": true
        }
      ],
      "observable_type": "domain"
    },
    {
      "id": "lookup_ip",
      "name": "Lookup Ip",
      "description": "Returns the result of a lookup on a specific ip address",
      "http_method": "GET",
      "endpoint": "/actions/lookup_ip",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "ip",
          "type": "string",
          "description": "IP to query",
          "required": true,
          "contains": [
            "ip",
            "ipv6"
          ]
        }
      ],
      "observable_type": "ip"
    }
  ],
  "source_metadata": {
    "original_name": "MxToolbox",
    "original_type": "investigative",
    "converted_at": "2025-12-18T16:25:28.994512",
    "source_version": "2.0.8"
  }
}