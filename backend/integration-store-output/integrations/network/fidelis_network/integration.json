{
  "id": "fidelis_network_network",
  "name": "Fidelis Network",
  "description": "This app integrates with Fidelis Network to execute various investigate and generic actions",
  "version": "1.0.5",
  "category": "network",
  "vendor": "Fidelis Cybersecurity",
  "auth_type": "basic_auth",
  "auth_config": {
    "type": "basic_auth",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "Using base URL ",
  "actions": [
    {
      "id": "list_alerts",
      "name": "List Alerts",
      "description": "List all of the alerts tracked within the enterprise on particular assets and|or users for the specified time",
      "http_method": "GET",
      "endpoint": "/actions/list_alerts",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "column",
          "type": "string",
          "description": "Column for ordering",
          "required": true,
          "default": "ALERT_TIME"
        },
        {
          "name": "direction",
          "type": "string",
          "description": "Direction of alerts order",
          "required": true,
          "default": "DESC"
        },
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in UTC (YYYY-MM-DD HH:MM:SS)",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in UTC (YYYY-MM-DD HH:MM:SS)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Specify the maximum number of alerts to return. You can specify between 1 and 200,000. (Default is 100)",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_alert_details",
      "name": "Get Alert Details",
      "description": "Gets an alert details from Fidelis Network",
      "http_method": "GET",
      "endpoint": "/actions/get_alert_details",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "Alert ID",
          "required": true,
          "contains": [
            "alert id"
          ]
        }
      ]
    },
    {
      "id": "delete_alert",
      "name": "Delete Alert",
      "description": "Delete alerts from Fidelis Network",
      "http_method": "GET",
      "endpoint": "/actions/delete_alert",
      "action_type": "generic",
      "read_only": false,
      "cacheable": false,
      "cache_ttl_days": 0,
      "parameters": [
        {
          "name": "alert_id",
          "type": "string",
          "description": "Alert IDs (comma-separated)",
          "required": true,
          "contains": [
            "alert id"
          ]
        }
      ]
    }
  ],
