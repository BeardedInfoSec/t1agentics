{
  "id": "vanta",
  "name": "Vanta",
  "description": "Integrates with Vanta REST API v1 for compliance automation including controls monitoring, vulnerability management, and evidence tracking",
  "version": "1.0.0",
  "category": "grc",
  "vendor": "Vanta",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://api.vanta.com/v1",
  "actions": [
    {
      "id": "list_controls",
      "name": "List Controls",
      "description": "List compliance controls and their statuses",
      "http_method": "GET",
      "endpoint": "/controls",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "frameworkId", "type": "string", "description": "Filter by framework ID (e.g. SOC2, ISO27001)", "required": false},
        {"name": "pageSize", "type": "number", "description": "Results per page", "required": false, "default": 50},
        {"name": "pageCursor", "type": "string", "description": "Cursor for pagination", "required": false}
      ]
    },
    {
      "id": "list_tests",
      "name": "List Tests",
      "description": "List compliance tests and their results",
      "http_method": "GET",
      "endpoint": "/tests",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "controlId", "type": "string", "description": "Filter by control ID", "required": false},
        {"name": "status", "type": "string", "description": "Filter by status (PASSING, FAILING, DISABLED)", "required": false},
        {"name": "pageSize", "type": "number", "description": "Results per page", "required": false, "default": 50},
        {"name": "pageCursor", "type": "string", "description": "Cursor for pagination", "required": false}
      ]
    },
    {
      "id": "list_vulnerabilities",
      "name": "List Vulnerabilities",
      "description": "List vulnerability findings and their statuses",
      "http_method": "GET",
      "endpoint": "/vulnerabilities",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "severity", "type": "string", "description": "Filter by severity (CRITICAL, HIGH, MEDIUM, LOW, INFO)", "required": false},
        {"name": "status", "type": "string", "description": "Filter by remediation status", "required": false},
        {"name": "pageSize", "type": "number", "description": "Results per page", "required": false, "default": 50},
        {"name": "pageCursor", "type": "string", "description": "Cursor for pagination", "required": false}
      ]
    },
    {
      "id": "list_evidence",
      "name": "List Evidence Documents",
      "description": "List uploaded evidence documents",
      "http_method": "GET",
      "endpoint": "/documents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "pageSize", "type": "number", "description": "Results per page", "required": false, "default": 50},
        {"name": "pageCursor", "type": "string", "description": "Cursor for pagination", "required": false}
      ]
    },
    {
      "id": "list_resources",
      "name": "List Resources",
      "description": "List monitored resources and their compliance status",
      "http_method": "GET",
      "endpoint": "/resources",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "resourceType", "type": "string", "description": "Filter by resource type", "required": false},
        {"name": "pageSize", "type": "number", "description": "Results per page", "required": false, "default": 50},
        {"name": "pageCursor", "type": "string", "description": "Cursor for pagination", "required": false}
      ]
    },
    {
      "id": "list_people",
      "name": "List People",
      "description": "List personnel and their compliance status",
      "http_method": "GET",
      "endpoint": "/people",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "pageSize", "type": "number", "description": "Results per page", "required": false, "default": 50},
        {"name": "pageCursor", "type": "string", "description": "Cursor for pagination", "required": false}
      ]
    }
  ]
}
