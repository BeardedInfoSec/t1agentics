{
  "id": "exabeam_secops",
  "name": "Exabeam SecOps",
  "description": "Exabeam Security Operations Platform combining SIEM, UEBA, and SOAR for incident response, case management, and automated security workflows via OAuth2-authenticated REST API.",
  "version": "1.0.0",
  "category": "soar",
  "vendor": "Exabeam",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "token_url": "https://{host}/auth/v1/token",
    "header_name": "Authorization",
    "location": "header",
    "token_prefix": "Bearer"
  },
  "base_url": "https://{host}/api/v1",
  "actions": [
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "Retrieve a list of incidents sorted by creation time.",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "page", "type": "integer", "description": "Page number.", "required": false},
        {"name": "limit", "type": "integer", "description": "Results per page.", "required": false},
        {"name": "status", "type": "string", "description": "Filter by status: 'new', 'inProgress', 'closed', 'noncredible'.", "required": false},
        {"name": "priority", "type": "string", "description": "Filter by priority.", "required": false},
        {"name": "startTime", "type": "string", "description": "Start time filter in ISO 8601.", "required": false},
        {"name": "endTime", "type": "string", "description": "End time filter in ISO 8601.", "required": false}
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident",
      "description": "Retrieve details of a specific incident.",
      "http_method": "GET",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true}
      ]
    },
    {
      "id": "create_incident",
      "name": "Create Incident",
      "description": "Create a new security incident.",
      "http_method": "POST",
      "endpoint": "/incidents",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "name", "type": "string", "description": "Incident name.", "required": true},
        {"name": "description", "type": "string", "description": "Incident description.", "required": false},
        {"name": "priority", "type": "string", "description": "Priority: 'low', 'medium', 'high', 'critical'.", "required": false},
        {"name": "type", "type": "string", "description": "Incident type.", "required": false},
        {"name": "assignee", "type": "string", "description": "Assigned analyst.", "required": false},
        {"name": "source", "type": "string", "description": "Incident source.", "required": false}
      ]
    },
    {
      "id": "update_incident",
      "name": "Update Incident",
      "description": "Update an existing incident.",
      "http_method": "PUT",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true},
        {"name": "name", "type": "string", "description": "Updated name.", "required": false},
        {"name": "status", "type": "string", "description": "Updated status.", "required": false},
        {"name": "priority", "type": "string", "description": "Updated priority.", "required": false},
        {"name": "assignee", "type": "string", "description": "Updated assignee.", "required": false}
      ]
    },
    {
      "id": "close_incident",
      "name": "Close Incident",
      "description": "Close an incident with resolution details.",
      "http_method": "PUT",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true},
        {"name": "status", "type": "string", "description": "Set to 'closed'.", "required": true},
        {"name": "resolution", "type": "string", "description": "Resolution summary.", "required": true},
        {"name": "closureReason", "type": "string", "description": "Reason for closure.", "required": false}
      ]
    },
    {
      "id": "list_cases",
      "name": "List Cases",
      "description": "Retrieve a list of investigation cases.",
      "http_method": "GET",
      "endpoint": "/cases",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "page", "type": "integer", "description": "Page number.", "required": false},
        {"name": "limit", "type": "integer", "description": "Results per page.", "required": false},
        {"name": "status", "type": "string", "description": "Filter by status.", "required": false}
      ]
    },
    {
      "id": "get_case",
      "name": "Get Case",
      "description": "Retrieve details of a specific case.",
      "http_method": "GET",
      "endpoint": "/cases/{caseId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "caseId", "type": "string", "description": "The case ID.", "required": true}
      ]
    },
    {
      "id": "run_playbook",
      "name": "Run Playbook",
      "description": "Execute an automated playbook on an incident.",
      "http_method": "POST",
      "endpoint": "/playbooks/{playbookId}/execute",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "playbookId", "type": "string", "description": "The playbook ID.", "required": true},
        {"name": "incidentId", "type": "string", "description": "Target incident ID.", "required": false},
        {"name": "parameters", "type": "object", "description": "Input parameters.", "required": false}
      ]
    },
    {
      "id": "add_comment",
      "name": "Add Comment",
      "description": "Add a comment to an incident.",
      "http_method": "POST",
      "endpoint": "/incidents/{incidentId}/comments",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true},
        {"name": "comment", "type": "string", "description": "Comment text.", "required": true}
      ]
    },
    {
      "id": "search_users",
      "name": "Search Users",
      "description": "Search for users in the UEBA model for investigation.",
      "http_method": "GET",
      "endpoint": "/users/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "query", "type": "string", "description": "Search query string.", "required": true},
        {"name": "limit", "type": "integer", "description": "Maximum results.", "required": false}
      ]
    }
  ]
}
