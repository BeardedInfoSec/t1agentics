{
  "id": "swimlane",
  "name": "Swimlane",
  "description": "Low-code security automation platform for managing applications, records (cases), and automated workflows across security operations.",
  "version": "1.0.0",
  "category": "soar",
  "vendor": "Swimlane",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "location": "header",
    "token_prefix": "Bearer"
  },
  "base_url": "https://{host}/api",
  "actions": [
    {
      "id": "list_applications",
      "name": "List Applications",
      "description": "Retrieve a list of all applications configured in Swimlane.",
      "http_method": "GET",
      "endpoint": "/app",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "get_application",
      "name": "Get Application",
      "description": "Retrieve details of a specific application by ID.",
      "http_method": "GET",
      "endpoint": "/app/{appId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "appId", "type": "string", "description": "The application ID.", "required": true}
      ]
    },
    {
      "id": "list_records",
      "name": "List Records",
      "description": "Retrieve records from a specific application with optional filtering.",
      "http_method": "GET",
      "endpoint": "/app/{appId}/record",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "appId", "type": "string", "description": "The application ID.", "required": true},
        {"name": "limit", "type": "integer", "description": "Maximum number of records to return.", "required": false},
        {"name": "offset", "type": "integer", "description": "Number of records to skip.", "required": false},
        {"name": "sort", "type": "string", "description": "Field ID to sort by.", "required": false},
        {"name": "order", "type": "string", "description": "Sort order: 'asc' or 'desc'.", "required": false}
      ]
    },
    {
      "id": "get_record",
      "name": "Get Record",
      "description": "Retrieve a specific record (case/incident) by its ID.",
      "http_method": "GET",
      "endpoint": "/app/{appId}/record/{recordId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "appId", "type": "string", "description": "The application ID.", "required": true},
        {"name": "recordId", "type": "string", "description": "The record ID.", "required": true}
      ]
    },
    {
      "id": "create_record",
      "name": "Create Record",
      "description": "Create a new record (case/incident) in an application.",
      "http_method": "POST",
      "endpoint": "/app/{appId}/record",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "appId", "type": "string", "description": "The application ID.", "required": true},
        {"name": "values", "type": "object", "description": "Object of field ID-value pairs for the record.", "required": true}
      ]
    },
    {
      "id": "update_record",
      "name": "Update Record",
      "description": "Update an existing record's field values.",
      "http_method": "PUT",
      "endpoint": "/app/{appId}/record/{recordId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "appId", "type": "string", "description": "The application ID.", "required": true},
        {"name": "recordId", "type": "string", "description": "The record ID to update.", "required": true},
        {"name": "values", "type": "object", "description": "Object of field ID-value pairs to update.", "required": true}
      ]
    },
    {
      "id": "delete_record",
      "name": "Delete Record",
      "description": "Delete a record from an application.",
      "http_method": "DELETE",
      "endpoint": "/app/{appId}/record/{recordId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "appId", "type": "string", "description": "The application ID.", "required": true},
        {"name": "recordId", "type": "string", "description": "The record ID to delete.", "required": true}
      ]
    },
    {
      "id": "search_records",
      "name": "Search Records",
      "description": "Search for records using filter criteria and keywords.",
      "http_method": "POST",
      "endpoint": "/app/{appId}/record/search",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "appId", "type": "string", "description": "The application ID.", "required": true},
        {"name": "filters", "type": "array", "description": "Array of filter objects with field ID, operator, and value.", "required": false},
        {"name": "keywords", "type": "string", "description": "Keywords to search for across records.", "required": false},
        {"name": "limit", "type": "integer", "description": "Maximum results to return.", "required": false},
        {"name": "offset", "type": "integer", "description": "Records to skip.", "required": false},
        {"name": "sort", "type": "object", "description": "Sort configuration with field ID and order.", "required": false}
      ]
    },
    {
      "id": "bulk_modify_records",
      "name": "Bulk Modify Records",
      "description": "Modify multiple records at once using filter criteria.",
      "http_method": "PUT",
      "endpoint": "/app/{appId}/record/batch",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "appId", "type": "string", "description": "The application ID.", "required": true},
        {"name": "recordIds", "type": "array", "description": "Array of record IDs to modify.", "required": true},
        {"name": "values", "type": "object", "description": "Field values to apply to all specified records.", "required": true}
      ]
    },
    {
      "id": "list_tasks",
      "name": "List Tasks",
      "description": "List workflow tasks and their statuses.",
      "http_method": "GET",
      "endpoint": "/task",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "status", "type": "string", "description": "Filter by task status.", "required": false},
        {"name": "limit", "type": "integer", "description": "Maximum results to return.", "required": false}
      ]
    },
    {
      "id": "list_users",
      "name": "List Users",
      "description": "Retrieve a list of all users in Swimlane.",
      "http_method": "GET",
      "endpoint": "/user",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "add_comment",
      "name": "Add Comment",
      "description": "Add a comment to a record.",
      "http_method": "POST",
      "endpoint": "/app/{appId}/record/{recordId}/comment",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "appId", "type": "string", "description": "The application ID.", "required": true},
        {"name": "recordId", "type": "string", "description": "The record ID.", "required": true},
        {"name": "message", "type": "string", "description": "Comment text.", "required": true}
      ]
    }
  ]
}
