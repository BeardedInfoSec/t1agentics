{
  "id": "devo_soar",
  "name": "Devo SOAR",
  "description": "Devo security orchestration and automation platform (formerly LogicHub) for automated threat response, playbook execution, and incident management.",
  "version": "1.0.0",
  "category": "soar",
  "vendor": "Devo",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "location": "header",
    "token_prefix": "Bearer"
  },
  "base_url": "https://{host}/api/v1",
  "actions": [
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "Retrieve a list of security incidents.",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "page", "type": "integer", "description": "Page number.", "required": false},
        {"name": "limit", "type": "integer", "description": "Results per page.", "required": false},
        {"name": "status", "type": "string", "description": "Filter by status: 'open', 'closed', 'in_progress'.", "required": false},
        {"name": "severity", "type": "string", "description": "Filter by severity.", "required": false},
        {"name": "startDate", "type": "string", "description": "Start date in ISO 8601.", "required": false},
        {"name": "endDate", "type": "string", "description": "End date in ISO 8601.", "required": false}
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident",
      "description": "Retrieve details of a specific incident.",
      "http_method": "GET",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true}
      ]
    },
    {
      "id": "create_incident",
      "name": "Create Incident",
      "description": "Create a new security incident.",
      "http_method": "POST",
      "endpoint": "/incidents",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "name", "type": "string", "description": "Incident name.", "required": true},
        {"name": "description", "type": "string", "description": "Incident description.", "required": false},
        {"name": "severity", "type": "string", "description": "Severity: 'low', 'medium', 'high', 'critical'.", "required": false},
        {"name": "type", "type": "string", "description": "Incident type.", "required": false},
        {"name": "assignee", "type": "string", "description": "Assigned user.", "required": false},
        {"name": "source", "type": "string", "description": "Source of the incident.", "required": false}
      ]
    },
    {
      "id": "update_incident",
      "name": "Update Incident",
      "description": "Update an existing incident.",
      "http_method": "PUT",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true},
        {"name": "name", "type": "string", "description": "Updated name.", "required": false},
        {"name": "severity", "type": "string", "description": "Updated severity.", "required": false},
        {"name": "status", "type": "string", "description": "Updated status.", "required": false},
        {"name": "assignee", "type": "string", "description": "Updated assignee.", "required": false}
      ]
    },
    {
      "id": "close_incident",
      "name": "Close Incident",
      "description": "Close an incident with resolution details.",
      "http_method": "PUT",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true},
        {"name": "status", "type": "string", "description": "Set to 'closed'.", "required": true},
        {"name": "resolution", "type": "string", "description": "Resolution summary.", "required": false}
      ]
    },
    {
      "id": "run_playbook",
      "name": "Run Playbook",
      "description": "Execute an automation playbook.",
      "http_method": "POST",
      "endpoint": "/playbooks/{playbookId}/execute",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "playbookId", "type": "string", "description": "The playbook ID.", "required": true},
        {"name": "input", "type": "object", "description": "Input parameters for the playbook.", "required": false},
        {"name": "incidentId", "type": "string", "description": "Incident ID to associate with.", "required": false}
      ]
    },
    {
      "id": "list_playbooks",
      "name": "List Playbooks",
      "description": "Retrieve a list of available playbooks.",
      "http_method": "GET",
      "endpoint": "/playbooks",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "page", "type": "integer", "description": "Page number.", "required": false},
        {"name": "limit", "type": "integer", "description": "Results per page.", "required": false}
      ]
    },
    {
      "id": "get_playbook_status",
      "name": "Get Playbook Status",
      "description": "Retrieve the execution status of a playbook run.",
      "http_method": "GET",
      "endpoint": "/playbooks/executions/{executionId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "executionId", "type": "string", "description": "The execution ID.", "required": true}
      ]
    },
    {
      "id": "add_artifact",
      "name": "Add Artifact",
      "description": "Add an artifact/observable to an incident.",
      "http_method": "POST",
      "endpoint": "/incidents/{incidentId}/artifacts",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incidentId", "type": "string", "description": "The incident ID.", "required": true},
        {"name": "type", "type": "string", "description": "Artifact type (IP, Domain, Hash, URL).", "required": true},
        {"name": "value", "type": "string", "description": "Artifact value.", "required": true},
        {"name": "description", "type": "string", "description": "Description.", "required": false}
      ]
    },
    {
      "id": "query_data",
      "name": "Query Data",
      "description": "Execute a query against Devo data tables.",
      "http_method": "POST",
      "endpoint": "/search/query",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "query", "type": "string", "description": "LINQ query string.", "required": true},
        {"name": "from", "type": "string", "description": "Start time in ISO 8601.", "required": true},
        {"name": "to", "type": "string", "description": "End time in ISO 8601.", "required": true},
        {"name": "limit", "type": "integer", "description": "Maximum results.", "required": false}
      ]
    }
  ]
}
