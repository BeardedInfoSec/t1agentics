{
  "id": "azure_defender_identity",
  "name": "Microsoft Defender for Identity",
  "description": "Cloud-based security solution leveraging Active Directory signals to identify, detect, and investigate advanced threats, compromised identities, and insider actions",
  "version": "1.0.0",
  "category": "azure_security",
  "vendor": "Microsoft Azure",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "token_url": "https://login.microsoftonline.com/{tenantId}/oauth2/v2.0/token",
    "scope": "https://graph.microsoft.com/.default",
    "grant_type": "client_credentials"
  },
  "base_url": "https://graph.microsoft.com/v1.0/security",
  "actions": [
    {
      "id": "list_alerts",
      "name": "List Identity Alerts",
      "description": "List identity-related security alerts from Defender for Identity",
      "http_method": "GET",
      "endpoint": "/alerts_v2",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "$filter",
          "type": "string",
          "description": "OData filter (e.g., \"serviceSource eq 'microsoftDefenderForIdentity' and severity eq 'high'\")",
          "required": false
        },
        {
          "name": "$top",
          "type": "number",
          "description": "Maximum alerts to return",
          "required": false,
          "default": 100
        },
        {
          "name": "$orderby",
          "type": "string",
          "description": "Order by expression (e.g., \"createdDateTime desc\")",
          "required": false
        },
        {
          "name": "$skip",
          "type": "number",
          "description": "Number of records to skip for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "get_alert",
      "name": "Get Alert Details",
      "description": "Retrieve detailed information about a specific identity alert",
      "http_method": "GET",
      "endpoint": "/alerts_v2/{alertId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "alertId",
          "type": "string",
          "description": "The unique identifier of the alert",
          "required": true
        }
      ]
    },
    {
      "id": "list_incidents",
      "name": "List Security Incidents",
      "description": "List correlated security incidents involving identity threats",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "$filter",
          "type": "string",
          "description": "OData filter expression",
          "required": false
        },
        {
          "name": "$top",
          "type": "number",
          "description": "Maximum incidents to return",
          "required": false,
          "default": 100
        },
        {
          "name": "$orderby",
          "type": "string",
          "description": "Order by expression",
          "required": false
        }
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident Details",
      "description": "Retrieve detailed information about a specific security incident",
      "http_method": "GET",
      "endpoint": "/incidents/{incidentId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "incidentId",
          "type": "string",
          "description": "The unique identifier of the incident",
          "required": true
        }
      ]
    },
    {
      "id": "list_health_issues",
      "name": "List Health Issues",
      "description": "List Defender for Identity sensor health issues",
      "http_method": "GET",
      "endpoint": "/identities/healthIssues",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "$filter",
          "type": "string",
          "description": "OData filter expression",
          "required": false
        },
        {
          "name": "$top",
          "type": "number",
          "description": "Maximum issues to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "update_alert",
      "name": "Update Alert",
      "description": "Update the status or classification of a security alert",
      "http_method": "PATCH",
      "endpoint": "/alerts_v2/{alertId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "alertId",
          "type": "string",
          "description": "The unique identifier of the alert",
          "required": true
        },
        {
          "name": "status",
          "type": "string",
          "description": "New status (new, inProgress, resolved)",
          "required": false
        },
        {
          "name": "classification",
          "type": "string",
          "description": "Classification (truePositive, falsePositive, benignPositive)",
          "required": false
        },
        {
          "name": "assignedTo",
          "type": "string",
          "description": "User to assign the alert to",
          "required": false
        }
      ]
    }
  ]
}