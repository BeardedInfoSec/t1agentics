  "base_url": "https://api.ti.insight.rapid7.com/public/v1",
  "actions": [
    {
      "id": "hunt_ioc",
      "name": "Hunt Ioc",
      "description": "Look for information about an ioc in the Intsights database",
      "http_method": "GET",
      "endpoint": "/actions/hunt_ioc",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "hunting",
          "type": "string",
          "description": "Look for information about an ioc in the Intsights database",
          "required": true
        }
      ]
    },
    {
      "id": "enrich_ioc",
      "name": "Enrich Ioc",
      "description": "Get enrichment information on IOC using the (paid) enrich API endpoint",
      "http_method": "GET",
      "endpoint": "/actions/enrich_ioc",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "ioc",
          "type": "string",
          "description": "The IOC to enrich",
          "required": true
        },
        {
          "name": "max_poll_cycles",
          "type": "number",
          "description": "The maximum amount of poll cycles to wait before erroring out",
          "required": true,
          "default": 15
        },
        {
          "name": "sleep_seconds",
          "type": "number",
          "description": "The amount of seconds to sleep before trying to poll the endpoint again for results",
          "required": true,
          "default": 2
        }
      ]
    },
    {
      "id": "hunt_file",
      "name": "Hunt File",
      "description": "Look for information about a file hash in the Intsights database",
