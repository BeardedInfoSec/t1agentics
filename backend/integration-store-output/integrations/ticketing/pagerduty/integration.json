{
  "id": "pagerduty",
  "name": "PagerDuty",
  "description": "Integrates with PagerDuty REST API v2 for incident management, on-call scheduling, and alert routing for digital operations",
  "version": "1.0.0",
  "category": "ticketing",
  "vendor": "PagerDuty",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header",
    "prefix": "Token token="
  },
  "base_url": "https://api.pagerduty.com",
  "actions": [
    {
      "id": "create_incident",
      "name": "Create Incident",
      "description": "Create a new incident in PagerDuty",
      "http_method": "POST",
      "endpoint": "/incidents",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "title", "type": "string", "description": "Title of the incident", "required": true},
        {"name": "service_id", "type": "string", "description": "ID of the service the incident is associated with", "required": true},
        {"name": "urgency", "type": "string", "description": "Urgency level (high or low)", "required": false, "default": "high"},
        {"name": "body", "type": "string", "description": "Detailed description of the incident", "required": false},
        {"name": "escalation_policy_id", "type": "string", "description": "ID of the escalation policy to use", "required": false},
        {"name": "from", "type": "string", "description": "Email address of the user creating the incident (required header)", "required": true}
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident",
      "description": "Retrieve details of a specific PagerDuty incident",
      "http_method": "GET",
      "endpoint": "/incidents/{id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "id", "type": "string", "description": "Incident ID", "required": true}
      ]
    },
    {
      "id": "update_incident",
      "name": "Update Incident",
      "description": "Update an existing PagerDuty incident (acknowledge, resolve, reassign)",
      "http_method": "PUT",
      "endpoint": "/incidents/{id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "id", "type": "string", "description": "Incident ID to update", "required": true},
        {"name": "status", "type": "string", "description": "New status (acknowledged or resolved)", "required": false},
        {"name": "title", "type": "string", "description": "Updated incident title", "required": false},
        {"name": "urgency", "type": "string", "description": "Updated urgency (high or low)", "required": false},
        {"name": "escalation_policy_id", "type": "string", "description": "New escalation policy ID", "required": false},
        {"name": "from", "type": "string", "description": "Email address of the user making the update", "required": true}
      ]
    },
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "List incidents filtered by status, urgency, date range, or service",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "statuses[]", "type": "string", "description": "Filter by status (triggered, acknowledged, resolved)", "required": false},
        {"name": "service_ids[]", "type": "string", "description": "Filter by service IDs (comma-separated)", "required": false},
        {"name": "since", "type": "string", "description": "Start date filter in ISO 8601 format", "required": false},
        {"name": "until", "type": "string", "description": "End date filter in ISO 8601 format", "required": false},
        {"name": "urgencies[]", "type": "string", "description": "Filter by urgency (high, low)", "required": false},
        {"name": "limit", "type": "number", "description": "Number of results per page", "required": false, "default": 25},
        {"name": "offset", "type": "number", "description": "Pagination offset", "required": false, "default": 0}
      ]
    },
    {
      "id": "add_note",
      "name": "Add Note",
      "description": "Add a note to an existing incident",
      "http_method": "POST",
      "endpoint": "/incidents/{id}/notes",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "id", "type": "string", "description": "Incident ID", "required": true},
        {"name": "content", "type": "string", "description": "Content of the note", "required": true},
        {"name": "from", "type": "string", "description": "Email address of the user adding the note", "required": true}
      ]
    },
    {
      "id": "resolve_incident",
      "name": "Resolve Incident",
      "description": "Resolve a PagerDuty incident",
      "http_method": "PUT",
      "endpoint": "/incidents/{id}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "id", "type": "string", "description": "Incident ID to resolve", "required": true},
        {"name": "resolution", "type": "string", "description": "Resolution summary", "required": false},
        {"name": "from", "type": "string", "description": "Email address of the user resolving the incident", "required": true}
      ]
    }
  ]
}
