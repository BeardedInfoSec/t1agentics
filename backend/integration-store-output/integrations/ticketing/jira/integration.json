{
  "id": "jira",
  "name": "Jira",
  "description": "Integration with Jira for security operations",
  "version": "1.0.0",
  "category": "ticketing",
  "vendor": "Atlassian",
  "auth_type": "basic_auth",
  "auth_config": {
    "type": "basic_auth",
    "username_field": "username",
    "password_field": "password"
  },
  "base_url": "",
  "actions": [
    {
      "id": "create_issue",
      "name": "Create Jira Issue",
      "http_method": "POST",
      "endpoint": "/rest/api/3/issue",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Create a new Jira issue/ticket",
      "observable_type": "investigation"
    },
    {
      "id": "update_issue",
      "name": "Update Jira Issue",
      "http_method": "PUT",
      "endpoint": "/rest/api/3/issue/{issue_key}",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Update an existing Jira issue"
    },
    {
      "id": "add_comment",
      "name": "Add Comment to Issue",
      "http_method": "POST",
      "endpoint": "/rest/api/3/issue/{issue_key}/comment",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Add a comment to a Jira issue"
    },
    {
      "id": "get_issue",
      "name": "Get Jira Issue",
      "http_method": "GET",
      "endpoint": "/rest/api/3/issue/{issue_key}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Get details of a Jira issue"
    }
  ]
}