{
  "id": "incident_io",
  "name": "incident.io",
  "description": "Integrates with incident.io REST API v2 for incident declaration, management, and post-incident analysis",
  "version": "1.0.0",
  "category": "ticketing",
  "vendor": "incident.io",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://api.incident.io/v2",
  "actions": [
    {
      "id": "create_incident",
      "name": "Create Incident",
      "description": "Create a new incident in incident.io",
      "http_method": "POST",
      "endpoint": "/incidents",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "name", "type": "string", "description": "Incident name/title", "required": true},
        {"name": "idempotency_key", "type": "string", "description": "Unique key to prevent duplicate creation", "required": true},
        {"name": "severity_id", "type": "string", "description": "Severity level ID", "required": true},
        {"name": "visibility", "type": "string", "description": "Visibility (public or private)", "required": true},
        {"name": "summary", "type": "string", "description": "Incident summary", "required": false},
        {"name": "incident_type_id", "type": "string", "description": "Incident type ID", "required": false},
        {"name": "mode", "type": "string", "description": "Incident mode (standard, retrospective, tutorial, test)", "required": false, "default": "standard"},
        {"name": "slack_channel_name_override", "type": "string", "description": "Custom Slack channel name", "required": false}
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident",
      "description": "Retrieve details of a specific incident",
      "http_method": "GET",
      "endpoint": "/incidents/{id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "id", "type": "string", "description": "Incident ID", "required": true}
      ]
    },
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "List and filter incidents",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "status_category[one_of]", "type": "string", "description": "Filter by status category (active, triage, declined, merged, canceled, live, learning, closed)", "required": false},
        {"name": "severity[one_of]", "type": "string", "description": "Filter by severity IDs", "required": false},
        {"name": "page_size", "type": "number", "description": "Results per page", "required": false, "default": 25},
        {"name": "after", "type": "string", "description": "Pagination cursor", "required": false}
      ]
    },
    {
      "id": "update_incident",
      "name": "Update Incident",
      "description": "Update an existing incident",
      "http_method": "PUT",
      "endpoint": "/incidents/{id}/actions/edit",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "id", "type": "string", "description": "Incident ID to update", "required": true},
        {"name": "name", "type": "string", "description": "Updated incident name", "required": false},
        {"name": "summary", "type": "string", "description": "Updated summary", "required": false},
        {"name": "severity_id", "type": "string", "description": "Updated severity ID", "required": false},
        {"name": "incident_type_id", "type": "string", "description": "Updated incident type ID", "required": false}
      ]
    },
    {
      "id": "create_update",
      "name": "Create Incident Update",
      "description": "Post a status update to an incident",
      "http_method": "POST",
      "endpoint": "/incident_updates",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incident_id", "type": "string", "description": "Incident ID", "required": true},
        {"name": "message", "type": "string", "description": "Update message in Slack-flavored markdown", "required": true},
        {"name": "new_status_id", "type": "string", "description": "New incident status ID", "required": false}
      ]
    },
    {
      "id": "list_severities",
      "name": "List Severities",
      "description": "List all configured severity levels",
      "http_method": "GET",
      "endpoint": "/severities",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    }
  ]
}
