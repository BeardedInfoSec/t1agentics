{
  "id": "servicenow",
  "name": "ServiceNow",
  "description": "Integration with ServiceNow for security operations",
  "version": "1.0.0",
  "category": "ticketing",
  "vendor": "ServiceNow",
  "auth_type": "basic_auth",
  "auth_config": {
    "type": "basic_auth",
    "username_field": "username",
    "password_field": "password"
  },
  "base_url": "",
  "actions": [
    {
      "id": "create_incident",
      "name": "Create Incident",
      "http_method": "POST",
      "endpoint": "/api/now/table/incident",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Create a new ServiceNow incident"
    },
    {
      "id": "create_security_incident",
      "name": "Create Security Incident",
      "http_method": "POST",
      "endpoint": "/api/now/table/sn_si_incident",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Create a security incident in ServiceNow SecOps"
    }
  ]
}