{
  "id": "squadcast",
  "name": "Squadcast",
  "description": "Integrates with Squadcast REST API v3 for incident management, alerting, and on-call scheduling for SRE and DevOps teams",
  "version": "1.0.0",
  "category": "ticketing",
  "vendor": "Squadcast",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://api.squadcast.com/v3",
  "actions": [
    {
      "id": "create_incident",
      "name": "Create Incident",
      "description": "Create a new incident in Squadcast",
      "http_method": "POST",
      "endpoint": "/incidents",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "message", "type": "string", "description": "Incident message/title", "required": true},
        {"name": "description", "type": "string", "description": "Detailed description of the incident", "required": false},
        {"name": "service_id", "type": "string", "description": "Service ID to create the incident for", "required": true},
        {"name": "priority", "type": "string", "description": "Priority level (P1, P2, P3, P4, P5)", "required": false},
        {"name": "tags", "type": "string", "description": "JSON object of tags with key-value pairs", "required": false}
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident",
      "description": "Retrieve details of a specific Squadcast incident",
      "http_method": "GET",
      "endpoint": "/incidents/{incident_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "incident_id", "type": "string", "description": "Incident ID", "required": true}
      ]
    },
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "List and filter Squadcast incidents",
      "http_method": "GET",
      "endpoint": "/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {"name": "status", "type": "string", "description": "Filter by status (triggered, acknowledged, resolved, suppressed)", "required": false},
        {"name": "service_id", "type": "string", "description": "Filter by service ID", "required": false},
        {"name": "page", "type": "number", "description": "Page number", "required": false, "default": 1},
        {"name": "per_page", "type": "number", "description": "Results per page", "required": false, "default": 20}
      ]
    },
    {
      "id": "acknowledge_incident",
      "name": "Acknowledge Incident",
      "description": "Acknowledge a Squadcast incident",
      "http_method": "PUT",
      "endpoint": "/incidents/{incident_id}/ack",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incident_id", "type": "string", "description": "Incident ID to acknowledge", "required": true}
      ]
    },
    {
      "id": "resolve_incident",
      "name": "Resolve Incident",
      "description": "Resolve a Squadcast incident",
      "http_method": "PUT",
      "endpoint": "/incidents/{incident_id}/resolve",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {"name": "incident_id", "type": "string", "description": "Incident ID to resolve", "required": true}
      ]
    },
    {
      "id": "list_services",
      "name": "List Services",
      "description": "List all services in the organization",
      "http_method": "GET",
      "endpoint": "/services",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    }
  ]
}
