{
  "id": "koodous",
  "name": "Koodous",
  "description": "This app integrates with Koodous to analyze APK files",
  "version": "2.1.1",
  "category": "sandbox",
  "vendor": "Koodous",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "location": "header",
    "header_name": "Authorization",
    "prefix": "Token "
  },
  "base_url": "https://developer.koodous.com",
  "actions": [
    {
      "id": "detonate_file",
      "name": "Detonate File",
      "description": "Run the file in the sandbox and retrieve the analysis results",
      "http_method": "GET",
      "endpoint": "/actions/detonate_file",
      "action_type": "generic",
      "read_only": false,
      "cacheable": false,
      "cache_ttl_days": 0,
      "parameters": [
        {
          "name": "vault_id",
          "type": "string",
          "description": "Vault ID of file to detonate",
          "required": true,
          "contains": [
            "vault id",
            "sha1"
          ]
        },
        {
          "name": "analysis_type",
          "type": "string",
          "description": "Type of analysis",
          "required": false,
          "default": "all"
        },
        {
          "name": "attempts",
          "type": "number",
          "description": "Number of attempts to make while polling",
          "required": false,
          "default": 10
        },
        {
          "name": "force_yara_analysis",
          "type": "boolean",
          "description": "Perform Yara analysis",
          "required": false,
          "default": false
        }
      ],
      "observable_type": "file_hash"
    },
    {
      "id": "get_report",
      "name": "Get Report",
      "description": "Query for results of an already completed detonation",
      "http_method": "GET",
      "endpoint": "/actions/get_report",
      "action_type": "investigate",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "parameters": [
        {
          "name": "sha256",
          "type": "string",
          "description": "SHA256 hash of file to get analysis of",
          "required": false,
          "contains": [
            "sha256"
          ]
        },
        {
          "name": "vault_id",
          "type": "string",
          "description": "Vault ID, will check if there is an existing report for this file",
          "required": false,
          "contains": [
            "vault id",
            "sha1"
          ]
        },
        {
          "name": "attempts",
          "type": "number",
          "description": "Number of attempts to make while polling",
          "required": false,
          "default": 1
        }
      ],
      "observable_type": "file_hash"
    }
  ],
  "source_metadata": {
    "original_name": "Koodous",
    "original_type": "sandbox",
    "converted_at": "2025-12-18T16:25:28.898202",
    "source_version": "2.1.1"
  }
}