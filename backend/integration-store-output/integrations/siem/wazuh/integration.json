{
  "id": "wazuh",
  "name": "Wazuh",
  "description": "Integrates with the open-source Wazuh SIEM/XDR platform for agent management, alert retrieval, security configuration assessment, file integrity monitoring, and vulnerability detection via the Wazuh Server REST API",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "Wazuh",
  "auth_type": "bearer",
  "auth_config": {
    "type": "bearer",
    "header_name": "Authorization",
    "prefix": "Bearer",
    "location": "header"
  },
  "base_url": "https://{host}:55000",
  "actions": [
    {
      "id": "authenticate",
      "name": "Authenticate",
      "description": "Authenticate and obtain a JWT token for subsequent API calls",
      "http_method": "POST",
      "endpoint": "/security/user/authenticate",
      "action_type": "generic",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "list_agents",
      "name": "List Agents",
      "description": "Retrieve a list of all Wazuh agents with their status and metadata",
      "http_method": "GET",
      "endpoint": "/agents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "status",
          "type": "string",
          "description": "Filter by agent status (active, disconnected, never_connected, pending)",
          "required": false
        },
        {
          "name": "q",
          "type": "string",
          "description": "Query filter in Wazuh API query format",
          "required": false
        },
        {
          "name": "select",
          "type": "string",
          "description": "Comma-separated list of fields to return",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum agents to return",
          "required": false,
          "default": 500
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        },
        {
          "name": "sort",
          "type": "string",
          "description": "Sort criteria (e.g., +name or -lastKeepAlive)",
          "required": false
        }
      ]
    },
    {
      "id": "get_agent",
      "name": "Get Agent Details",
      "description": "Retrieve details for a specific Wazuh agent by ID",
      "http_method": "GET",
      "endpoint": "/agents/{agent_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "agent_id",
          "type": "string",
          "description": "Agent ID to retrieve (e.g., 001)",
          "required": true
        },
        {
          "name": "select",
          "type": "string",
          "description": "Comma-separated fields to return",
          "required": false
        }
      ]
    },
    {
      "id": "get_alerts",
      "name": "Get Alerts",
      "description": "Retrieve security alerts from the Wazuh manager",
      "http_method": "GET",
      "endpoint": "/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "q",
          "type": "string",
          "description": "Query filter (e.g., rule.level>10)",
          "required": false
        },
        {
          "name": "select",
          "type": "string",
          "description": "Comma-separated fields to return",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum alerts to return",
          "required": false,
          "default": 500
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        },
        {
          "name": "sort",
          "type": "string",
          "description": "Sort criteria",
          "required": false
        }
      ]
    },
    {
      "id": "restart_agent",
      "name": "Restart Agent",
      "description": "Restart a Wazuh agent by ID",
      "http_method": "PUT",
      "endpoint": "/agents/{agent_id}/restart",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "agent_id",
          "type": "string",
          "description": "Agent ID to restart",
          "required": true
        }
      ]
    },
    {
      "id": "get_sca_results",
      "name": "Get SCA Results",
      "description": "Retrieve Security Configuration Assessment (SCA) scan results for an agent",
      "http_method": "GET",
      "endpoint": "/sca/{agent_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "agent_id",
          "type": "string",
          "description": "Agent ID to retrieve SCA results for",
          "required": true
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum results to return",
          "required": false,
          "default": 500
        }
      ]
    },
    {
      "id": "get_fim_files",
      "name": "Get FIM Files",
      "description": "Retrieve File Integrity Monitoring (FIM) data for an agent",
      "http_method": "GET",
      "endpoint": "/syscheck/{agent_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "agent_id",
          "type": "string",
          "description": "Agent ID to retrieve FIM data for",
          "required": true
        },
        {
          "name": "q",
          "type": "string",
          "description": "Query filter for FIM results",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum results to return",
          "required": false,
          "default": 500
        }
      ]
    },
    {
      "id": "get_vulnerabilities",
      "name": "Get Vulnerabilities",
      "description": "Retrieve vulnerability detection results for an agent",
      "http_method": "GET",
      "endpoint": "/vulnerability/{agent_id}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "agent_id",
          "type": "string",
          "description": "Agent ID to retrieve vulnerabilities for",
          "required": true
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity (Critical, High, Medium, Low)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum results to return",
          "required": false,
          "default": 500
        }
      ]
    },
    {
      "id": "get_manager_stats",
      "name": "Get Manager Stats",
      "description": "Retrieve Wazuh manager statistics and health information",
      "http_method": "GET",
      "endpoint": "/manager/stats",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "date",
          "type": "string",
          "description": "Date for statistics (YYYY-MM-DD format)",
          "required": false
        }
      ]
    }
  ]
}
