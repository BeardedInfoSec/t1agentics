{
  "id": "netwitness",
  "name": "NetWitness",
  "description": "Integrates with RSA NetWitness Platform for incident management, alert retrieval, event investigation, and host snapshot collection via the NetWitness REST API",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "RSA (NetWitness)",
  "auth_type": "basic",
  "auth_config": {
    "type": "basic",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://{host}:443",
  "actions": [
    {
      "id": "authenticate",
      "name": "Authenticate",
      "description": "Authenticate with NetWitness and obtain a session token",
      "http_method": "POST",
      "endpoint": "/rest/api/auth/userpass",
      "action_type": "generic",
      "read_only": true,
      "parameters": [
        {
          "name": "username",
          "type": "string",
          "description": "NetWitness username",
          "required": true
        },
        {
          "name": "password",
          "type": "string",
          "description": "NetWitness password",
          "required": true
        }
      ]
    },
    {
      "id": "list_incidents",
      "name": "List Incidents",
      "description": "Retrieve incidents from NetWitness Respond",
      "http_method": "GET",
      "endpoint": "/rest/api/incidents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "since",
          "type": "string",
          "description": "Retrieve incidents since this datetime (ISO 8601)",
          "required": false
        },
        {
          "name": "until",
          "type": "string",
          "description": "Retrieve incidents until this datetime",
          "required": false
        },
        {
          "name": "status",
          "type": "string",
          "description": "Filter by incident status (New, Assigned, InProgress, Remediation, Closed)",
          "required": false
        },
        {
          "name": "pageNumber",
          "type": "number",
          "description": "Page number for pagination",
          "required": false,
          "default": 0
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Number of incidents per page",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "get_incident",
      "name": "Get Incident Details",
      "description": "Retrieve details for a specific incident",
      "http_method": "GET",
      "endpoint": "/rest/api/incidents/{incidentId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "incidentId",
          "type": "string",
          "description": "Incident ID to retrieve",
          "required": true
        }
      ]
    },
    {
      "id": "list_alerts",
      "name": "List Alerts",
      "description": "Retrieve alerts from NetWitness",
      "http_method": "GET",
      "endpoint": "/rest/api/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "since",
          "type": "string",
          "description": "Alerts since this datetime (ISO 8601)",
          "required": false
        },
        {
          "name": "until",
          "type": "string",
          "description": "Alerts until this datetime",
          "required": false
        },
        {
          "name": "pageNumber",
          "type": "number",
          "description": "Page number",
          "required": false,
          "default": 0
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Page size",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "update_incident",
      "name": "Update Incident",
      "description": "Update incident status, assignee, or priority",
      "http_method": "PUT",
      "endpoint": "/rest/api/incidents/{incidentId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "incidentId",
          "type": "string",
          "description": "Incident ID to update",
          "required": true
        },
        {
          "name": "status",
          "type": "string",
          "description": "New status (New, Assigned, InProgress, Remediation, Closed)",
          "required": false
        },
        {
          "name": "assignee",
          "type": "string",
          "description": "User to assign incident to",
          "required": false
        },
        {
          "name": "priority",
          "type": "string",
          "description": "New priority (Low, Medium, High, Critical)",
          "required": false
        }
      ]
    },
    {
      "id": "query_events",
      "name": "Query Events",
      "description": "Query events from NetWitness Concentrator/Broker using meta values",
      "http_method": "GET",
      "endpoint": "/sdk/v1/content",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "NetWitness query (e.g., ip.src=10.0.0.1)",
          "required": true
        },
        {
          "name": "startDate",
          "type": "string",
          "description": "Start date for query",
          "required": false
        },
        {
          "name": "endDate",
          "type": "string",
          "description": "End date for query",
          "required": false
        },
        {
          "name": "size",
          "type": "number",
          "description": "Maximum events to return",
          "required": false,
          "default": 100
        }
      ],
      "observable_type": "ip"
    },
    {
      "id": "get_host_details",
      "name": "Get Host Details",
      "description": "Retrieve endpoint host details and snapshot from NetWitness Endpoint",
      "http_method": "GET",
      "endpoint": "/rest/api/hosts/{hostId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "hostId",
          "type": "string",
          "description": "Host ID or agent ID",
          "required": true
        }
      ]
    }
  ]
}
