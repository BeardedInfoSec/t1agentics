{
  "id": "microsoft_graph_security",
  "name": "Microsoft Graph Security",
  "description": "Integration with Microsoft Graph Security for security operations",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "Microsoft",
  "auth_type": "oauth2",
  "auth_config": {
    "type": "oauth2",
    "client_id": "",
    "client_secret": "",
    "tenant_id": "",
    "token_url": "https://login.microsoftonline.com/{tenant_id}/oauth2/v2.0/token",
    "scope": "https://graph.microsoft.com/.default"
  },
  "base_url": "https://graph.microsoft.com/v1.0",
  "actions": [
    {
      "id": "list_alerts",
      "name": "List Security Alerts",
      "http_method": "GET",
      "endpoint": "/security/alerts_v2",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Get security alerts from Microsoft 365 Defender, Azure Defender, and other Microsoft security products"
    },
    {
      "id": "get_alert",
      "name": "Get Alert Details",
      "http_method": "GET",
      "endpoint": "/security/alerts_v2/{alert_id}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Get detailed information about a security alert"
    },
    {
      "id": "update_alert",
      "name": "Update Alert",
      "http_method": "PATCH",
      "endpoint": "/security/alerts_v2/{alert_id}",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Update alert status, comments, or assigned user"
    },
    {
      "id": "get_secure_score",
      "name": "Get Secure Score",
      "http_method": "GET",
      "endpoint": "/security/secureScores",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Get the organization's Microsoft Secure Score"
    },
    {
      "id": "get_user",
      "name": "Get User Details",
      "http_method": "GET",
      "endpoint": "/users/{user_principal_name}",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 7,
      "description": "Get details about a user for identity enrichment",
      "observable_type": "email"
    },
    {
      "id": "get_sign_ins",
      "name": "Get Sign-in Logs",
      "http_method": "GET",
      "endpoint": "/auditLogs/signIns",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Get Azure AD sign-in logs for a user"
    },
    {
      "id": "list_ti_indicators",
      "name": "List Threat Indicators",
      "http_method": "GET",
      "endpoint": "/security/tiIndicators",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "List threat intelligence indicators"
    }
  ]
}