{
  "id": "google_chronicle_siem",
  "name": "Google Chronicle SIEM",
  "description": "Integrates with Google Security Operations (Chronicle) for UDM search, detection rule management, alert retrieval, asset and IOC investigation via the Chronicle API",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "Google Cloud",
  "auth_type": "oauth2_client",
  "auth_config": {
    "type": "oauth2_client",
    "token_url": "https://oauth2.googleapis.com/token",
    "scope": "https://www.googleapis.com/auth/chronicle-backstory",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://backstory.googleapis.com",
  "actions": [
    {
      "id": "search_udm_events",
      "name": "Search UDM Events",
      "description": "Search for Unified Data Model (UDM) events using Chronicle search syntax",
      "http_method": "POST",
      "endpoint": "/v2/detect/rules:searchEvents",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "UDM search query string",
          "required": true
        },
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in RFC 3339 format",
          "required": true
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in RFC 3339 format",
          "required": true
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum events to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "list_detections",
      "name": "List Detections",
      "description": "List detections generated by Chronicle detection rules",
      "http_method": "GET",
      "endpoint": "/v2/detect/rules/{ruleId}/detections",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "ruleId",
          "type": "string",
          "description": "Rule ID to list detections for (use '-' for all rules)",
          "required": true
        },
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in RFC 3339 format",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in RFC 3339 format",
          "required": false
        },
        {
          "name": "alert_state",
          "type": "string",
          "description": "Filter by alert state (ALERTING, NOT_ALERTING)",
          "required": false
        },
        {
          "name": "page_size",
          "type": "number",
          "description": "Maximum detections per page",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "list_rules",
      "name": "List Detection Rules",
      "description": "List all YARA-L detection rules configured in Chronicle",
      "http_method": "GET",
      "endpoint": "/v2/detect/rules",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "page_size",
          "type": "number",
          "description": "Maximum rules to return per page",
          "required": false,
          "default": 100
        },
        {
          "name": "page_token",
          "type": "string",
          "description": "Pagination token for next page",
          "required": false
        }
      ]
    },
    {
      "id": "create_rule",
      "name": "Create Detection Rule",
      "description": "Create a new YARA-L detection rule in Chronicle",
      "http_method": "POST",
      "endpoint": "/v2/detect/rules",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "ruleText",
          "type": "string",
          "description": "YARA-L 2.0 rule text",
          "required": true
        }
      ]
    },
    {
      "id": "lookup_ioc",
      "name": "Lookup IOC",
      "description": "Look up an indicator of compromise (domain, IP, hash) in Chronicle",
      "http_method": "GET",
      "endpoint": "/v2/ioc:listIOCs",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in RFC 3339 format",
          "required": true
        },
        {
          "name": "page_size",
          "type": "number",
          "description": "Maximum IOCs to return",
          "required": false,
          "default": 100
        }
      ],
      "observable_type": "ip"
    },
    {
      "id": "list_assets",
      "name": "List Assets",
      "description": "List assets that interacted with a specified artifact (IP, domain, hash)",
      "http_method": "GET",
      "endpoint": "/v1/artifact/listassets",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "artifact.domain_name",
          "type": "string",
          "description": "Domain name to look up",
          "required": false
        },
        {
          "name": "artifact.ip",
          "type": "string",
          "description": "IP address to look up",
          "required": false
        },
        {
          "name": "artifact.hash_sha256",
          "type": "string",
          "description": "SHA256 hash to look up",
          "required": false
        },
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in RFC 3339 format",
          "required": true
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in RFC 3339 format",
          "required": true
        },
        {
          "name": "page_size",
          "type": "number",
          "description": "Maximum assets to return",
          "required": false,
          "default": 100
        }
      ],
      "observable_type": "domain"
    },
    {
      "id": "list_alerts",
      "name": "List Alerts",
      "description": "Retrieve alerts from Chronicle",
      "http_method": "GET",
      "endpoint": "/v2/detect/alerts",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in RFC 3339 format",
          "required": false
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in RFC 3339 format",
          "required": false
        },
        {
          "name": "page_size",
          "type": "number",
          "description": "Maximum alerts to return",
          "required": false,
          "default": 100
        }
      ]
    }
  ]
}
