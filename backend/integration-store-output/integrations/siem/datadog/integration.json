{
  "id": "datadog",
  "name": "Datadog",
  "description": "Integration with Datadog for security operations",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "Datadog",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "DD-API-KEY",
    "location": "header"
  },
  "base_url": "https://api.datadoghq.com",
  "actions": [
    {
      "id": "get_security_signals",
      "name": "Get Security Signals",
      "http_method": "POST",
      "endpoint": "/api/v2/security_monitoring/signals/search",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Get security signals (alerts) from Datadog Security Monitoring"
    },
    {
      "id": "list_security_rules",
      "name": "List Security Rules",
      "http_method": "GET",
      "endpoint": "/api/v2/security_monitoring/rules",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "List all security monitoring rules"
    },
    {
      "id": "search_logs",
      "name": "Search Logs",
      "http_method": "POST",
      "endpoint": "/api/v2/logs/events/search",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Search and filter logs in Datadog"
    },
    {
      "id": "get_csm_findings",
      "name": "Get CSM Findings",
      "http_method": "GET",
      "endpoint": "/api/v2/posture_management/findings",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Get Cloud Security Management findings (misconfigurations)"
    },
    {
      "id": "get_incidents",
      "name": "Get Incidents",
      "http_method": "GET",
      "endpoint": "/api/v2/incidents",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "List incidents from Datadog Incident Management"
    },
    {
      "id": "get_host_info",
      "name": "Get Host Info",
      "http_method": "GET",
      "endpoint": "/api/v1/hosts",
      "read_only": true,
      "cacheable": true,
      "cache_ttl_days": 1,
      "description": "Get information about monitored hosts"
    }
  ]
}