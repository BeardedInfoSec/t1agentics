{
  "id": "elastic_security",
  "name": "Elastic Security",
  "description": "Integration with Elastic Security for security operations",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "Elastic",
  "auth_type": "api_key",
  "auth_config": {
    "type": "api_key",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "",
  "actions": [
    {
      "id": "search",
      "name": "Search Events",
      "http_method": "POST",
      "endpoint": "/.logs-*/_search",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Search security events in Elasticsearch"
    },
    {
      "id": "get_alerts",
      "name": "Get Security Alerts",
      "http_method": "POST",
      "endpoint": "/api/detection_engine/signals/search",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Get alerts from Elastic Security"
    }
  ]
}