{
  "id": "sumo_logic_siem",
  "name": "Sumo Logic Cloud SIEM",
  "description": "Integrates with Sumo Logic Cloud SIEM for signal and insight management, entity investigation, log search, and rule management via the Sumo Logic REST API",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "Sumo Logic",
  "auth_type": "basic",
  "auth_config": {
    "type": "basic",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "https://api.{region}.sumologic.com/api",
  "actions": [
    {
      "id": "list_insights",
      "name": "List Insights",
      "description": "Retrieve Cloud SIEM insights (correlated signals grouped into incidents)",
      "http_method": "GET",
      "endpoint": "/sec/v1/insights",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "status",
          "type": "string",
          "description": "Filter by insight status (new, inprogress, closed)",
          "required": false
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Filter by severity (LOW, MEDIUM, HIGH, CRITICAL)",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of results",
          "required": false,
          "default": 50
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        }
      ]
    },
    {
      "id": "get_insight",
      "name": "Get Insight Details",
      "description": "Retrieve details of a specific Cloud SIEM insight",
      "http_method": "GET",
      "endpoint": "/sec/v1/insights/{insightId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "insightId",
          "type": "string",
          "description": "Insight ID to retrieve",
          "required": true
        }
      ]
    },
    {
      "id": "list_signals",
      "name": "List Signals",
      "description": "Retrieve Cloud SIEM signals (individual detection events)",
      "http_method": "GET",
      "endpoint": "/sec/v1/signals",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "created_after",
          "type": "string",
          "description": "Filter signals created after this datetime (ISO 8601)",
          "required": false
        },
        {
          "name": "created_before",
          "type": "string",
          "description": "Filter signals created before this datetime",
          "required": false
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum number of results",
          "required": false,
          "default": 50
        }
      ]
    },
    {
      "id": "update_insight",
      "name": "Update Insight",
      "description": "Update the status or assignee of a Cloud SIEM insight",
      "http_method": "PUT",
      "endpoint": "/sec/v1/insights/{insightId}",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "insightId",
          "type": "string",
          "description": "Insight ID to update",
          "required": true
        },
        {
          "name": "status",
          "type": "string",
          "description": "New status (new, inprogress, closed)",
          "required": false
        },
        {
          "name": "assignee",
          "type": "string",
          "description": "User to assign the insight to",
          "required": false
        },
        {
          "name": "resolution",
          "type": "string",
          "description": "Resolution when closing (TruePositive, FalsePositive, Duplicate, NoAction)",
          "required": false
        }
      ]
    },
    {
      "id": "create_search_job",
      "name": "Create Search Job",
      "description": "Create a new log search job in Sumo Logic",
      "http_method": "POST",
      "endpoint": "/v1/search/jobs",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Sumo Logic search query string",
          "required": true
        },
        {
          "name": "from",
          "type": "string",
          "description": "Start time in ISO 8601 format",
          "required": true
        },
        {
          "name": "to",
          "type": "string",
          "description": "End time in ISO 8601 format",
          "required": true
        },
        {
          "name": "timeZone",
          "type": "string",
          "description": "Time zone for the query (e.g., UTC)",
          "required": false,
          "default": "UTC"
        }
      ]
    },
    {
      "id": "get_search_results",
      "name": "Get Search Results",
      "description": "Retrieve results from a completed search job",
      "http_method": "GET",
      "endpoint": "/v1/search/jobs/{searchJobId}/messages",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "searchJobId",
          "type": "string",
          "description": "Search job ID to retrieve results for",
          "required": true
        },
        {
          "name": "offset",
          "type": "number",
          "description": "Offset for pagination",
          "required": false,
          "default": 0
        },
        {
          "name": "limit",
          "type": "number",
          "description": "Maximum results to return",
          "required": false,
          "default": 100
        }
      ]
    },
    {
      "id": "get_entity",
      "name": "Get Entity Details",
      "description": "Retrieve details about a Cloud SIEM entity (user, IP, hostname, etc.)",
      "http_method": "GET",
      "endpoint": "/sec/v1/entities/{entityId}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "entityId",
          "type": "string",
          "description": "Entity ID to retrieve",
          "required": true
        }
      ]
    }
  ]
}
