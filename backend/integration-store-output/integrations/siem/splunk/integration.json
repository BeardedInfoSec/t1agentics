{
  "id": "splunk",
  "name": "Splunk",
  "description": "Integration with Splunk for security operations",
  "version": "1.0.0",
  "category": "siem",
  "vendor": "Splunk",
  "auth_type": "bearer_token",
  "auth_config": {
    "type": "bearer_token",
    "header_name": "Authorization",
    "location": "header"
  },
  "base_url": "",
  "actions": [
    {
      "id": "search",
      "name": "Run Search",
      "http_method": "POST",
      "endpoint": "/services/search/jobs",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Run a Splunk search query"
    },
    {
      "id": "send_event",
      "name": "Send Event to HEC",
      "http_method": "POST",
      "endpoint": "/services/collector/event",
      "read_only": true,
      "cacheable": false,
      "cache_ttl_days": 30,
      "description": "Send an event to Splunk via HTTP Event Collector"
    }
  ]
}