{
  "id": "akamai_waf",
  "name": "Akamai WAF",
  "description": "Akamai Application Security API for managing WAF security configurations, policies, custom rules, and IP/Geo controls for App and API Protector",
  "version": "1.0.0",
  "category": "waf",
  "vendor": "Akamai",
  "auth_type": "signed",
  "auth_config": {
    "type": "signed",
    "location": "header",
    "note": "Akamai EdgeGrid: Authorization EG1-HMAC-SHA256 scheme"
  },
  "base_url": "https://{host}/appsec/v1",
  "actions": [
    {
      "id": "list_security_configurations",
      "name": "List Security Configurations",
      "description": "Retrieve all WAF security configurations in the account",
      "http_method": "GET",
      "endpoint": "/configs",
      "action_type": "investigate",
      "read_only": true,
      "parameters": []
    },
    {
      "id": "get_security_configuration",
      "name": "Get Security Configuration",
      "description": "Retrieve details of a specific security configuration version",
      "http_method": "GET",
      "endpoint": "/configs/{config_id}/versions/{version_number}",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "config_id",
          "type": "integer",
          "description": "Security configuration ID",
          "required": true
        },
        {
          "name": "version_number",
          "type": "integer",
          "description": "Configuration version number",
          "required": true
        }
      ]
    },
    {
      "id": "list_security_policies",
      "name": "List Security Policies",
      "description": "Retrieve all security policies within a configuration version",
      "http_method": "GET",
      "endpoint": "/configs/{config_id}/versions/{version_number}/security-policies",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "config_id",
          "type": "integer",
          "description": "Security configuration ID",
          "required": true
        },
        {
          "name": "version_number",
          "type": "integer",
          "description": "Configuration version number",
          "required": true
        }
      ]
    },
    {
      "id": "list_custom_rules",
      "name": "List Custom Rules",
      "description": "Retrieve all custom rules defined in a security configuration",
      "http_method": "GET",
      "endpoint": "/configs/{config_id}/custom-rules",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "config_id",
          "type": "integer",
          "description": "Security configuration ID",
          "required": true
        }
      ]
    },
    {
      "id": "create_custom_rule",
      "name": "Create Custom Rule",
      "description": "Create a new custom WAF rule for specific traffic patterns",
      "http_method": "POST",
      "endpoint": "/configs/{config_id}/custom-rules",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "config_id",
          "type": "integer",
          "description": "Security configuration ID",
          "required": true
        },
        {
          "name": "body",
          "type": "object",
          "description": "Custom rule definition including name, conditions, and structured rule logic",
          "required": true
        }
      ]
    },
    {
      "id": "get_ip_geo_firewall",
      "name": "Get IP/Geo Firewall Settings",
      "description": "Retrieve IP and geo-blocking firewall settings for a security policy",
      "http_method": "GET",
      "endpoint": "/configs/{config_id}/versions/{version_number}/security-policies/{policy_id}/ip-geo-firewall",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "config_id",
          "type": "integer",
          "description": "Security configuration ID",
          "required": true
        },
        {
          "name": "version_number",
          "type": "integer",
          "description": "Configuration version number",
          "required": true
        },
        {
          "name": "policy_id",
          "type": "string",
          "description": "Security policy ID",
          "required": true
        }
      ]
    },
    {
      "id": "update_ip_geo_firewall",
      "name": "Update IP/Geo Firewall",
      "description": "Update IP and geo-blocking settings to block or allow specific IPs and countries",
      "http_method": "PUT",
      "endpoint": "/configs/{config_id}/versions/{version_number}/security-policies/{policy_id}/ip-geo-firewall",
      "action_type": "contain",
      "read_only": false,
      "parameters": [
        {
          "name": "config_id",
          "type": "integer",
          "description": "Security configuration ID",
          "required": true
        },
        {
          "name": "version_number",
          "type": "integer",
          "description": "Configuration version number",
          "required": true
        },
        {
          "name": "policy_id",
          "type": "string",
          "description": "Security policy ID",
          "required": true
        },
        {
          "name": "body",
          "type": "object",
          "description": "IP/Geo firewall settings including block mode, IP controls, and geo controls",
          "required": true
        }
      ]
    },
    {
      "id": "list_match_targets",
      "name": "List Match Targets",
      "description": "Retrieve all match targets that define which requests are inspected by which policy",
      "http_method": "GET",
      "endpoint": "/configs/{config_id}/versions/{version_number}/match-targets",
      "action_type": "investigate",
      "read_only": true,
      "parameters": [
        {
          "name": "config_id",
          "type": "integer",
          "description": "Security configuration ID",
          "required": true
        },
        {
          "name": "version_number",
          "type": "integer",
          "description": "Configuration version number",
          "required": true
        }
      ]
    },
    {
      "id": "activate_configuration",
      "name": "Activate Configuration",
      "description": "Activate a security configuration version on staging or production network",
      "http_method": "POST",
      "endpoint": "/activations",
      "action_type": "generic",
      "read_only": false,
      "parameters": [
        {
          "name": "body",
          "type": "object",
          "description": "Activation request including configId, configVersion, network (STAGING/PRODUCTION), and notification emails",
          "required": true
        }
      ]
    }
  ]
}