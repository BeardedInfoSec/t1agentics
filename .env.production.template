# T1 Agentics - Production Environment Configuration
# Copy to .env.production and fill in all values
# Generate secrets: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Admin Account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
ADMIN_EMAIL=admin@example.com

# Database
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
PLATFORM_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXPIRE_MINUTES=1440

# Credentials Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_GENERATE_FERNET_KEY

# License
LICENSE_SECRET_KEY=CHANGE_ME_LICENSE_SECRET

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=T1 Agentics
SMTP_USE_TLS=true

# AI Provider
AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-5-20250929
# Platform-wide daily cost kill-switch (USD). Set to 0 to disable.
CLAUDE_MAX_DAILY_USD=25

# CORS
ALLOWED_ORIGINS=https://your-domain.example
