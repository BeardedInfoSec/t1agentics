# ============================================================================
# T1 Agentics - example environment file
# ============================================================================
# install.sh generates a real .env for you. This template documents every
# variable so you can edit by hand or run a one-off "docker compose" without
# the installer.
#
# Treat the real .env as a secret. Never commit it.
# ============================================================================

# Deployment mode: production | development | test
ENVIRONMENT=production

# ----------------------------------------------------------------------------
# Public surface
# ----------------------------------------------------------------------------
# Hostname this install will serve. Caddy provisions a Let's Encrypt cert for it.
DOMAIN=soc.example.com

# The first user that will be created. Receives platform-admin rights and is
# the contact address for Let's Encrypt.
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
# 12+ characters. CHANGE before any install you care about.
ADMIN_PASSWORD=change-me-please

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
POSTGRES_USER=agentcore
POSTGRES_DB=agentcore
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=change-me-strong-random

# ----------------------------------------------------------------------------
# ClickHouse (UX telemetry + log search)
# ----------------------------------------------------------------------------
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=t1_telemetry

# ----------------------------------------------------------------------------
# Secrets - generate fresh values for every install
# ----------------------------------------------------------------------------
# openssl rand -hex 32
JWT_SECRET_KEY=change-me
PLATFORM_JWT_SECRET=change-me

# Fernet key (32 random bytes, urlsafe base64). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=change-me

# Used to sign approve/reject links in the inbound-lead flow.
# openssl rand -hex 32
LEAD_DRAFT_SIGNING_SECRET=change-me

# ----------------------------------------------------------------------------
# AI provider - BYO API key
# ----------------------------------------------------------------------------
# Bring your own API key. Get one from your AI provider. Leave empty to run
# with AI features disabled - the app will still boot.
ANTHROPIC_API_KEY=

# Which provider the backend should call. "claude" is the production path;
# leaving ANTHROPIC_API_KEY empty silently disables AI features regardless.
AI_PROVIDER=claude
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-5-20250929

# Daily platform-wide cost ceiling (USD). The kill-switch fails open on DB
# error. Set to 0 to disable.
CLAUDE_MAX_DAILY_USD=25

# Optional: Postman API key to enable Postman Public API Network as an
# integration-discovery source. Leave empty to disable that source.
POSTMAN_API_KEY=

# ----------------------------------------------------------------------------
# SMTP (optional - leave blank to disable email)
# ----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=T1 Agentics
SMTP_USE_TLS=true
