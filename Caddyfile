# T1 Agentics - Caddy reverse proxy
# DOMAIN and CADDY_TLS are injected from the compose environment by install.sh:
#   CADDY_TLS=internal       -> Caddy's built-in CA (LAN / private domains)
#   CADDY_TLS=you@email.com  -> public ACME (Let's Encrypt) for a real domain
# The mode is chosen automatically from your domain; override with T1_TLS_MODE.

{
	# While debugging a public cert you can point at Let's Encrypt staging:
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$DOMAIN} {
	# "internal" uses Caddy's own CA for private/LAN domains; an email address
	# switches this to public ACME. A public domain that resolves to this host
	# is required for ACME to succeed.
	tls {$CADDY_TLS:internal}

	encode zstd gzip

	log {
		output stdout
		format console
		level INFO
	}

	# API + websocket routes go to the FastAPI backend.
	@api {
		path /api/* /ws/* /docs /openapi.json /redoc
	}
	handle @api {
		reverse_proxy backend:8000 {
			transport http {
				read_timeout 300s
				write_timeout 300s
				dial_timeout 10s
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Everything else is the React SPA served by nginx on :80 inside the container.
	handle {
		reverse_proxy frontend:80
	}

	# Sensible security headers. CSP is intentionally permissive — the SPA
	# loads inline styles and the analyst can paste arbitrary external IOCs;
	# tighten per deployment if required.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

# Health endpoint that does not require TLS / a hostname.
:80 {
	respond /healthz "ok" 200
}
